			local btn = Mk("TextButton", {
				Parent = row,
				Position = UD2(0, 0, 0, 22),
				Size = UD2(1, 0, 0, 25),
				BackgroundColor3 = FrontierLib.Theme.PanelDark,
				BorderSizePixel = 0,
				Text = "",
				AutoButtonColor = false,
				ZIndex = 13,
			})
			FrontierLib:_RegisterTheme(btn, "BackgroundColor3", "PanelDark")
			AddCorner(btn, 3)
			AddStroke(btn, "Border", 0.25, 1)
			AddHover(btn, "PanelDark", "Hover")

			local valTxt = Mk("TextLabel", {
				Parent = btn,
				Position = UD2(0, 7, 0, 0),
				Size = UD2(1, -28, 1, 0),
				BackgroundTransparency = 1,
				Text = "",
				Font = Enum.Font.SourceSans,
				TextSize = 14,
				TextColor3 = FrontierLib.Theme.SubText,
