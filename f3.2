function FrontierLib:CreateWindow(cfg)
	cfg = cfg or {}

	local titleText = cfg.Title or "frontierism UI"
	local winW = cfg.Width or 700
	local winH = cfg.Height or 500
	local minW = cfg.MinWidth or 560
	local minH = cfg.MinHeight or 360

	if cfg.Accent then
		self.Theme.Accent = cfg.Accent
	end

	if cfg.ConfigFolder then
		self.ConfigFolder = cfg.ConfigFolder
	end

	local old = GuiParent:FindFirstChild("Frontierism_UI")
	if old then
		old:Destroy()
	end

	local sg = Mk("ScreenGui", {
		Parent = GuiParent,
		Name = "Frontierism_UI",
		ResetOnSpawn = false,
		IgnoreGuiInset = true,
		ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
	})

	tinsert(self._Guis, sg)

	local WindowObj = {
		Tabs = {},
		ActiveTab = nil,
		Elements = {},
		Sections = {},
		Open = true,
		Minimized = false,
		_Root = nil,
		_Gui = sg,
		_Required = {
			Credits = false,
			Settings = false,
			UIKeybinds = false,
		},
	}

	tinsert(self._Windows, WindowObj)

	------------------------------------------------------------------------------------------------
	-- Tooltip
	------------------------------------------------------------------------------------------------

	local ttFrame = Mk("Frame", {
		Parent = sg,
		Size = UD2(0, 0, 0, 22),
		BackgroundColor3 = RGB(25, 25, 25),
		BackgroundTransparency = 0.08,
		BorderSizePixel = 0,
		Visible = false,
		ZIndex = 100000,
	})

	AddCorner(ttFrame, 3)
	AddStroke(ttFrame, "Border", 0.15, 1)

	local ttText = Mk("TextLabel", {
		Parent = ttFrame,
		Size = UD2(1, 0, 1, 0),
		BackgroundTransparency = 1,
		Font = Enum.Font.SourceSans,
		TextSize = 14,
		TextColor3 = self.Theme.Text,
		Text = "",
		ZIndex = 100001,
	})

	self:_RegisterTheme(ttText, "TextColor3", "Text")

	local ttTarget = nil

	Connect(rs.RenderStepped, function(dt)
		if not ttFrame or not ttFrame.Parent then
			return
		end

		if ttFrame.Visible then
			local mp = uis:GetMouseLocation()
			local target = UD2(0, mp.X + 14, 0, mp.Y + 14)

			if not ttTarget then
				ttFrame.Position = target
			end

			ttTarget = target
			ttFrame.Position = ttFrame.Position:Lerp(ttTarget, clamp(dt * 20, 0, 1))
		else
			ttTarget = nil
		end
	end)

	local function AddTooltip(inst, text)
		if not inst or not text or text == "" then
			return
		end

		Connect(inst.MouseEnter, function()
			ttText.Text = " " .. tostring(text) .. " "
			ttFrame.Size = UD2(0, TextWidth(ttText.Text, Enum.Font.SourceSans, 14) + 12, 0, 22)
			ttFrame.Visible = true
		end)

		Connect(inst.MouseLeave, function()
			ttFrame.Visible = false
		end)
	end

