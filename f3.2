		out = false,
	})

	Tw(frame, {BackgroundTransparency = 0.04}, 0.22)
	Tw(stroke, {Transparency = 0.15}, 0.22)
	Tw(accent, {BackgroundTransparency = 0}, 0.22)
	Tw(icon, {TextTransparency = 0}, 0.22)
	Tw(text, {TextTransparency = 0}, 0.22)
	Tw(prog, {BackgroundTransparency = 0.15}, 0.22)
end

Connect(rs.RenderStepped, function()
	if not notifGui or not notifGui.Parent then
		return
	end

	local now = tk()
	local topY = 34
	local gap = 8
	local dead = {}

	for i, n in ipairs(notifList) do
		if not n.frame or not n.frame.Parent then
			tinsert(dead, i)
			continue
		end

		local age = now - n.born
		local targetY = topY + (i - 1) * (42 + gap)
		local current = n.frame.Position
		n.frame.Position = UD2(
			0.5,
			-n.frame.AbsoluteSize.X / 2,
			0,
			current.Y.Offset + (targetY - current.Y.Offset) * 0.22
		)

		if age >= n.life and not n.out then
			n.out = true

			Tw(n.frame, {BackgroundTransparency = 1}, 0.2)
			Tw(n.stroke, {Transparency = 1}, 0.2)
			Tw(n.accent, {BackgroundTransparency = 1}, 0.2)
			Tw(n.icon, {TextTransparency = 1}, 0.2)
			Tw(n.text, {TextTransparency = 1}, 0.2)
			Tw(n.prog, {BackgroundTransparency = 1}, 0.2)

			task.delay(0.22, function()
				SafeDestroy(n.frame)
			end)

			tinsert(dead, i)
		else
			local pct = clamp(1 - (age / n.life), 0, 1)
			n.prog.Size = UD2(pct, 0, 0, 2)
		end
	end

	for i = #dead, 1, -1 do
		tremove(notifList, dead[i])
	end
end)

----------------------------------------------------------------------------------------------------
-- Required Watchdog
----------------------------------------------------------------------------------------------------

local function StartRequiredWatchdog(WindowObj)
	task.delay(1, function()
		if not WindowObj or not WindowObj._Required then
			return
		end

		local started = tk()

		while tk() - started < 5 do
			local missing = {}

			if not WindowObj._Required.Credits then
				tinsert(missing, "credits")
			end

			if not WindowObj._Required.Settings then
				tinsert(missing, "settings")
			end

			if not WindowObj._Required.UIKeybinds then
				tinsert(missing, "ui keybinds")
			end

			if #missing == 0 then
				return
			end

			for _, item in ipairs(missing) do
				warn("where is the " .. item .. "???")
			end

			task.wait(0.2)
		end
	end)
end

