	-- Intro / Root
	------------------------------------------------------------------------------------------------

	local blur = nil
	if cfg.Blur ~= false then
		blur = Mk("BlurEffect", {
			Parent = lighting,
			Name = "Frontier_Blur",
			Size = 0,
		})
		if blur then
			Tw(blur, {Size = 12}, 0.45)
		end
	end

	local root = Mk("Frame", {
		Parent = sg,
		Size = UD2(0, winW, 0, winH),
		Position = UD2(0.5, -winW / 2, 0.5, -winH / 2),
		BackgroundColor3 = self.Theme.Bg,
		BorderSizePixel = 0,
		ClipsDescendants = true,
		Visible = false,
		ZIndex = 5,
	})

