		local bar = Mk("Frame", {
			Parent = barBg,
			Size = UD2(0, 0, 1, 0),
			BackgroundColor3 = self.Theme.Accent,
			BorderSizePixel = 0,
			ZIndex = 10001,
		})
		self:_RegisterTheme(bar, "BackgroundColor3", "Accent")

		Tw(intro, {
			Size = UD2(0, w, 0, h),
			Position = UD2(0.5, -w / 2, 0.5, -h / 2)
		}, 0.38, Enum.EasingStyle.Quart)

		task.wait(0.45)

		local steps = {
			{"loading theme...", 0.25, 0.22},
			{"building components...", 0.58, 0.28},
			{"mounting window...", 0.83, 0.22},
			{"done.", 1, 0.18},
		}

		for _, step in ipairs(steps) do
			if not intro.Parent then
				return
			end
			status.Text = step[1]
			Tw(bar, {Size = UD2(step[2], 0, 1, 0)}, step[3], Enum.EasingStyle.Sine)
			task.wait(step[3])
		end

		Tw(intro, {
			Size = UD2(0, w, 0, 0),
			Position = UD2(0.5, -w / 2, 0.5, 0)
		}, 0.35, Enum.EasingStyle.Quart)

		task.wait(0.35)
		SafeDestroy(intro)

		if root and root.Parent then
			ShowRoot()
		end

		task.wait(0.35)

		if blur and blur.Parent then
			Tw(blur, {Size = 0}, 0.4)
			task.delay(0.42, function()
				SafeDestroy(blur)
			end)
		end
	end)

