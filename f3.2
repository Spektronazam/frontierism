				TextTruncate = Enum.TextTruncate.AtEnd,
				ZIndex = 14,
			})
			FrontierLib:_RegisterTheme(valTxt, "TextColor3", "SubText")

			local arrow = Mk("TextLabel", {
				Parent = btn,
				Position = UD2(1, -21, 0, 0),
				Size = UD2(0, 18, 1, 0),
				BackgroundTransparency = 1,
				Text = "▼",
				Font = Enum.Font.SourceSans,
				TextSize = 12,
				TextColor3 = FrontierLib.Theme.SubText,
				ZIndex = 14,
			})
			FrontierLib:_RegisterTheme(arrow, "TextColor3", "SubText")

			local menuOpen = false
			local menuFrame = nil

			local obj = {}

			local function updateDisplay(noCallback)
				if isMulti then
					local selected = {}

					for _, item in ipairs(items) do
						if state[item] then
							tinsert(selected, tostring(item))
						end
					end

					valTxt.Text = #selected > 0 and table.concat(selected, ", ") or "None"
					SetFlag(p.Flag, state)
				else
					valTxt.Text = tostring(state)
					SetFlag(p.Flag, state)
				end

				if not noCallback then
					FireCallback(p.Callback, state)
				end
			end

			local function closeMenu()
				if menuFrame then
					SafeDestroy(menuFrame)
					menuFrame = nil
				end
				menuOpen = false
				arrow.Text = "▼"
			end

			local function createItemButton(item)
				local selected = isMulti and state[item] or state == item

				local itBtn = Mk("TextButton", {
					Parent = menuFrame,
					Size = UD2(1, 0, 0, 24),
					BackgroundColor3 = FrontierLib.Theme.PanelDark,
					BackgroundTransparency = 1,
					BorderSizePixel = 0,
					Text = "  " .. tostring(item),
					Font = Enum.Font.SourceSans,
					TextSize = 14,
					TextColor3 = selected and FrontierLib.Theme.Accent or FrontierLib.Theme.Text,
					TextXAlignment = Enum.TextXAlignment.Left,
					AutoButtonColor = false,
					ZIndex = 1002,
				})

				AddHover(itBtn, "PanelDark", "Hover")

				Connect(itBtn.MouseButton1Click, function()
					if isMulti then
						state[item] = not state[item]
						selected = state[item]
						itBtn.TextColor3 = selected and FrontierLib.Theme.Accent or FrontierLib.Theme.Text
					else
						state = item
						closeMenu()
					end

					updateDisplay(false)
				end)
			end

			local function openMenu()
				if menuOpen then
					closeMenu()
					return
				end

				menuOpen = true
				arrow.Text = "▲"

				local height = min(#items * 24 + 4, 170)
				local x = btn.AbsolutePosition.X
				local y = btn.AbsolutePosition.Y + btn.AbsoluteSize.Y + 2

				if y + height > workspace.CurrentCamera.ViewportSize.Y then
					y = btn.AbsolutePosition.Y - height - 2
				end

				menuFrame = Mk("ScrollingFrame", {
					Parent = sg,
					Size = UD2(0, btn.AbsoluteSize.X, 0, height),
					Position = UD2(0, x, 0, y),
					BackgroundColor3 = FrontierLib.Theme.PanelDark,
					BorderSizePixel = 0,
					ScrollBarThickness = 2,
					ScrollBarImageColor3 = FrontierLib.Theme.Accent,
					CanvasSize = UD2(0, 0, 0, 0),
					ZIndex = 1000,
				})
				FrontierLib:_RegisterTheme(menuFrame, "BackgroundColor3", "PanelDark")
				FrontierLib:_RegisterTheme(menuFrame, "ScrollBarImageColor3", "Accent")
				AddCorner(menuFrame, 3)
				AddStroke(menuFrame, "Border", 0, 1)

				local layout = AddList(menuFrame, 0)

				Connect(layout:GetPropertyChangedSignal("AbsoluteContentSize"), function()
					if menuFrame then
						menuFrame.CanvasSize = UD2(0, 0, 0, layout.AbsoluteContentSize.Y)
					end
				end)

				for _, item in ipairs(items) do
					createItemButton(item)
				end
			end

			Connect(btn.MouseButton1Click, openMenu)

			Connect(uis.InputBegan, function(input)
				if menuOpen and input.UserInputType == Enum.UserInputType.MouseButton1 then
					if menuFrame and not IsMouseInside(menuFrame, input) and not IsMouseInside(btn, input) then
						closeMenu()
					end
				end
			end)

			function obj:Set(v)
				if isMulti then
					state = {}

					if type(v) == "table" then
						for k, val in pairs(v) do
							if type(k) == "number" then
								state[val] = true
							else
								state[k] = val == true
							end
						end
					end
				else
					state = v
				end

				updateDisplay(false)
			end

			function obj:Get()
				return state
			end

			function obj:Refresh(newItems, preferred)
				items = newItems or {}

				if isMulti then
					local valid = {}
					for _, item in ipairs(items) do
						valid[item] = true
					end

					for k in pairs(state) do
						if not valid[k] then
							state[k] = nil
						end
					end
				else
					local found = false

					for _, item in ipairs(items) do
						if item == state then
							found = true
							break
						end
					end

					if preferred then
						state = preferred
					elseif not found then
						state = items[1] or "None"
					end
				end

				closeMenu()
				updateDisplay(false)
			end

			function obj:SetVisible(v)
				row.Visible = v == true
				section:_UpdateSize()
			end

			if p.Flag then
				FrontierLib.Pointers[p.Flag] = obj
			end

			AddTooltip(row, p.Tip)
			updateDisplay(true)
			RegisterElement(row, p.Text)
			section:_UpdateSize()

			return obj
		end

		function api:AddColorPicker(p)
			p = p or {}

			local color = p.Default or C3(1, 1, 1)
			local h, s, v = color:ToHSV()

			local row = Mk("Frame", {
				Parent = section._Holder,
				Size = UD2(1, 0, 0, 28),
				BackgroundTransparency = 1,
				ZIndex = 12,
			})

			local label = Mk("TextLabel", {
				Parent = row,
				Position = UD2(0, 0, 0, 0),
				Size = UD2(1, -55, 1, 0),
				BackgroundTransparency = 1,
				Text = tostring(p.Text or "Color"),
				Font = Enum.Font.SourceSans,
				TextSize = 14,
				TextColor3 = FrontierLib.Theme.Text,
				TextXAlignment = Enum.TextXAlignment.Left,
				ZIndex = 13,
			})
			FrontierLib:_RegisterTheme(label, "TextColor3", "Text")

			local cBtn = Mk("TextButton", {
				Parent = row,
				Position = UD2(1, -46, 0, 3),
				Size = UD2(0, 46, 0, 20),
				BackgroundColor3 = color,
				BorderSizePixel = 0,
				Text = "",
				AutoButtonColor = false,
				ZIndex = 13,
			})
			AddCorner(cBtn, 3)
			AddStroke(cBtn, "Border", 0.15, 1)

			local menuOpen = false
			local popup = nil
			local hexBox = nil
			local svMarker = nil
			local hueMarker = nil
			local preview = nil

			local obj = {}

			local function closePopup()
				if popup then
					SafeDestroy(popup)
					popup = nil
				end
				menuOpen = false
			end

			local function updateColor(c, noCallback)
				if typeof(c) ~= "Color3" then
					return
				end

				color = c
				h, s, v = color:ToHSV()
				cBtn.BackgroundColor3 = color

				if preview then
					preview.BackgroundColor3 = color
				end

				if hexBox and hexBox.Parent then
					hexBox.Text = ColorToHex(color)
				end

				if svMarker and svMarker.Parent then
					svMarker.Position = UD2(s, -4, 1 - v, -4)
				end

				if hueMarker and hueMarker.Parent then
					hueMarker.Position = UD2(0, -2, h, -3)
				end

				SetFlag(p.Flag, ColorToHex(color))

				if not noCallback then
					FireCallback(p.Callback, color)
				end
			end

			local function buildPopup()
				closePopup()
				menuOpen = true

				local px = cBtn.AbsolutePosition.X - 174
				local py = cBtn.AbsolutePosition.Y + 26

				popup = Mk("Frame", {
					Parent = sg,
					Size = UD2(0, 220, 0, 176),
					Position = UD2(0, px, 0, py),
					BackgroundColor3 = FrontierLib.Theme.PanelDark,
					BorderSizePixel = 0,
					ZIndex = 1200,
				})
				FrontierLib:_RegisterTheme(popup, "BackgroundColor3", "PanelDark")
				AddCorner(popup, 4)
				AddStroke(popup, "Border", 0, 1)

				local sv = Mk("TextButton", {
					Parent = popup,
					Position = UD2(0, 10, 0, 10),
					Size = UD2(0, 140, 0, 110),
					BackgroundColor3 = HSV(h, 1, 1),
					BorderSizePixel = 0,
					Text = "",
					AutoButtonColor = false,
					ZIndex = 1201,
				})
				AddCorner(sv, 3)

				local whiteGrad = Mk("Frame", {
					Parent = sv,
					Size = UD2(1, 0, 1, 0),
					BackgroundColor3 = C3(1, 1, 1),
					BorderSizePixel = 0,
					ZIndex = 1202,
				})
				AddCorner(whiteGrad, 3)
				Mk("UIGradient", {
					Parent = whiteGrad,
					Transparency = NumberSequence.new({
						NumberSequenceKeypoint.new(0, 0),
						NumberSequenceKeypoint.new(1, 1),
					}),
					Rotation = 0,
				})

				local blackGrad = Mk("Frame", {
					Parent = sv,
					Size = UD2(1, 0, 1, 0),
					BackgroundColor3 = C3(0, 0, 0),
					BorderSizePixel = 0,
					ZIndex = 1203,
				})
				AddCorner(blackGrad, 3)
				Mk("UIGradient", {
					Parent = blackGrad,
					Transparency = NumberSequence.new({
						NumberSequenceKeypoint.new(0, 1),
						NumberSequenceKeypoint.new(1, 0),
					}),
					Rotation = 90,
				})

				svMarker = Mk("Frame", {
					Parent = sv,
					Size = UD2(0, 8, 0, 8),
					Position = UD2(s, -4, 1 - v, -4),
					BackgroundColor3 = C3(1, 1, 1),
					BorderSizePixel = 0,
					ZIndex = 1205,
				})
				AddCorner(svMarker, 8)
				AddStroke(svMarker, "Border", 0, 1)

				local hueBar = Mk("TextButton", {
					Parent = popup,
					Position = UD2(0, 160, 0, 10),
					Size = UD2(0, 14, 0, 110),
					BackgroundColor3 = C3(1, 1, 1),
					BorderSizePixel = 0,
					Text = "",
					AutoButtonColor = false,
					ZIndex = 1201,
				})
				AddCorner(hueBar, 3)

				Mk("UIGradient", {
					Parent = hueBar,
					Rotation = 90,
					Color = ColorSequence.new({
						ColorSequenceKeypoint.new(0.000, RGB(255, 0, 0)),
						ColorSequenceKeypoint.new(0.167, RGB(255, 255, 0)),
						ColorSequenceKeypoint.new(0.333, RGB(0, 255, 0)),
						ColorSequenceKeypoint.new(0.500, RGB(0, 255, 255)),
						ColorSequenceKeypoint.new(0.667, RGB(0, 0, 255)),
						ColorSequenceKeypoint.new(0.833, RGB(255, 0, 255)),
						ColorSequenceKeypoint.new(1.000, RGB(255, 0, 0)),
					})
				})

				hueMarker = Mk("Frame", {
					Parent = hueBar,
					Size = UD2(1, 4, 0, 6),
					Position = UD2(0, -2, h, -3),
					BackgroundColor3 = C3(1, 1, 1),
					BorderSizePixel = 0,
					ZIndex = 1205,
				})
				AddCorner(hueMarker, 2)
				AddStroke(hueMarker, "Border", 0, 1)

				preview = Mk("Frame", {
					Parent = popup,
					Position = UD2(0, 184, 0, 10),
					Size = UD2(0, 26, 0, 110),
					BackgroundColor3 = color,
					BorderSizePixel = 0,
					ZIndex = 1201,
				})
				AddCorner(preview, 3)
				AddStroke(preview, "Border", 0.2, 1)

				hexBox = Mk("TextBox", {
					Parent = popup,
					Position = UD2(0, 10, 0, 132),
					Size = UD2(1, -20, 0, 26),
					BackgroundColor3 = FrontierLib.Theme.Bg,
					BorderSizePixel = 0,
					Text = ColorToHex(color),
					Font = Enum.Font.SourceSans,
					TextSize = 14,
					TextColor3 = FrontierLib.Theme.Text,
					ClearTextOnFocus = false,
					ZIndex = 1201,
				})
				FrontierLib:_RegisterTheme(hexBox, "BackgroundColor3", "Bg")
				FrontierLib:_RegisterTheme(hexBox, "TextColor3", "Text")
				AddCorner(hexBox, 3)
				AddStroke(hexBox, "Border", 0.2, 1)

				local svDragging = false
				local hueDragging = false

				local function updateSV(input)
					local x = clamp((input.Position.X - sv.AbsolutePosition.X) / max(sv.AbsoluteSize.X, 1), 0, 1)
					local y = clamp((input.Position.Y - sv.AbsolutePosition.Y) / max(sv.AbsoluteSize.Y, 1), 0, 1)

					s = x
					v = 1 - y

					updateColor(HSV(h, s, v), false)
				end

				local function updateHue(input)
					local y = clamp((input.Position.Y - hueBar.AbsolutePosition.Y) / max(hueBar.AbsoluteSize.Y, 1), 0, 1)

					h = y
					sv.BackgroundColor3 = HSV(h, 1, 1)

					updateColor(HSV(h, s, v), false)
				end

				Connect(sv.InputBegan, function(input)
					if input.UserInputType == Enum.UserInputType.MouseButton1 then
						svDragging = true
						updateSV(input)
					end
				end)

				Connect(hueBar.InputBegan, function(input)
					if input.UserInputType == Enum.UserInputType.MouseButton1 then
						hueDragging = true
						updateHue(input)
					end
				end)

				Connect(uis.InputChanged, function(input)
					if input.UserInputType == Enum.UserInputType.MouseMovement then
						if svDragging then
							updateSV(input)
						elseif hueDragging then
							updateHue(input)
						end
					end
				end)

				Connect(uis.InputEnded, function(input)
					if input.UserInputType == Enum.UserInputType.MouseButton1 then
						svDragging = false
						hueDragging = false
					end
				end)

				Connect(hexBox.FocusLost, function()
					local c = HexToColor(hexBox.Text)
					if c then
						updateColor(c, false)
						if sv and sv.Parent then
							local nh = c:ToHSV()
							sv.BackgroundColor3 = HSV(nh, 1, 1)
						end
					else
						hexBox.Text = ColorToHex(color)
					end
				end)
			end

			Connect(cBtn.MouseButton1Click, function()
				if menuOpen then
					closePopup()
				else
					buildPopup()
				end
			end)

			Connect(uis.InputBegan, function(input)
				if menuOpen and input.UserInputType == Enum.UserInputType.MouseButton1 then
					if popup and not IsMouseInside(popup, input) and not IsMouseInside(cBtn, input) then
						closePopup()
					end
				end
			end)

			function obj:Set(c)
				if typeof(c) == "string" then
					c = HexToColor(c)
				end
				updateColor(c, false)
			end

			function obj:Get()
				return color
			end

			function obj:SetVisible(vv)
				row.Visible = vv == true
				section:_UpdateSize()
			end

			if p.Flag then
				FrontierLib.Pointers[p.Flag] = obj
			end

			AddTooltip(row, p.Tip)
			updateColor(color, true)
			RegisterElement(row, p.Text)
			section:_UpdateSize()

			return obj
		end

		function api:AddKeybind(p)
			p = p or {}

			local key = tostring(p.Default or "None")
			if typeof(p.Default) == "EnumItem" then
				key = p.Default.Name
			end

			local row = Mk("Frame", {
				Parent = section._Holder,
				Size = UD2(1, 0, 0, 28),
				BackgroundTransparency = 1,
				ZIndex = 12,
			})

			local label = Mk("TextLabel", {
				Parent = row,
				Position = UD2(0, 0, 0, 0),
				Size = UD2(1, -92, 1, 0),
				BackgroundTransparency = 1,
				Text = tostring(p.Text or "Keybind"),
				Font = Enum.Font.SourceSans,
				TextSize = 14,
				TextColor3 = FrontierLib.Theme.Text,
				TextXAlignment = Enum.TextXAlignment.Left,
				ZIndex = 13,
			})
			FrontierLib:_RegisterTheme(label, "TextColor3", "Text")

			local btn = Mk("TextButton", {
				Parent = row,
				Position = UD2(1, -86, 0, 3),
				Size = UD2(0, 86, 0, 22),
				BackgroundColor3 = FrontierLib.Theme.PanelDark,
				BorderSizePixel = 0,
				Text = "[" .. key .. "]",
				Font = Enum.Font.SourceSans,
				TextSize = 13,
				TextColor3 = FrontierLib.Theme.SubText,
				AutoButtonColor = false,
				ZIndex = 13,
			})
			FrontierLib:_RegisterTheme(btn, "BackgroundColor3", "PanelDark")
			FrontierLib:_RegisterTheme(btn, "TextColor3", "SubText")
			AddCorner(btn, 3)
			AddStroke(btn, "Border", 0.25, 1)
			AddHover(btn, "PanelDark", "Hover")

			local binding = false
			local obj = {}

			local function updateBind(noCallback)
				btn.Text = "[" .. key .. "]"
				SetFlag(p.Flag, key)

				if key == "None" then
					FrontierLib.Keybinds[p.Text] = nil
				else
					FrontierLib.Keybinds[p.Text] = {
						Name = p.Text or "Keybind",
						Key = key,
						OnPressed = p.OnPressed,
					}
				end

				if not noCallback then
					FireCallback(p.Callback, key)
				end
			end

			Connect(btn.MouseButton1Click, function()
				if binding then
					return
				end

				binding = true
				btn.Text = "[...]"

				local c
				c = uis.InputBegan:Connect(function(input)
					if input.UserInputType == Enum.UserInputType.Keyboard
						or input.UserInputType.Name:find("MouseButton") then

						local name = InputToName(input)

						if name == "Escape" or name == "Backspace" then
							key = "None"
						else
							key = name
						end

						binding = false
						updateBind(false)

						if c then
							c:Disconnect()
						end
					end
				end)
			end)

			function obj:Set(k)
				if typeof(k) == "EnumItem" then
					key = k.Name
				else
					key = tostring(k or "None")
				end
				updateBind(false)
			end

			function obj:Get()
				return key
			end

			function obj:SetVisible(v)
				row.Visible = v == true
				section:_UpdateSize()
			end

			if p.Flag then
				FrontierLib.Pointers[p.Flag] = obj
			end

			AddTooltip(row, p.Tip)
			updateBind(true)
			RegisterElement(row, p.Text)
			section:_UpdateSize()

			return obj
		end

		function api:AddTextInput(p)
			p = p or {}

			local row = Mk("Frame", {
				Parent = section._Holder,
				Size = UD2(1, 0, 0, 48),
				BackgroundTransparency = 1,
				ZIndex = 12,
			})

			local label = Mk("TextLabel", {
				Parent = row,
				Position = UD2(0, 0, 0, 0),
				Size = UD2(1, 0, 0, 17),
				BackgroundTransparency = 1,
				Text = tostring(p.Text or "Input"),
				Font = Enum.Font.SourceSans,
				TextSize = 14,
				TextColor3 = FrontierLib.Theme.Text,
				TextXAlignment = Enum.TextXAlignment.Left,
				ZIndex = 13,
			})
			FrontierLib:_RegisterTheme(label, "TextColor3", "Text")

			local box = Mk("TextBox", {
				Parent = row,
				Position = UD2(0, 0, 0, 22),
				Size = UD2(1, 0, 0, 25),
				BackgroundColor3 = FrontierLib.Theme.PanelDark,
				BorderSizePixel = 0,
				Text = tostring(p.Default or ""),
				PlaceholderText = tostring(p.Placeholder or "..."),
				PlaceholderColor3 = FrontierLib.Theme.SubText,
				Font = Enum.Font.SourceSans,
				TextSize = 14,
				TextColor3 = FrontierLib.Theme.Text,
				ClearTextOnFocus = false,
				ZIndex = 13,
			})
			FrontierLib:_RegisterTheme(box, "BackgroundColor3", "PanelDark")
			FrontierLib:_RegisterTheme(box, "TextColor3", "Text")
			FrontierLib:_RegisterTheme(box, "PlaceholderColor3", "SubText")
			AddCorner(box, 3)
			AddStroke(box, "Border", 0.25, 1)

			local obj = {}

			local function update(noCallback)
				SetFlag(p.Flag, box.Text)
				if not noCallback then
					FireCallback(p.Callback, box.Text)
				end
			end

			Connect(box.FocusLost, function()
				update(false)
			end)

			function obj:Set(v)
				box.Text = tostring(v or "")
				update(false)
			end

			function obj:Get()
				return box.Text
			end

			function obj:SetVisible(v)
				row.Visible = v == true
				section:_UpdateSize()
			end

			if p.Flag then
				FrontierLib.Pointers[p.Flag] = obj
			end

			AddTooltip(row, p.Tip)
			update(true)
			RegisterElement(row, p.Text)
			section:_UpdateSize()

			return obj
		end

		return api
	end

