			})
			FrontierLib:_RegisterTheme(box, "BackgroundColor3", "PanelDark")
			AddCorner(box, 3)
			AddStroke(box, "Border", 0.15, 1)

			local fill = Mk("Frame", {
				Parent = box,
				Size = UD2(1, -6, 1, -6),
				Position = UD2(0, 3, 0, 3),
				BackgroundColor3 = FrontierLib.Theme.Accent,
				BackgroundTransparency = 1,
				BorderSizePixel = 0,
				ZIndex = 14,
			})
			FrontierLib:_RegisterTheme(fill, "BackgroundColor3", "Accent")
			AddCorner(fill, 2)

			local label = Mk("TextLabel", {
				Parent = row,
				Position = UD2(0, 25, 0, 0),
				Size = UD2(1, -25, 1, 0),
				BackgroundTransparency = 1,
				Text = tostring(p.Text or "Toggle"),
				Font = Enum.Font.SourceSans,
				TextSize = 14,
				TextColor3 = FrontierLib.Theme.Text,
				TextXAlignment = Enum.TextXAlignment.Left,
				ZIndex = 13,
			})
			FrontierLib:_RegisterTheme(label, "TextColor3", "Text")
			AddTooltip(row, p.Tip)

			local state = p.Default == true
			SetFlag(p.Flag, state)

			local obj = {}

			local function update(noCallback)
				SetFlag(p.Flag, state)
				Tw(fill, {BackgroundTransparency = state and 0 or 1}, 0.12)
				if not noCallback then
					FireCallback(p.Callback, state)
				end
			end

			Connect(box.MouseButton1Click, function()
				state = not state
				update(false)
			end)

			Connect(label.InputBegan, function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 then
					state = not state
					update(false)
				end
			end)

			function obj:Set(v)
				state = v == true
				update(false)
			end

			function obj:Get()
				return state
			end

			function obj:SetVisible(v)
				row.Visible = v == true
				section:_UpdateSize()
			end

			if p.Flag then
				FrontierLib.Pointers[p.Flag] = obj
			end

			update(true)
			RegisterElement(row, p.Text)
			section:_UpdateSize()

			return obj
		end

		function api:AddSlider(p)
			p = p or {}

			local minVal = p.Min or 0
			local maxVal = p.Max or 100
			local decimals = p.Decimals or 0
			local value = p.Default
			if value == nil then
				value = minVal
			end

			local row = Mk("Frame", {
				Parent = section._Holder,
				Size = UD2(1, 0, 0, 42),
				BackgroundTransparency = 1,
				ZIndex = 12,
			})

			local label = Mk("TextLabel", {
				Parent = row,
				Position = UD2(0, 0, 0, 0),
				Size = UD2(1, -60, 0, 17),
				BackgroundTransparency = 1,
				Text = tostring(p.Text or "Slider"),
				Font = Enum.Font.SourceSans,
				TextSize = 14,
				TextColor3 = FrontierLib.Theme.Text,
				TextXAlignment = Enum.TextXAlignment.Left,
				ZIndex = 13,
			})
			FrontierLib:_RegisterTheme(label, "TextColor3", "Text")

			local valueBox = Mk("TextBox", {
				Parent = row,
				Position = UD2(1, -58, 0, 0),
				Size = UD2(0, 58, 0, 17),
				BackgroundTransparency = 1,
				Text = "",
				Font = Enum.Font.SourceSans,
				TextSize = 14,
				TextColor3 = FrontierLib.Theme.Accent,
				TextXAlignment = Enum.TextXAlignment.Right,
				ClearTextOnFocus = false,
				ZIndex = 13,
			})
			FrontierLib:_RegisterTheme(valueBox, "TextColor3", "Accent")

			local track = Mk("TextButton", {
				Parent = row,
				Position = UD2(0, 0, 0, 25),
				Size = UD2(1, 0, 0, 9),
				BackgroundColor3 = FrontierLib.Theme.PanelDark,
				BorderSizePixel = 0,
				Text = "",
				AutoButtonColor = false,
				ZIndex = 13,
			})
			FrontierLib:_RegisterTheme(track, "BackgroundColor3", "PanelDark")
			AddCorner(track, 3)
			AddStroke(track, "Border", 0.3, 1)

			local fill = Mk("Frame", {
				Parent = track,
				Size = UD2(0, 0, 1, 0),
				BackgroundColor3 = FrontierLib.Theme.Accent,
				BorderSizePixel = 0,
				ZIndex = 14,
			})
			FrontierLib:_RegisterTheme(fill, "BackgroundColor3", "Accent")
			AddCorner(fill, 3)

			local dragging = false
			local obj = {}

			local function round(v)
				local mult = 10 ^ decimals
				return floor(v * mult + 0.5) / mult
			end

			local function setVal(v, noCallback)
				v = tonumber(v) or minVal
				value = round(clamp(v, minVal, maxVal))

				local pct = 0
				if maxVal ~= minVal then
					pct = (value - minVal) / (maxVal - minVal)
				end

				valueBox.Text = tostring(value)
				fill.Size = UD2(pct, 0, 1, 0)

				SetFlag(p.Flag, value)

				if not noCallback then
					FireCallback(p.Callback, value)
				end
			end

			local function dragTo(input)
				local pct = clamp((input.Position.X - track.AbsolutePosition.X) / max(track.AbsoluteSize.X, 1), 0, 1)
				setVal(minVal + (maxVal - minVal) * pct, false)
			end

			Connect(track.InputBegan, function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 then
					dragging = true
					dragTo(input)
				end
			end)

			Connect(uis.InputChanged, function(input)
				if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
					dragTo(input)
				end
			end)

			Connect(uis.InputEnded, function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 then
					dragging = false
				end
			end)

			Connect(valueBox.FocusLost, function()
				local n = tonumber(valueBox.Text)
				if n then
					setVal(n, false)
				else
					valueBox.Text = tostring(value)
				end
			end)

			function obj:Set(v)
				setVal(v, false)
			end

			function obj:Get()
				return value
			end

			function obj:SetVisible(v)
				row.Visible = v == true
				section:_UpdateSize()
			end

			if p.Flag then
				FrontierLib.Pointers[p.Flag] = obj
			end

			AddTooltip(row, p.Tip)
			setVal(value, true)
			RegisterElement(row, p.Text)
			section:_UpdateSize()

			return obj
		end

		function api:AddDropdown(p)
			p = p or {}

			local items = p.Items or {}
			local isMulti = p.Multi == true

			local state

			if isMulti then
				state = {}

				if type(p.Default) == "table" then
					for k, v in pairs(p.Default) do
						if type(k) == "number" then
							state[v] = true
						else
							state[k] = v == true
						end
					end
				end
			else
				state = p.Default or items[1] or "None"
			end

			local row = Mk("Frame", {
				Parent = section._Holder,
				Size = UD2(1, 0, 0, 48),
				BackgroundTransparency = 1,
				ZIndex = 12,
			})

			local label = Mk("TextLabel", {
				Parent = row,
				Position = UD2(0, 0, 0, 0),
				Size = UD2(1, 0, 0, 17),
				BackgroundTransparency = 1,
				Text = tostring(p.Text or "Dropdown"),
				Font = Enum.Font.SourceSans,
				TextSize = 14,
				TextColor3 = FrontierLib.Theme.Text,
				TextXAlignment = Enum.TextXAlignment.Left,
				ZIndex = 13,
			})
