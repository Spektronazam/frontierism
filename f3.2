-- Theme System
----------------------------------------------------------------------------------------------------

function FrontierLib:_RegisterTheme(inst, prop, key)
	if not inst or not prop or not key then
		return
	end

	tinsert(self._ThemeObjects, {
		Inst = inst,
		Prop = prop,
		Key = key,
	})

	pcall(function()
		inst[prop] = self.Theme[key]
	end)
end

function FrontierLib:SetThemeKey(key, value)
	if not self.Theme[key] or typeof(value) ~= "Color3" then
		return
	end

	self.Theme[key] = value

	for i = #self._ThemeObjects, 1, -1 do
		local item = self._ThemeObjects[i]
		if not item or not item.Inst or not item.Inst.Parent then
			tremove(self._ThemeObjects, i)
		elseif item.Key == key then
			pcall(function()
				item.Inst[item.Prop] = value
			end)
		end
	end
end

function FrontierLib:SetTheme(theme)
	for k, v in pairs(theme or {}) do
		if self.Theme[k] and typeof(v) == "Color3" then
			self:SetThemeKey(k, v)
		end
	end
end

