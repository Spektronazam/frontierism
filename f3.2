				BackgroundTransparency = 1,
				Text = "made w/ love by frontier",
				Font = Enum.Font.GothamBold,
				TextSize = 18,
				TextColor3 = C3(1, 1, 1),
				ZIndex = 13,
			})

			local grad = Mk("UIGradient", {
				Parent = txt,
				Color = ColorSequence.new({
					ColorSequenceKeypoint.new(0, RGB(0, 0, 0)),
					ColorSequenceKeypoint.new(0.5, FrontierLib.Theme.Accent),
					ColorSequenceKeypoint.new(1, RGB(0, 0, 0)),
				}),
				Offset = Vector2.new(-1, 0),
				Rotation = 0,
			})

			task.spawn(function()
				while txt and txt.Parent and FrontierLib._Alive do
					local tween = Tw(grad, {Offset = Vector2.new(1, 0)}, 2, Enum.EasingStyle.Linear)
					if tween then
						tween.Completed:Wait()
					end
					if grad and grad.Parent then
						grad.Offset = Vector2.new(-1, 0)
					end
					task.wait(0.08)
				end
			end)

			RegisterElement(row, "credits frontier")
			section:_UpdateSize()

			return row
		end

