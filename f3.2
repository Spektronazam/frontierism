	function WindowObj:AddTab(name)
		local tab = {
			Name = tostring(name or "Tab"),
			Sections = {},
			DefaultSection = nil,
		}

		local btn = Mk("TextButton", {
			Parent = tabList,
			Size = UD2(1, 0, 0, 31),
			BackgroundColor3 = FrontierLib.Theme.PanelDark,
			BackgroundTransparency = 1,
			BorderSizePixel = 0,
			Text = "  " .. tab.Name,
			Font = Enum.Font.SourceSans,
			TextSize = 14,
			TextColor3 = FrontierLib.Theme.SubText,
			TextXAlignment = Enum.TextXAlignment.Left,
			AutoButtonColor = false,
			ZIndex = 8,
		})
		FrontierLib:_RegisterTheme(btn, "BackgroundColor3", "PanelDark")
		FrontierLib:_RegisterTheme(btn, "TextColor3", "SubText")

		local indicator = Mk("Frame", {
			Parent = btn,
			Size = UD2(0, 3, 1, -8),
			Position = UD2(0, 0, 0, 4),
			BackgroundColor3 = FrontierLib.Theme.Accent,
			BackgroundTransparency = 1,
			BorderSizePixel = 0,
			ZIndex = 9,
		})
		FrontierLib:_RegisterTheme(indicator, "BackgroundColor3", "Accent")
		AddCorner(indicator, 2)

		local page = Mk("ScrollingFrame", {
			Parent = content,
			Size = UD2(1, 0, 1, 0),
			Position = UD2(1, 0, 0, 0),
			BackgroundTransparency = 1,
			Visible = false,
			ScrollBarThickness = 4,
			ScrollBarImageColor3 = FrontierLib.Theme.Accent,
			BorderSizePixel = 0,
			CanvasSize = UD2(0, 0, 0, 0),
			ZIndex = 7,
		})
		FrontierLib:_RegisterTheme(page, "ScrollBarImageColor3", "Accent")

		local pageLayout = AddList(page, 8)
		AddPadding(page, 10, 10, 10, 10)

		Connect(pageLayout:GetPropertyChangedSignal("AbsoluteContentSize"), function()
			page.CanvasSize = UD2(0, 0, 0, pageLayout.AbsoluteContentSize.Y + 22)
		end)

		tab.Button = btn
		tab.Indicator = indicator
		tab.Page = page
		tab.Layout = pageLayout

		local function selectTab()
			if WindowObj.ActiveTab == tab then
				return
			end

			local oldTab = WindowObj.ActiveTab
			WindowObj.ActiveTab = tab

			btn.BackgroundTransparency = 0.25
			btn.TextColor3 = FrontierLib.Theme.Text
			Tw(indicator, {BackgroundTransparency = 0}, 0.15)

			page.Visible = true

			if oldTab then
				page.Position = UD2(1, 0, 0, 0)
				Tw(page, {Position = UD2(0, 0, 0, 0)}, 0.34, Enum.EasingStyle.Quart)

				oldTab.Button.BackgroundTransparency = 1
				oldTab.Button.TextColor3 = FrontierLib.Theme.SubText
				Tw(oldTab.Indicator, {BackgroundTransparency = 1}, 0.15)

				local oldPage = oldTab.Page
				Tw(oldPage, {Position = UD2(-1, 0, 0, 0)}, 0.34, Enum.EasingStyle.Quart)

				task.delay(0.34, function()
					if WindowObj.ActiveTab ~= oldTab and oldPage then
						oldPage.Visible = false
					end
				end)
			else
				page.Position = UD2(0, 0, 0, 0)
			end
		end

		Connect(btn.MouseButton1Click, selectTab)

		Connect(btn.MouseEnter, function()
			if WindowObj.ActiveTab ~= tab then
				btn.BackgroundTransparency = 0.75
			end
		end)

		Connect(btn.MouseLeave, function()
			if WindowObj.ActiveTab ~= tab then
				btn.BackgroundTransparency = 1
			end
		end)

		function tab:AddSection(title)
			local sectionFrame = Mk("Frame", {
				Parent = page,
				Size = UD2(1, 0, 0, 40),
				BackgroundColor3 = FrontierLib.Theme.Panel,
				BackgroundTransparency = 0,
				BorderSizePixel = 0,
				ZIndex = 10,
			})
			FrontierLib:_RegisterTheme(sectionFrame, "BackgroundColor3", "Panel")
			AddCorner(sectionFrame, 3)
			AddStroke(sectionFrame, "Border", 0.15, 1)

			local header = Mk("TextLabel", {
				Parent = sectionFrame,
				Position = UD2(0, 8, 0, 0),
				Size = UD2(1, -16, 0, 24),
				BackgroundTransparency = 1,
				Text = tostring(title or "Section"),
				Font = Enum.Font.SourceSansSemibold,
				TextSize = 14,
				TextColor3 = FrontierLib.Theme.Accent,
				TextXAlignment = Enum.TextXAlignment.Left,
				ZIndex = 11,
			})
			FrontierLib:_RegisterTheme(header, "TextColor3", "Accent")

			local holder = Mk("Frame", {
				Parent = sectionFrame,
				Position = UD2(0, 8, 0, 28),
				Size = UD2(1, -16, 0, 0),
				BackgroundTransparency = 1,
				ZIndex = 11,
			})

			local holderLayout = AddList(holder, 6)

			local section = {
				_Tab = tab,
				_Frame = sectionFrame,
				_Holder = holder,
				_Header = header,
				_Layout = holderLayout,
			}

			function section:_UpdateSize()
				task.defer(function()
					if not sectionFrame or not sectionFrame.Parent then
						return
					end

					local visibleCount = 0
					for _, child in ipairs(holder:GetChildren()) do
						if child:IsA("GuiObject") and child.Visible then
							visibleCount += 1
						end
					end

					local height = holderLayout.AbsoluteContentSize.Y
					holder.Size = UD2(1, -16, 0, height)
					sectionFrame.Size = UD2(1, 0, 0, height + 38)
					sectionFrame.Visible = visibleCount > 0 or searchBox.Text == ""
				end)
			end

			Connect(holderLayout:GetPropertyChangedSignal("AbsoluteContentSize"), function()
				section:_UpdateSize()
			end)

			CreateSectionAPI(section)

			tinsert(tab.Sections, section)
			tinsert(WindowObj.Sections, section)

			section:_UpdateSize()
			return section
		end

		tab.DefaultSection = tab:AddSection(tab.Name)

		local directMethods = {
			"AddLabel",
			"AddCredits",
			"AddButton",
			"AddToggle",
			"AddSlider",
			"AddDropdown",
			"AddColorPicker",
			"AddKeybind",
			"AddTextInput",
		}

		for _, method in ipairs(directMethods) do
			tab[method] = function(_, ...)
				return tab.DefaultSection
			end
		end

		tinsert(WindowObj.Tabs, tab)

		if #WindowObj.Tabs == 1 then
			task.defer(selectTab)
		end

		return tab
	end

	------------------------------------------------------------------------------------------------
	-- Settings / Configs / Theme Editor / Required Items
	------------------------------------------------------------------------------------------------

	local function EnsureFolders()
		if not HasFileSystem then
			return false
		end

		if not isfolder("Frontierism") then
			pcall(makefolder, "Frontierism")
		end

		local hubFolder = "Frontierism/" .. FrontierLib.ConfigFolder

		if not isfolder(hubFolder) then
			pcall(makefolder, hubFolder)
		end

		return true, hubFolder
	end

	local function GetConfigs(hubFolder)
		local cfgs = {}

		if HasFileSystem and hubFolder then
			local ok, files = pcall(listfiles, hubFolder)

			if ok and files then
				for _, file in ipairs(files) do
					local name = tostring(file):match("([^/\\]+)%.json$")
					if name then
						tinsert(cfgs, name)
					end
				end
			end
		end

		if #cfgs == 0 then
			tinsert(cfgs, "Default")
		end

		table.sort(cfgs)
		return cfgs
	end

	function WindowObj:SaveConfig(name)
		local okFolder, hubFolder = EnsureFolders()

		if not okFolder then
			FrontierLib:Notify("File system unavailable.", 3, "error")
			return false
		end

		name = SanitizeFileName(name or FrontierLib.Flags.SelectedConfig or "Default")

		local data = {
			Flags = FrontierLib.Flags,
			Theme = {},
			ToggleKey = FrontierLib.ToggleKey.Name,
		}

		for k, v in pairs(FrontierLib.Theme) do
			if typeof(v) == "Color3" then
				data.Theme[k] = ColorToHex(v)
			end
		end

		local encoded = hs:JSONEncode(data)
		local ok = pcall(writefile, hubFolder .. "/" .. name .. ".json", encoded)

		if ok then
			FrontierLib:Notify("Saved Config: " .. name, 2, "success")
			return true
		else
			FrontierLib:Notify("Failed to save config.", 3, "error")
			return false
		end
	end

	function WindowObj:LoadConfig(name)
		local okFolder, hubFolder = EnsureFolders()

		if not okFolder then
			FrontierLib:Notify("File system unavailable.", 3, "error")
			return false
		end

		name = SanitizeFileName(name or FrontierLib.Flags.SelectedConfig or "Default")
		local path = hubFolder .. "/" .. name .. ".json"

		if not isfile(path) then
			FrontierLib:Notify("Config file not found.", 3, "error")
			return false
		end

		local ok, data = pcall(function()
			return hs:JSONDecode(readfile(path))
		end)

		if not ok or type(data) ~= "table" then
			FrontierLib:Notify("Invalid config JSON.", 3, "error")
			return false
		end

		local flags = data.Flags or data

		if type(flags) == "table" then
			for flag, value in pairs(flags) do
				FrontierLib.Flags[flag] = value

				if FrontierLib.Pointers[flag] and FrontierLib.Pointers[flag].Set then
					pcall(function()
						FrontierLib.Pointers[flag]:Set(value)
					end)
				end
			end
		end

		if type(data.Theme) == "table" then
			for key, hex in pairs(data.Theme) do
				local c = HexToColor(hex)
				if c then
					FrontierLib:SetThemeKey(key, c)
				end
			end
		end

		if data.ToggleKey then
			local keyItem = NameToKeyCode(data.ToggleKey)
			if keyItem then
				FrontierLib.ToggleKey = keyItem
			end
		end

		FrontierLib:Notify("Loaded Config: " .. name, 2, "info")
		return true
	end

	task.defer(function()
		local settingsTab = WindowObj:AddTab("Settings")
		WindowObj._Required.Settings = true

		settingsTab:AddCredits()

		local interface = settingsTab:AddSection("Interface")

		interface:AddKeybind({
			Text = "UI Toggle Key",
			Flag = "UIToggleKey",
			Default = FrontierLib.ToggleKey.Name,
			Tip = "Key used to hide/show the UI.",
			Callback = function(key)
				local item = NameToKeyCode(key)
				if item then
					FrontierLib.ToggleKey = item
					WindowObj._Required.UIKeybinds = true
					FrontierLib:Notify("UI key set to " .. key, 2, "success")
				end
			end,
		})

		WindowObj._Required.UIKeybinds = true

		interface:AddToggle({
			Text = "Show Keybinds Widget",
			Flag = "ShowKeybindsWidget",
			Default = false,
			Tip = "Displays currently registered keybinds.",
		})

		interface:AddButton({
			Text = "Hide UI",
			Tip = "You can reopen it with the UI toggle key.",
			Callback = function()
				HideRoot()
			end,
		})

		local themeSec = settingsTab:AddSection("Theme Editor")

		local themeKeys = {
			"Accent",
			"Bg",
			"Topbar",
			"Sidebar",
			"Panel",
			"PanelDark",
			"PanelLight",
			"Border",
			"Text",
			"SubText",
			"Hover",
			"Disabled",
			"Success",
			"Warning",
			"Error",
		}

		for _, key in ipairs(themeKeys) do
			themeSec:AddColorPicker({
				Text = key,
				Default = FrontierLib.Theme[key],
				Flag = "Theme_" .. key,
				Callback = function(c)
					FrontierLib:SetThemeKey(key, c)
				end,
			})
		end

		themeSec:AddButton({
			Text = "Reset Theme",
			Callback = function()
				local defaultTheme = {
					Accent = RGB(255, 140, 0),
					Bg = RGB(32, 32, 32),
					Topbar = RGB(26, 26, 26),
					Sidebar = RGB(28, 28, 28),
					Panel = RGB(42, 42, 42),
					PanelDark = RGB(24, 24, 24),
					PanelLight = RGB(55, 55, 55),
					Border = RGB(15, 15, 15),
					Text = RGB(245, 245, 245),
					SubText = RGB(185, 185, 185),
					Hover = RGB(64, 64, 64),
					Disabled = RGB(95, 95, 95),
					Success = RGB(90, 255, 140),
					Warning = RGB(255, 210, 90),
					Error = RGB(255, 80, 80),
				}

				FrontierLib:SetTheme(defaultTheme)

				for _, k in ipairs(themeKeys) do
					local ptr = FrontierLib.Pointers["Theme_" .. k]
					if ptr and ptr.Set then
						ptr:Set(FrontierLib.Theme[k])
					end
				end

				FrontierLib:Notify("Theme reset.", 2, "info")
			end,
		})

		local configSec = settingsTab:AddSection("Configuration")

		local okFolder, hubFolder = EnsureFolders()

		if not okFolder then
			configSec:AddLabel("File system unavailable.")
		end

		local configDropdown = configSec:AddDropdown({
			Text = "Select Config",
			Flag = "SelectedConfig",
			Items = GetConfigs(hubFolder),
			Default = "Default",
		})

		local nameInput = configSec:AddTextInput({
			Text = "Config Name",
			Placeholder = "MyConfig",
			Default = "",
		})

		configSec:AddButton({
			Text = "Save Config",
			Callback = function()
				local name = nameInput:Get()
				if name == "" then
					name = FrontierLib.Flags.SelectedConfig or "Default"
				end

				if WindowObj:SaveConfig(name) then
					local _, folder = EnsureFolders()
					configDropdown:Refresh(GetConfigs(folder), name)
				end
			end,
		})

		configSec:AddButton({
			Text = "Load Config",
			Callback = function()
				local name = FrontierLib.Flags.SelectedConfig or "Default"
				WindowObj:LoadConfig(name)
			end,
		})

		configSec:AddButton({
			Text = "Delete Config",
			Callback = function()
				local _, folder = EnsureFolders()
				local name = SanitizeFileName(FrontierLib.Flags.SelectedConfig or "Default")
				local path = folder .. "/" .. name .. ".json"

				if HasFileSystem and isfile(path) then
					pcall(delfile, path)
					FrontierLib:Notify("Deleted Config: " .. name, 2, "warning")
					configDropdown:Refresh(GetConfigs(folder), "Default")
				else
					FrontierLib:Notify("Config not found.", 2, "error")
				end
			end,
		})

		local automationSec = settingsTab:AddSection("Automation")

		local autoLoadFile = hubFolder and (hubFolder .. "/autoload.txt") or nil
		local autoLoadEnabled = HasFileSystem and autoLoadFile and isfile(autoLoadFile) and readfile(autoLoadFile) ~= ""

		automationSec:AddToggle({
			Text = "Autoload Selected Config",
			Flag = "AutoloadConfig",
			Default = autoLoadEnabled,
			Callback = function(state)
				if not HasFileSystem or not autoLoadFile then
					FrontierLib:Notify("File system unavailable.", 3, "error")
					return
				end

				if state then
					local name = FrontierLib.Flags.SelectedConfig or "Default"
					pcall(writefile, autoLoadFile, name)
					FrontierLib:Notify("Autoload set to " .. name, 2, "success")
				else
					pcall(writefile, autoLoadFile, "")
					FrontierLib:Notify("Autoload disabled.", 2, "info")
				end
			end,
		})

		automationSec:AddButton({
			Text = "Copy Autoexecute Script",
			Tip = "Copies a template loadstring.",
			Callback = function()
				pcall(setclipboard, "loadstring(game:HttpGet('YOUR_RAW_LINK_HERE'))()")
				FrontierLib:Notify("Copied to clipboard.", 2, "success")
			end,
		})

		if HasFileSystem and autoLoadFile and isfile(autoLoadFile) then
			local autoCfg = readfile(autoLoadFile)

			if autoCfg and autoCfg ~= "" then
				task.delay(0.75, function()
					WindowObj:LoadConfig(autoCfg)
				end)
			end
		end

		StartRequiredWatchdog(WindowObj)
	end)

	------------------------------------------------------------------------------------------------
	-- Keybinds Widget
	------------------------------------------------------------------------------------------------

	local kbWidget = Mk("Frame", {
		Parent = sg,
		Position = UD2(0, 20, 0, 200),
		Size = UD2(0, 190, 0, 31),
		BackgroundColor3 = self.Theme.PanelDark,
		BorderSizePixel = 0,
		Visible = false,
		ZIndex = 200,
	})
	self:_RegisterTheme(kbWidget, "BackgroundColor3", "PanelDark")
	AddCorner(kbWidget, 3)
	AddStroke(kbWidget, "Accent", 0, 1)

	local kbHeader = Mk("TextLabel", {
		Parent = kbWidget,
		Size = UD2(1, 0, 0, 30),
		BackgroundTransparency = 1,
		Text = " Keybinds",
		Font = Enum.Font.SourceSansSemibold,
		TextSize = 14,
		TextColor3 = self.Theme.Accent,
		TextXAlignment = Enum.TextXAlignment.Left,
		ZIndex = 201,
	})
	self:_RegisterTheme(kbHeader, "TextColor3", "Accent")

	local kbList = Mk("Frame", {
		Parent = kbWidget,
		Position = UD2(0, 0, 0, 30),
		Size = UD2(1, 0, 1, -30),
		BackgroundTransparency = 1,
		ZIndex = 201,
	})

	local kbLayout = AddList(kbList, 0)
	local kbLabels = {}

	local kbDrag = {
		active = false,
		start = ZV2,
		startPos = nil,
	}

	Connect(kbHeader.InputBegan, function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			kbDrag.active = true
			kbDrag.start = V2(input.Position.X, input.Position.Y)
			kbDrag.startPos = kbWidget.Position
		end
	end)

	Connect(uis.InputChanged, function(input)
		if kbDrag.active and input.UserInputType == Enum.UserInputType.MouseMovement then
			local delta = V2(input.Position.X, input.Position.Y) - kbDrag.start
			kbWidget.Position = UD2(
				0,
				kbDrag.startPos.X.Offset + delta.X,
				0,
				kbDrag.startPos.Y.Offset + delta.Y
			)
		end
	end)

	Connect(uis.InputEnded, function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			kbDrag.active = false
		end
	end)

	Connect(rs.RenderStepped, function()
		if not FrontierLib.Flags.ShowKeybindsWidget then
			kbWidget.Visible = false
			return
		end

		local count = 0
		local index = 1

		for id, bind in pairs(FrontierLib.Keybinds) do
			local name = id
			local key = bind

			if type(bind) == "table" then
				name = bind.Name or id
				key = bind.Key or "None"
			end

			if key ~= "None" then
				count += 1

				if not kbLabels[index] then
					local lbl = Mk("TextLabel", {
						Parent = kbList,
						Size = UD2(1, 0, 0, 20),
						BackgroundTransparency = 1,
						Font = Enum.Font.SourceSans,
						TextSize = 13,
						TextColor3 = FrontierLib.Theme.Text,
						TextXAlignment = Enum.TextXAlignment.Left,
						ZIndex = 202,
					})
					FrontierLib:_RegisterTheme(lbl, "TextColor3", "Text")
					kbLabels[index] = lbl
				end

				kbLabels[index].Text = string.format(" %s: [%s]", tostring(name), tostring(key))
				kbLabels[index].Visible = true
				index += 1
			end
		end

		for i = index, #kbLabels do
			kbLabels[i].Visible = false
		end

		if count == 0 then
			kbWidget.Visible = false
		else
			kbWidget.Visible = true
			kbWidget.Size = UD2(0, 190, 0, 35 + count * 20)
		end
	end)

	------------------------------------------------------------------------------------------------
	-- Global Input
	------------------------------------------------------------------------------------------------

	Connect(uis.InputBegan, function(input, gpe)
		if gpe or uis:GetFocusedTextBox() then
			return
		end

		if input.KeyCode == FrontierLib.ToggleKey then
			WindowObj:Toggle()
			return
		end

		for _, bind in pairs(FrontierLib.Keybinds) do
			if type(bind) == "table"
				and bind.OnPressed
				and InputMatches(input, bind.Key) then
				pcall(bind.OnPressed, input)
			end
		end
	end)

	return WindowObj
end

----------------------------------------------------------------------------------------------------
-- Destroy
----------------------------------------------------------------------------------------------------

function FrontierLib:Destroy()
	self._Alive = false

	DisconnectAll()

	for inst, tween in pairs(TwCache) do
		pcall(function()
			tween:Cancel()
		end)
		TwCache[inst] = nil
	end

	for _, gui in ipairs(self._Guis or {}) do
		SafeDestroy(gui)
	end

	self._Guis = {}

	pcall(function()
		local ui = GuiParent:FindFirstChild("Frontierism_UI")
		if ui then
			ui:Destroy()
		end
	end)

	pcall(function()
		local nf = GuiParent:FindFirstChild("Frontier_Notifications")
		if nf then
			nf:Destroy()
		end
	end)

	pcall(function()
		local blur = lighting:FindFirstChild("Frontier_Blur")
		if blur then
			blur:Destroy()
		end
	end)

	self.Flags = {}
	self.Pointers = {}
	self.Keybinds = {}
	self._ThemeObjects = {}
	self._Windows = {}
end

return FrontierLib
