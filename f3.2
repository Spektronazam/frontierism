local function SafeDestroy(x)
	if x then
		pcall(function()
			x:Destroy()
		end)
	end
end

local function Connect(sig, fn)
	local c = sig:Connect(fn)
	tinsert(FrontierLib._Connections, c)
	return c
end

local function DisconnectAll()
	for i = #FrontierLib._Connections, 1, -1 do
		local c = FrontierLib._Connections[i]
		if c then
			pcall(function()
				c:Disconnect()
			end)
		end
		FrontierLib._Connections[i] = nil
	end
end

local function GetGuiParent()
	local parent

	pcall(function()
		if typeof(gethui) == "function" then
			parent = gethui()
		end
	end)

	if parent then
		return parent
	end

	pcall(function()
		parent = game:GetService("CoreGui")
	end)

	if parent then
		return parent
	end

	return lp:WaitForChild("PlayerGui")
end

local GuiParent = GetGuiParent()

local function Mk(className, props)
	local ok, inst = pcall(Instance.new, className)
	if not ok or not inst then
		return nil
	end

	local parent = props and props.Parent

	if props then
		for k, v in pairs(props) do
			if k ~= "Parent" then
				pcall(function()
					inst[k] = v
				end)
			end
		end
	end

	if parent then
		pcall(function()
			inst.Parent = parent
		end)
	end

	return inst
end

local TwCache = setmetatable({}, {__mode = "k"})

local function Tw(inst, props, dur, style, dir)
	if not inst then
		return nil
	end

	dur = dur or 0.16
	style = style or Enum.EasingStyle.Quad
	dir = dir or Enum.EasingDirection.Out

	local old = TwCache[inst]
	if old then
		pcall(function()
			old:Cancel()
		end)
	end

	local ok, tween = pcall(function()
		return ts:Create(inst, TweenInfo.new(dur, style, dir), props)
	end)

	if not ok or not tween then
		return nil
	end

	TwCache[inst] = tween
	tween:Play()

	tween.Completed:Once(function()
		if TwCache[inst] == tween then
			TwCache[inst] = nil
		end
	end)

	return tween
end

local function Byte(n)
	return clamp(floor((n or 0) * 255 + 0.5), 0, 255)
end

local function ColorToHex(color)
	return string.format("#%02X%02X%02X", Byte(color.R), Byte(color.G), Byte(color.B))
end

local function HexToColor(hex)
	hex = tostring(hex or ""):gsub("#", "")

	if #hex == 3 then
		hex = hex:sub(1,1)..hex:sub(1,1)..hex:sub(2,2)..hex:sub(2,2)..hex:sub(3,3)..hex:sub(3,3)
	end

	if not hex:match("^%x%x%x%x%x%x$") then
		return nil
	end

	return RGB(
		tonumber(hex:sub(1,2), 16),
		tonumber(hex:sub(3,4), 16),
		tonumber(hex:sub(5,6), 16)
	)
end

local function TextWidth(text, font, size)
	local ok, result = pcall(function()
		return txts:GetTextSize(tostring(text), size, font, Vector2.new(10000, 10000))
	end)

	if ok and result then
		return result.X
	end

	return #tostring(text) * size * 0.5
end

local function InputToName(input)
	if input.UserInputType == Enum.UserInputType.Keyboard then
		return input.KeyCode.Name
	end

	local inputName = input.UserInputType.Name
	if inputName:find("MouseButton") then
		return inputName
	end

	return "None"
end

local function NameToKeyCode(name)
	if typeof(name) == "EnumItem" then
		return name
	end

	local ok, item = pcall(function()
		return Enum.KeyCode[tostring(name)]
	end)

	return ok and item or nil
end

local function InputMatches(input, keyName)
	return InputToName(input) == tostring(keyName)
end

local function IsMouseInside(gui, input)
	if not gui then
		return false
	end

	local p = input.Position
	local ap = gui.AbsolutePosition
	local as = gui.AbsoluteSize

	return p.X >= ap.X
		and p.X <= ap.X + as.X
		and p.Y >= ap.Y
		and p.Y <= ap.Y + as.Y
end

local function SanitizeFileName(name)
	name = tostring(name or "Default")
	name = name:gsub("[/\\:%*%?\"<>|]", "_")
	name = name:gsub("^%s+", "")
	name = name:gsub("%s+$", "")

	if name == "" then
		name = "Default"
	end

	return name
end

local function AddCorner(inst, radius)
	return Mk("UICorner", {
		Parent = inst,
		CornerRadius = UD(0, radius or 3)
	})
end

local function AddStroke(inst, colorKey, transparency, thickness)
	local stroke = Mk("UIStroke", {
		Parent = inst,
		Color = FrontierLib.Theme[colorKey or "Border"],
		Transparency = transparency or 0,
		Thickness = thickness or 1,
		ApplyStrokeMode = Enum.ApplyStrokeMode.Border,
	})

	if stroke then
		FrontierLib:_RegisterTheme(stroke, "Color", colorKey or "Border")
	end

	return stroke
end

local function AddPadding(inst, left, right, top, bottom)
	return Mk("UIPadding", {
		Parent = inst,
		PaddingLeft = UD(0, left or 0),
		PaddingRight = UD(0, right or left or 0),
		PaddingTop = UD(0, top or 0),
		PaddingBottom = UD(0, bottom or top or 0),
	})
end

local function AddList(inst, padding)
	return Mk("UIListLayout", {
		Parent = inst,
		SortOrder = Enum.SortOrder.LayoutOrder,
		Padding = UD(0, padding or 6)
	})
end

local function AddHover(btn, normalKey, hoverKey)
	if not btn then
		return
	end

	Connect(btn.MouseEnter, function()
		Tw(btn, {BackgroundColor3 = FrontierLib.Theme[hoverKey or "Hover"]}, 0.14)
	end)

	Connect(btn.MouseLeave, function()
		Tw(btn, {BackgroundColor3 = FrontierLib.Theme[normalKey or "PanelDark"]}, 0.14)
	end)
end

