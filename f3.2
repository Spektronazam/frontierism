		function api:AddCredits()
			WindowObj._Required.Credits = true

			local row = Mk("Frame", {
				Parent = section._Holder,
				Size = UD2(1, 0, 0, 44),
				BackgroundColor3 = FrontierLib.Theme.PanelDark,
				BorderSizePixel = 0,
				ZIndex = 12,
			})
			FrontierLib:_RegisterTheme(row, "BackgroundColor3", "PanelDark")
