				Size=UDim2.new(wide or 0.6, 0, 0, 16),
				BackgroundTransparency=1, Text=text, Font=Enum.Font.Gotham,
				TextSize=13, TextColor3=FrontierLib.Theme.Text,
				TextXAlignment=Enum.TextXAlignment.Left, ZIndex=6
			})
		end

