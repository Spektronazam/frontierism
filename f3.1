local notifCount = 0

function FrontierLib:Notify(msg, dur, nt)
	dur = dur or 3
	local style = NfStyle[nt] or NfStyle.info
	notifCount += 1

	local frame = Mk("Frame", {
		Parent              = notifStack,
		Size                = UDim2.new(1, 0, 0, 44),
		BackgroundColor3    = FrontierLib.Theme.PanelDark,
		BorderSizePixel     = 0,
		ClipsDescendants    = true,
		ZIndex              = 11000,
		LayoutOrder         = notifCount,
	})
	RoundFrame(frame, 5)

	-- Left accent bar
	local bar = Mk("Frame", {
		Parent              = frame,
		Size                = UDim2.new(0, 3, 1, 0),
		BackgroundColor3    = style.color,
		BorderSizePixel     = 0,
		ZIndex              = 11001,
	})

	local icon = Mk("TextLabel", {
		Parent              = frame,
		Position            = UDim2.new(0, 12, 0, 0),
		Size                = UDim2.new(0, 22, 1, 0),
		BackgroundTransparency = 1,
		Text                = style.icon,
		Font                = Enum.Font.GothamBold,
		TextSize            = 14,
		TextColor3          = style.color,
		ZIndex              = 11001,
	})

	local text = Mk("TextLabel", {
		Parent              = frame,
		Position            = UDim2.new(0, 38, 0, 0),
		Size                = UDim2.new(1, -46, 1, 0),
		BackgroundTransparency = 1,
		Text                = msg,
		Font                = Enum.Font.Gotham,
		TextSize            = 13,
		TextColor3          = FrontierLib.Theme.Text,
		TextXAlignment      = Enum.TextXAlignment.Left,
		TextWrapped         = true,
		ZIndex              = 11001,
	})

	-- Progress bar
	local progBg = Mk("Frame", {
		Parent              = frame,
		Size                = UDim2.new(1, 0, 0, 2),
		Position            = UDim2.new(0, 0, 1, -2),
		BackgroundColor3    = FrontierLib.Theme.Border,
		BorderSizePixel     = 0,
		ZIndex              = 11002,
	})
	local prog = Mk("Frame", {
		Parent              = progBg,
		Size                = UDim2.new(1, 0, 1, 0),
		BackgroundColor3    = style.color,
		BorderSizePixel     = 0,
		ZIndex              = 11003,
	})

	-- Slide in
	frame.Size = UDim2.new(1, 0, 0, 0)
	Tw(frame, {Size = UDim2.new(1, 0, 0, 44)}, 0.25, Enum.EasingStyle.Quart)

	-- Timer loop
	task.spawn(function()
		local born = tk()
		while frame.Parent do
			local age = tk() - born
			local pct = clamp(1 - (age / dur), 0, 1)
			prog.Size = UDim2.new(pct, 0, 1, 0)
			if age >= dur then break end
			task.wait(0.02)
		end
		-- Slide out
		Tw(frame, {Size = UDim2.new(1, 0, 0, 0)}, 0.25, Enum.EasingStyle.Quart)
		task.wait(0.25)
		pcall(frame.Destroy, frame)
	end)
end

-- ─────────────────────────────────────────────────────────────────────────────
--  MAIN WINDOW
-- ─────────────────────────────────────────────────────────────────────────────
function FrontierLib:CreateWindow(cfg)
	cfg = cfg or {}
	local titleText = cfg.Title or "frontierism"
	local winW      = cfg.Width  or 680
	local winH      = cfg.Height or 480

	if cfg.Accent       then FrontierLib.Theme.Accent       = cfg.Accent end
	if cfg.ConfigFolder then FrontierLib.ConfigFolder        = cfg.ConfigFolder end

	-- Destroy any previous window (safe re-execution)
	local prev = cg:FindFirstChild("Frontierism_UI")
	if prev then prev:Destroy() end

	local sg = Mk("ScreenGui", {
		Parent          = cg,
		Name            = "Frontierism_UI",
		ResetOnSpawn    = false,
		IgnoreGuiInset  = true,
		ZIndexBehavior  = Enum.ZIndexBehavior.Sibling,
		DisplayOrder    = 100,
	})

	-- ── Tooltip ──────────────────────────────────────────────────────────────
	local ttFrame = Mk("Frame", {
		Parent              = sg,
		Size                = UDim2.new(0, 10, 0, 22),
		BackgroundColor3    = FrontierLib.Theme.PanelDark,
		BorderColor3        = FrontierLib.Theme.Border,
		BorderSizePixel     = 1,
		Visible             = false,
		ZIndex              = 200000,
	})
	RoundFrame(ttFrame, 3)
	local ttText = Mk("TextLabel", {
		Parent              = ttFrame,
		Size                = UDim2.new(1, 0, 1, 0),
		BackgroundTransparency = 1,
		Font                = Enum.Font.Gotham,
		TextSize            = 13,
		TextColor3          = FrontierLib.Theme.SubText,
		ZIndex              = 200001,
	})
	-- Update position in a tight loop rather than RenderStepped
	task.spawn(function()
		while sg.Parent do
			if ttFrame.Visible then
				local mp = uis:GetMouseLocation()
				ttFrame.Position = UDim2.new(0, mp.X + 14, 0, mp.Y + 14)
			end
			task.wait(0.02)
		end
	end)

	local function addTooltip(inst, tip)
		if not tip or tip == "" then return end
		inst.MouseEnter:Connect(function()
			ttText.Text = "  " .. tip .. "  "
			ttFrame.Size = UDim2.new(0, ttText.TextBounds.X + 14, 0, 22)
			ttFrame.Visible = true
		end)
		inst.MouseLeave:Connect(function() ttFrame.Visible = false end)
	end

	-- ── Blur (guarded: remove existing first) ────────────────────────────────
	local lg = game:GetService("Lighting")
	do
		local ex = lg:FindFirstChild("Frontier_Blur")
		if ex then ex:Destroy() end
	end
	local blur = Mk("BlurEffect", {Parent = lg, Size = 0, Name = "Frontier_Blur"})
	if blur then Tw(blur, {Size = 16}, 0.5, Enum.EasingStyle.Sine) end

	local function removeBlur()
		if blur and blur.Parent then
			Tw(blur, {Size = 0}, 0.5, Enum.EasingStyle.Sine)
			task.delay(0.5, function() pcall(blur.Destroy, blur) end)
		end
	end

	-- ── Root window frame ─────────────────────────────────────────────────────
	local root = Mk("Frame", {
		Parent              = sg,
		Size                = UDim2.new(0, winW, 0, winH),
		Position            = UDim2.new(0.5, -winW/2, 0.5, -winH/2),
		BackgroundColor3    = FrontierLib.Theme.Bg,
		BorderColor3        = FrontierLib.Theme.Border,
		BorderSizePixel     = 1,
		ClipsDescendants    = true,
		Visible             = false,
		ZIndex              = 5,
	})
	RoundFrame(root, 6)

	-- ── Background image (optional) ───────────────────────────────────────────
	local bgImage = Mk("ImageLabel", {
		Parent              = root,
		Size                = UDim2.new(1, 0, 1, 0),
		BackgroundTransparency = 1,
		ImageTransparency   = 1,
		ScaleType           = Enum.ScaleType.Crop,
		ZIndex              = 5,
	})

	-- ── Intro sequence ────────────────────────────────────────────────────────
	task.spawn(function()
		if cfg.SkipIntro then
			root.Visible = true
			removeBlur()
			return
		end

		local iW, iH = 300, 90
		local introF = Mk("Frame", {
			Parent              = sg,
			Size                = UDim2.new(0, iW, 0, 0),
			Position            = UDim2.new(0.5, -iW/2, 0.5, 0),
			BackgroundColor3    = FrontierLib.Theme.Bg,
			BorderColor3        = FrontierLib.Theme.Border,
			BorderSizePixel     = 1,
			ClipsDescendants    = true,
			ZIndex              = 9999,
		})
		RoundFrame(introF, 6)

		-- Top accent line
		Mk("Frame", {Parent=introF, Size=UDim2.new(1,0,0,2), BackgroundColor3=FrontierLib.Theme.Accent, BorderSizePixel=0, ZIndex=10000})

		Mk("TextLabel", {
			Parent=introF, Position=UDim2.new(0,14,0,14), Size=UDim2.new(1,-28,0,18),
			BackgroundTransparency=1, Text=titleText, Font=Enum.Font.GothamBold,
			TextSize=16, TextColor3=FrontierLib.Theme.Text, TextXAlignment=Enum.TextXAlignment.Left, ZIndex=10000
		})
		local statusLbl = Mk("TextLabel", {
			Parent=introF, Position=UDim2.new(0,14,0,38), Size=UDim2.new(1,-28,0,14),
			BackgroundTransparency=1, Text="Initializing...", Font=Enum.Font.Gotham,
			TextSize=12, TextColor3=FrontierLib.Theme.SubText, TextXAlignment=Enum.TextXAlignment.Left, ZIndex=10000
		})
		local barBg = Mk("Frame", {
			Parent=introF, Position=UDim2.new(0,14,0,62), Size=UDim2.new(1,-28,0,3),
			BackgroundColor3=FrontierLib.Theme.Panel, BorderSizePixel=0, ZIndex=10000
		})
		RoundFrame(barBg, 2)
		local barFill = Mk("Frame", {Parent=barBg, Size=UDim2.new(0,0,1,0), BackgroundColor3=FrontierLib.Theme.Accent, BorderSizePixel=0, ZIndex=10001})
		RoundFrame(barFill, 2)

		Tw(introF, {Size=UDim2.new(0,iW,0,iH), Position=UDim2.new(0.5,-iW/2,0.5,-iH/2)}, 0.4, Enum.EasingStyle.Quart)
		task.wait(0.5)

		local steps = {
			{txt = "Fetching dependencies...", pct = 0.3,  wait = 0.3},
			{txt = "Building interface...",    pct = 0.65, wait = 0.35},
			{txt = "Mounting elements...",     pct = 1.0,  wait = 0.25},
		}
		for _, step in ipairs(steps) do
			if not introF.Parent then return end
			statusLbl.Text = step.txt
			Tw(barFill, {Size=UDim2.new(step.pct,0,1,0)}, step.wait - 0.05, Enum.EasingStyle.Sine)
			task.wait(step.wait)
		end

		Tw(introF, {Size=UDim2.new(0,iW,0,0), Position=UDim2.new(0.5,-iW/2,0.5,0)}, 0.4, Enum.EasingStyle.Quart)
		task.wait(0.4)
		pcall(introF.Destroy, introF)

		-- Animate window open
		root.Size     = UDim2.new(0, winW, 0, 0)
		root.Position = UDim2.new(0.5, -winW/2, 0.5, 0)
		root.Visible  = true
		Tw(root, {Size=UDim2.new(0,winW,0,winH), Position=UDim2.new(0.5,-winW/2,0.5,-winH/2)}, 0.5, Enum.EasingStyle.Quart)
		task.wait(0.35)
		removeBlur()
	end)

	-- ── Topbar ────────────────────────────────────────────────────────────────
	local topbar = Mk("Frame", {
		Parent              = root,
		Size                = UDim2.new(1, 0, 0, 32),
		BackgroundColor3    = FrontierLib.Theme.Topbar,
		BorderSizePixel     = 0,
		ZIndex              = 6,
	})
	-- Topbar bottom border
	Mk("Frame", {
		Parent              = topbar,
		Size                = UDim2.new(1, 0, 0, 1),
		Position            = UDim2.new(0, 0, 1, -1),
		BackgroundColor3    = FrontierLib.Theme.Border,
		BorderSizePixel     = 0,
		ZIndex              = 6,
	})
	-- Accent top line
	Mk("Frame", {
		Parent              = topbar,
		Size                = UDim2.new(0, 60, 0, 2),
		BackgroundColor3    = FrontierLib.Theme.Accent,
		BorderSizePixel     = 0,
		ZIndex              = 7,
	})

	Mk("TextLabel", {
		Parent              = topbar,
		Position            = UDim2.new(0, 12, 0, 0),
		Size                = UDim2.new(1, -80, 1, 0),
		BackgroundTransparency = 1,
		Text                = titleText,
		Font                = Enum.Font.GothamBold,
		TextSize            = 14,
		TextColor3          = FrontierLib.Theme.Text,
		TextXAlignment      = Enum.TextXAlignment.Left,
		ZIndex              = 7,
	})

	-- Window control buttons
	local function mkCtrlBtn(xOff, label, labelCol)
		local b = Mk("TextButton", {
			Parent              = topbar,
			Position            = UDim2.new(1, xOff, 0, 0),
			Size                = UDim2.new(0, 32, 1, 0),
			BackgroundTransparency = 1,
			Text                = label,
			Font                = Enum.Font.GothamBold,
			TextSize            = 14,
			TextColor3          = labelCol or FrontierLib.Theme.SubText,
			AutoButtonColor     = false,
			ZIndex              = 8,
		})
		b.MouseEnter:Connect(function() Tw(b, {TextColor3 = FrontierLib.Theme.Text}) end)
		b.MouseLeave:Connect(function() Tw(b, {TextColor3 = labelCol or FrontierLib.Theme.SubText}) end)
		return b
	end

	local closeBtn = mkCtrlBtn(-32,  "✕", FrontierLib.Theme.Error)
	local minBtn   = mkCtrlBtn(-64,  "─")

	local minimized = false
	minBtn.MouseButton1Click:Connect(function()
		minimized = not minimized
		local targetH = minimized and 32 or winH
		Tw(root, {Size = UDim2.new(0, winW, 0, targetH)}, 0.35, Enum.EasingStyle.Quart)
	end)

	closeBtn.MouseButton1Click:Connect(function()
		Tw(root, {Size = UDim2.new(0, winW, 0, 0), Position = UDim2.new(0.5, -winW/2, 0.5, 0)}, 0.35, Enum.EasingStyle.Quart)
		task.delay(0.35, function()
			root.Visible = false
			root.Size     = UDim2.new(0, winW, 0, winH)
			root.Position = UDim2.new(0.5, -winW/2, 0.5, -winH/2)
		end)
		FrontierLib:Notify("UI hidden  —  press " .. FrontierLib.ToggleKey.Name .. " to reopen", 3, "info")
	end)

	-- Drag handle (everything except buttons)
	local dragHandle = Mk("TextButton", {
		Parent              = topbar,
		Size                = UDim2.new(1, -96, 1, 0),
		BackgroundTransparency = 1,
		Text                = "",
		ZIndex              = 7,
	})
	MakeDraggable(dragHandle, root)

	-- ── Sidebar ───────────────────────────────────────────────────────────────
	local SB_W = 145
	local sidebar = Mk("Frame", {
		Parent              = root,
		Position            = UDim2.new(0, 0, 0, 32),
		Size                = UDim2.new(0, SB_W, 1, -32),
		BackgroundColor3    = FrontierLib.Theme.Sidebar,
		BorderSizePixel     = 0,
		ZIndex              = 6,
	})
	-- Right divider
	Mk("Frame", {
		Parent              = sidebar,
		Position            = UDim2.new(1, -1, 0, 0),
		Size                = UDim2.new(0, 1, 1, 0),
		BackgroundColor3    = FrontierLib.Theme.Border,
		BorderSizePixel     = 0,
		ZIndex              = 6,
	})

	-- Search box
	local searchBox = Mk("TextBox", {
		Parent              = sidebar,
		Position            = UDim2.new(0, 8, 0, 8),
		Size                = UDim2.new(1, -16, 0, 26),
		BackgroundColor3    = FrontierLib.Theme.PanelDark,
		BorderColor3        = FrontierLib.Theme.Border,
