	-- ── Window object ─────────────────────────────────────────────────────────
	local WindowObj = {Tabs = {}, ActiveTab = nil, Elements = {}}

	function WindowObj:SetBackground(imgId, transparency, color)
		if imgId then
			bgImage.Image = imgId:find("rbxassetid") and imgId or ("rbxassetid://" .. imgId)
			Tw(bgImage, {ImageTransparency = transparency or 0.55}, 0.5)
			bgImage.ImageColor3 = color or Color3.new(1, 1, 1)
		else
			Tw(bgImage, {ImageTransparency = 1}, 0.5)
		end
	end

	function WindowObj:SetTheme(newTheme)
		for k, v in pairs(newTheme) do FrontierLib.Theme[k] = v end
	end

	function WindowObj:SetToggleKey(key)
		FrontierLib.ToggleKey = typeof(key) == "EnumItem" and key or Enum.KeyCode[key]
	end

	-- Search filter
	searchBox:GetPropertyChangedSignal("Text"):Connect(function()
		local q = searchBox.Text:lower()
		for _, el in ipairs(WindowObj.Elements) do
			el.i.Visible = (q == "") or (el.name:lower():find(q, 1, true) ~= nil)
		end
	end)

	-- ── AddTab ────────────────────────────────────────────────────────────────
	function WindowObj:AddTab(name)
		local tab = {Name = name}

		local btn = Mk("TextButton", {
			Parent              = tabList,
			Size                = UDim2.new(1, 0, 0, 34),
			BackgroundTransparency = 1,
			BorderSizePixel     = 0,
			Text                = "",
			AutoButtonColor     = false,
			ZIndex              = 6,
		})

		local indicator = Mk("Frame", {
			Parent              = btn,
			Size                = UDim2.new(0, 3, 0.6, 0),
			Position            = UDim2.new(0, 0, 0.2, 0),
			BackgroundColor3    = FrontierLib.Theme.Accent,
			BorderSizePixel     = 0,
			Visible             = false,
			ZIndex              = 7,
		})
		RoundFrame(indicator, 2)

		local btnLabel = Mk("TextLabel", {
			Parent              = btn,
			Position            = UDim2.new(0, 14, 0, 0),
			Size                = UDim2.new(1, -14, 1, 0),
			BackgroundTransparency = 1,
			Text                = name,
			Font                = Enum.Font.Gotham,
			TextSize            = 13,
			TextColor3          = FrontierLib.Theme.SubText,
			TextXAlignment      = Enum.TextXAlignment.Left,
			ZIndex              = 7,
		})

		-- Content page
		local page = Mk("ScrollingFrame", {
			Parent              = content,
			Size                = UDim2.new(1, 0, 1, 0),
			Position            = UDim2.new(1, 0, 0, 0),
			BackgroundTransparency = 1,
			Visible             = false,
			ScrollBarThickness  = 3,
			ScrollBarImageColor3 = FrontierLib.Theme.Accent,
			BorderSizePixel     = 0,
			ZIndex              = 6,
		})
		Mk("UIPadding", {
			Parent          = page,
			PaddingTop      = UDim.new(0, 12),
			PaddingLeft     = UDim.new(0, 14),
			PaddingRight    = UDim.new(0, 14),
			PaddingBottom   = UDim.new(0, 12),
		})
		local layout = Mk("UIListLayout", {
			Parent      = page,
			SortOrder   = Enum.SortOrder.LayoutOrder,
			Padding     = UDim.new(0, 7),
		})
		layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
			page.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + 24)
		end)
		tab.page   = page
		tab.layout = layout

		local function selectTab()
			if WindowObj.ActiveTab == tab then return end
			local old = WindowObj.ActiveTab
			WindowObj.ActiveTab = tab

			-- Style active button
			Tw(btn, {BackgroundColor3 = FrontierLib.Theme.Hover, BackgroundTransparency = 0})
			Tw(btnLabel, {TextColor3 = FrontierLib.Theme.Text})
			indicator.Visible = true

			-- Slide page in from right
			page.Visible  = true
			page.Position = UDim2.new(1, 0, 0, 0)
			Tw(page, {Position = UDim2.new(0, 0, 0, 0)}, 0.35, Enum.EasingStyle.Quart)

			if old then
				Tw(old.btn, {BackgroundTransparency = 1})
				Tw(old.btnLabel, {TextColor3 = FrontierLib.Theme.SubText})
				old.indicator.Visible = false
				local op = old.page
				Tw(op, {Position = UDim2.new(-1, 0, 0, 0)}, 0.35, Enum.EasingStyle.Quart)
				task.delay(0.35, function()
					if WindowObj.ActiveTab ~= old then op.Visible = false end
				end)
			else
				page.Position = UDim2.new(0, 0, 0, 0)
			end
		end

		btn.MouseButton1Click:Connect(selectTab)
		btn.MouseEnter:Connect(function()
			if WindowObj.ActiveTab ~= tab then Tw(btn, {BackgroundColor3 = FrontierLib.Theme.Hover, BackgroundTransparency = 0.5}) end
		end)
		btn.MouseLeave:Connect(function()
			if WindowObj.ActiveTab ~= tab then Tw(btn, {BackgroundTransparency = 1}) end
		end)

		tab.btn       = btn
		tab.btnLabel  = btnLabel
		tab.indicator = indicator
		tinsert(self.Tabs, tab)
		if #self.Tabs == 1 then task.defer(selectTab) end

		-- ── Element helpers ──────────────────────────────────────────────────

		-- Common row wrapper
		local function mkRow(h)
			return Mk("Frame", {Parent=page, Size=UDim2.new(1,0,0,h), BackgroundTransparency=1, ZIndex=6})
		end

		-- Shared label on left
		local function mkLabel(parent, text, yOff, wide)
			return Mk("TextLabel", {
