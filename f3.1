-- ─── Instance factory ────────────────────────────────────────────────────────
local function Mk(cn, pr)
	local ok, i = pcall(Instance.new, cn)
	if not ok then return nil end
	if pr then for k, v in pairs(pr) do pcall(function() i[k] = v end) end end
	return i
end

-- ─── Tween helper (weak cache so GC can clean up) ────────────────────────────
local TwCache = setmetatable({}, {__mode = "k"})
local function Tw(inst, pr, dur, sty, dir)
	if not inst or not inst.Parent then return nil end
	dur = dur or 0.18
	sty = sty or Enum.EasingStyle.Quart
	dir = dir or Enum.EasingDirection.Out
	local old = TwCache[inst]
	if old then pcall(old.Cancel, old) end
	local ok, t = pcall(ts.Create, ts, inst, TweenInfo.new(dur, sty, dir), pr)
	if not ok or not t then return nil end
	TwCache[inst] = t; t:Play()
	return t
end

-- ─── Hover helper ────────────────────────────────────────────────────────────
local function AddHover(btn, normal, hover)
	btn.MouseEnter:Connect(function() Tw(btn, {BackgroundColor3 = hover}) end)
	btn.MouseLeave:Connect(function() Tw(btn, {BackgroundColor3 = normal}) end)
end

-- ─── UICorner/UIStroke shortcuts ─────────────────────────────────────────────
local function RoundFrame(inst, radius)
	return Mk("UICorner", {Parent = inst, CornerRadius = UDim.new(0, radius or 4)})
end

-- ─── Color utilities ─────────────────────────────────────────────────────────
local function ColorToHex(c)
	return string.format("#%02X%02X%02X", c.R*255, c.G*255, c.B*255)
end
local function HexToColor(hex)
	hex = hex:gsub("#","")
	local r = tonumber("0x"..hex:sub(1,2)) or 0
	local g = tonumber("0x"..hex:sub(3,4)) or 0
	local b = tonumber("0x"..hex:sub(5,6)) or 0
	return Color3.fromRGB(r, g, b)
end

-- ─── Drag utility (reusable, no global leak) ─────────────────────────────────
local function MakeDraggable(handle, target)
	local drag = {active=false, start=ZV2, startPos=nil}
	handle.InputBegan:Connect(function(i)
		if i.UserInputType == Enum.UserInputType.MouseButton1 then
			drag.active   = true
			drag.start    = V2(i.Position.X, i.Position.Y)
			drag.startPos = target.Position
		end
	end)
	handle.InputEnded:Connect(function(i)
		if i.UserInputType == Enum.UserInputType.MouseButton1 then drag.active = false end
	end)
	uis.InputChanged:Connect(function(i)
		if drag.active and i.UserInputType == Enum.UserInputType.MouseMovement and drag.startPos then
			local d = V2(i.Position.X, i.Position.Y) - drag.start
			target.Position = UDim2.new(
				0, drag.startPos.X.Offset + d.X,
				0, drag.startPos.Y.Offset + d.Y
			)
		end
	end)
end

-- ─── Slider drag (scoped, no global uis leak) ────────────────────────────────
local function MakeSliderDrag(track, onValue)
	local dragging = false
	local function calc(i)
		local pct = clamp((i.Position.X - track.AbsolutePosition.X) / max(track.AbsoluteSize.X, 1), 0, 1)
		onValue(pct)
	end
	track.InputBegan:Connect(function(i)
		if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true; calc(i) end
	end)
	local ucn = uis.InputChanged:Connect(function(i)
		if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then calc(i) end
	end)
	local uec = uis.InputEnded:Connect(function(i)
		if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
	end)
	-- Return disconnect so ColorPicker can clean up
	return function() pcall(ucn.Disconnect, ucn); pcall(uec.Disconnect, uec) end
end

