local function Ripple(btn, clickPos)
	if not btn then return end
	local abs_pos = btn.AbsolutePosition
	local abs_size = btn.AbsoluteSize
	local rx = (clickPos and (clickPos.X - abs_pos.X)) or (abs_size.X / 2)
	local ry = (clickPos and (clickPos.Y - abs_pos.Y)) or (abs_size.Y / 2)
	local diameter = max(abs_size.X, abs_size.Y) * 2.2

	local circle = Mk("Frame", {
		Parent = btn,
		Position = UD2(0, rx - 2, 0, ry - 2),
		Size = UD2(0, 4, 0, 4),
		BackgroundColor3 = C3(1, 1, 1),
		BackgroundTransparency = 0.7,
		BorderSizePixel = 0,
		ZIndex = btn.ZIndex + 1,
	})
	AddCorner(circle, 9999)

	Tw(circle, {
		Position = UD2(0, rx - diameter / 2, 0, ry - diameter / 2),
		Size = UD2(0, diameter, 0, diameter),
		BackgroundTransparency = 1,
	}, 0.42, Enum.EasingStyle.Quad)

	task.delay(0.44, function() SafeDestroy(circle) end)
end

----------------------------------------------------------------------------------------------------
-- Signal System (lightweight pub/sub)
----------------------------------------------------------------------------------------------------

local Signal = {}
Signal.__index = Signal

function Signal.new()
	return setmetatable({ _listeners = {} }, Signal)
end

function Signal:Connect(fn)
	local id = #self._listeners + 1
	self._listeners[id] = fn
	return {
		Disconnect = function()
			self._listeners[id] = nil
		end,
	}
end

function Signal:Fire(...)
	for _, fn in pairs(self._listeners) do
		task.spawn(fn, ...)
	end
end

FrontierLib._Signals = {
	OnThemeChanged = Signal.new(),
	OnFlagChanged = Signal.new(),
	OnTabChanged = Signal.new(),
	OnConfigLoaded = Signal.new(),
	OnConfigSaved = Signal.new(),
	OnNotify = Signal.new(),
	OnLog = Signal.new(),
}

----------------------------------------------------------------------------------------------------
-- Spring Animation System
----------------------------------------------------------------------------------------------------

local Spring = {}
Spring.__index = Spring

function Spring.new(initial, stiffness, damping, mass)
	return setmetatable({
		Position = initial or 0,
		Velocity = 0,
		Target = initial or 0,
		Stiffness = stiffness or 180,
		Damping = damping or 16,
		Mass = mass or 1,
	}, Spring)
end

function Spring:Update(dt)
	local displacement = self.Position - self.Target
	local springForce = -self.Stiffness * displacement
	local dampForce = -self.Damping * self.Velocity
	local accel = (springForce + dampForce) / self.Mass
	self.Velocity = self.Velocity + accel * dt
	self.Position = self.Position + self.Velocity * dt
	return self.Position
end

function Spring:SetTarget(t)
	self.Target = t
end

function Spring:SetPosition(p)
	self.Position = p
	self.Velocity = 0
end

function Spring:IsSettled(threshold)
	threshold = threshold or 0.01
	return abs(self.Position - self.Target) < threshold and abs(self.Velocity) < threshold
end

local Spring2D = {}
Spring2D.__index = Spring2D

function Spring2D.new(x, y, stiffness, damping, mass)
	return setmetatable({
		X = Spring.new(x or 0, stiffness, damping, mass),
		Y = Spring.new(y or 0, stiffness, damping, mass),
	}, Spring2D)
end

function Spring2D:Update(dt)
	return self.X:Update(dt), self.Y:Update(dt)
end

function Spring2D:SetTarget(x, y)
	self.X:SetTarget(x)
	self.Y:SetTarget(y)
end

function Spring2D:SetPosition(x, y)
	self.X:SetPosition(x)
	self.Y:SetPosition(y)
end

function Spring2D:IsSettled(threshold)
	return self.X:IsSettled(threshold) and self.Y:IsSettled(threshold)
end

----------------------------------------------------------------------------------------------------
-- Theme Engine (Indexed Registry)
----------------------------------------------------------------------------------------------------

function FrontierLib:_RegisterTheme(inst, prop, key)
	if not inst or not prop or not key then return end
	if not self._ThemeIndex[key] then
		self._ThemeIndex[key] = {}
	end
	tinsert(self._ThemeIndex[key], { Inst = inst, Prop = prop })
	pcall(function() inst[prop] = self.Theme[key] end)
end

function FrontierLib:SetThemeKey(key, value)
	if not self.Theme[key] or typeof(value) ~= "Color3" then return end
	self.Theme[key] = value

	local bucket = self._ThemeIndex[key]
	if not bucket then return end

	for i = #bucket, 1, -1 do
		local item = bucket[i]
		if not item or not item.Inst or not item.Inst.Parent then
			tremove(bucket, i)
		else
			pcall(function() item.Inst[item.Prop] = value end)
		end
	end

	self._Signals.OnThemeChanged:Fire(key, value)
end

function FrontierLib:SetTheme(theme)
	for k, v in pairs(theme or {}) do
		if self.Theme[k] and typeof(v) == "Color3" then
			self:SetThemeKey(k, v)
		end
	end
end

function FrontierLib:ApplyPreset(presetName)
	local preset = self.ThemePresets[presetName]
	if preset then
		self:SetTheme(preset)
	end
end

function FrontierLib:ExportTheme()
	local data = {}
	for k, v in pairs(self.Theme) do
		if typeof(v) == "Color3" then data[k] = ColorToHex(v) end
	end
	return hs:JSONEncode(data)
end

function FrontierLib:ImportTheme(jsonStr)
	local ok, data = pcall(function() return hs:JSONDecode(jsonStr) end)
	if not ok or type(data) ~= "table" then return false end
	for k, hex in pairs(data) do
		local c = HexToColor(hex)
		if c and self.Theme[k] then self:SetThemeKey(k, c) end
	end
	return true
end

----------------------------------------------------------------------------------------------------
-- Frame Dispatcher (batched RenderStepped)
----------------------------------------------------------------------------------------------------

local _dispatcherConnected = false
local _dispatcherConnection = nil

local function RegisterFrameCallback(id, fn)
	FrontierLib._FrameCallbacks[id] = fn
	if not _dispatcherConnected then
		_dispatcherConnected = true
		_dispatcherConnection = rs.RenderStepped:Connect(function(dt)
			if not FrontierLib._Alive then return end
			for _, callback in pairs(FrontierLib._FrameCallbacks) do
				task.spawn(callback, dt)
			end
		end)
		tinsert(FrontierLib._Connections, _dispatcherConnection)
	end
end

local function UnregisterFrameCallback(id)
	FrontierLib._FrameCallbacks[id] = nil
end

