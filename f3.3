		function api:AddParagraph(p)
			p = p or {}
			local title = p.Title or ""
			local body = p.Content or ""

			local bodyH = TextHeight(body, Enum.Font.SourceSans, 13, 280) + 4
			local totalH = (title ~= "" and 22 or 0) + bodyH + 14

			local row = Mk("Frame", {
