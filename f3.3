function FrontierLib:CreateWindow(cfg)
	cfg = cfg or {}

	local titleText = cfg.Title or "frontierism UI"
	local winW = cfg.Width or 700
	local winH = cfg.Height or 500
	local minW = cfg.MinWidth or 560
	local minH = cfg.MinHeight or 360

	if cfg.Accent then self.Theme.Accent = cfg.Accent end
	if cfg.ConfigFolder then self.ConfigFolder = cfg.ConfigFolder end
	if cfg.Theme and self.ThemePresets[cfg.Theme] then self:ApplyPreset(cfg.Theme) end
	if cfg.SecureMode then self.SecureMode = true end

	local old = GuiParent:FindFirstChild("Frontierism_UI")
	if old then old:Destroy() end

	local sg = Mk("ScreenGui", {
		Parent = GuiParent,
		Name = self.SecureMode and RandomName() or "Frontierism_UI",
		ResetOnSpawn = false,
		IgnoreGuiInset = true,
		ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
	})
	tinsert(self._Guis, sg)

	local WindowObj = {
		Tabs = {},
		ActiveTab = nil,
		Elements = {},
		Sections = {},
		Open = true,
		Minimized = false,
		_Root = nil,
		_Gui = sg,
		_AutoSave = cfg.AutoSave == true,
		_AutoSaveInterval = cfg.AutoSaveInterval or 30,
		_LastAutoSave = tk(),
		_Required = {
			Credits = false,
			Settings = false,
			UIKeybinds = false,
		},
	}

	tinsert(self._Windows, WindowObj)

	------------------------------------------------------------------------------------------------
	-- Tooltip
	------------------------------------------------------------------------------------------------

	local ttFrame = Mk("Frame", {
		Parent = sg,
		Size = UD2(0, 0, 0, 22),
		BackgroundColor3 = RGB(20, 20, 22),
		BackgroundTransparency = 0.06,
		BorderSizePixel = 0,
		Visible = false,
		ZIndex = Z.Tooltip,
	})
	AddCorner(ttFrame, 4)
	AddStroke(ttFrame, "Border", 0.1, 1)

	local ttTitle = Mk("TextLabel", {
		Parent = ttFrame,
		Position = UD2(0, 8, 0, 3),
		Size = UD2(1, -16, 0, 16),
		BackgroundTransparency = 1,
		Font = Enum.Font.SourceSansSemibold,
		TextSize = 13,
		TextColor3 = self.Theme.Text,
		Text = "",
		TextXAlignment = Enum.TextXAlignment.Left,
		ZIndex = Z.Tooltip + 1,
	})
	self:_RegisterTheme(ttTitle, "TextColor3", "Text")

	local ttDesc = Mk("TextLabel", {
		Parent = ttFrame,
		Position = UD2(0, 8, 0, 18),
		Size = UD2(1, -16, 0, 14),
		BackgroundTransparency = 1,
		Font = Enum.Font.SourceSans,
		TextSize = 12,
		TextColor3 = self.Theme.SubText,
		Text = "",
		TextXAlignment = Enum.TextXAlignment.Left,
		Visible = false,
		ZIndex = Z.Tooltip + 1,
	})
	self:_RegisterTheme(ttDesc, "TextColor3", "SubText")

	local ttTarget = nil
	local ttShowTime = 0
	local ttDelay = 0.2

	local ttSpring = Spring2D.new(0, 0, 200, 20, 1)
	local ttVisible = false

	RegisterFrameCallback("Tooltip", function(dt)
		if not ttFrame or not ttFrame.Parent then return end
		if ttFrame.Visible then
			local mp = uis:GetMouseLocation()
			ttSpring:SetTarget(mp.X + 14, mp.Y + 14)
			local sx, sy = ttSpring:Update(dt)
			ttFrame.Position = UD2(0, sx, 0, sy)
		end
	end)

	local function ShowTooltip(text, desc)
		if not text or text == "" then return end
		ttTitle.Text = tostring(text)
		local hasDesc = desc and desc ~= ""
		ttDesc.Visible = hasDesc
		if hasDesc then ttDesc.Text = tostring(desc) end

		local w = TextWidth(text, Enum.Font.SourceSansSemibold, 13) + 20
		local h = 24
		if hasDesc then
			local dw = TextWidth(desc, Enum.Font.SourceSans, 12) + 20
			w = max(w, dw)
			h = 40
		end
		ttFrame.Size = UD2(0, w, 0, h)

		local mp = uis:GetMouseLocation()
		ttSpring:SetPosition(mp.X + 14, mp.Y + 14)

		ttFrame.Visible = true
		ttVisible = true
	end

	local function HideTooltip()
		ttFrame.Visible = false
		ttVisible = false
	end

	local function AddTooltip(inst, text, desc)
		if not inst or not text or text == "" then return end
		local hoverStart = 0
		local showing = false

		Connect(inst.MouseEnter, function()
			hoverStart = tk()
			showing = false
			task.delay(ttDelay, function()
				if tk() - hoverStart >= ttDelay - 0.01 and not showing then
					showing = true
					ShowTooltip(text, desc)
				end
			end)
		end)
		Connect(inst.MouseLeave, function()
			hoverStart = tk() + 999
			showing = false
			HideTooltip()
		end)
	end

	------------------------------------------------------------------------------------------------
	-- Intro / Root
	------------------------------------------------------------------------------------------------

	local blur = nil
	if cfg.Blur ~= false then
		blur = Mk("BlurEffect", { Parent = lighting, Name = "Frontier_Blur", Size = 0 })
		if blur then Tw(blur, {Size = 14}, 0.5) end
	end

	local root = Mk("Frame", {
		Parent = sg,
		Size = UD2(0, winW, 0, winH),
		Position = UD2(0.5, -winW / 2, 0.5, -winH / 2),
		BackgroundColor3 = self.Theme.Bg,
		BorderSizePixel = 0,
		ClipsDescendants = true,
		Visible = false,
		ZIndex = Z.Root,
	})
	WindowObj._Root = root
	self:_RegisterTheme(root, "BackgroundColor3", "Bg")
	AddCorner(root, 4)
	AddStroke(root, "Border", 0, 1)
	AddShadow(root, 8)

	local bgImage = Mk("ImageLabel", {
		Parent = root,
		Size = UD2(1, 0, 1, 0),
		BackgroundTransparency = 1,
		ImageTransparency = 1,
		ScaleType = Enum.ScaleType.Crop,
		ZIndex = Z.Root,
	})

	local function ShowRoot()
		WindowObj.Open = true
		root.Visible = true
		root.Size = UD2(0, winW, 0, 0)
		root.Position = UD2(0.5, -winW / 2, 0.5, 0)
		Tw(root, {
			Size = UD2(0, winW, 0, winH),
			Position = UD2(0.5, -winW / 2, 0.5, -winH / 2)
		}, 0.38, Enum.EasingStyle.Quart)
	end

	local function HideRoot()
		WindowObj.Open = false
		Tw(root, {
			Size = UD2(0, winW, 0, 0),
			Position = UD2(root.Position.X.Scale, root.Position.X.Offset, root.Position.Y.Scale, root.Position.Y.Offset + root.AbsoluteSize.Y / 2)
		}, 0.32, Enum.EasingStyle.Quart)
		task.delay(0.32, function()
			if root and root.Parent and not WindowObj.Open then
				root.Visible = false
				root.Size = UD2(0, winW, 0, winH)
			end
		end)
	end

	-- Intro Animation
	task.spawn(function()
		if cfg.SkipIntro then
			root.Visible = true
			if blur then SafeDestroy(blur) end
			return
		end

		local w, h = 320, 100
		local intro = Mk("Frame", {
			Parent = sg,
			Size = UD2(0, w, 0, 0),
			Position = UD2(0.5, -w / 2, 0.5, 0),
			BackgroundColor3 = self.Theme.Bg,
			BorderSizePixel = 0,
			ClipsDescendants = true,
			ZIndex = Z.Intro,
		})
		self:_RegisterTheme(intro, "BackgroundColor3", "Bg")
		AddCorner(intro, 5)
		AddStroke(intro, "Border", 0, 1)

		local accentLine = Mk("Frame", {
			Parent = intro,
			Size = UD2(0, 0, 0, 2),
			Position = UD2(0, 0, 0, 0),
			BackgroundColor3 = self.Theme.Accent,
			BorderSizePixel = 0,
			ZIndex = Z.IntroInner,
		})
		self:_RegisterTheme(accentLine, "BackgroundColor3", "Accent")

		local introTitle = Mk("TextLabel", {
			Parent = intro,
			Position = UD2(0, 16, 0, 18),
			Size = UD2(1, -32, 0, 22),
			BackgroundTransparency = 1,
			Text = titleText,
			Font = Enum.Font.GothamBold,
			TextSize = 17,
			TextColor3 = self.Theme.Text,
			TextXAlignment = Enum.TextXAlignment.Left,
			ZIndex = Z.IntroInner,
		})
		self:_RegisterTheme(introTitle, "TextColor3", "Text")

		local introVer = Mk("TextLabel", {
			Parent = intro,
			Position = UD2(1, -60, 0, 18),
			Size = UD2(0, 44, 0, 22),
			BackgroundTransparency = 1,
			Text = "v" .. self.Version,
			Font = Enum.Font.SourceSans,
			TextSize = 13,
			TextColor3 = self.Theme.SubText,
			TextXAlignment = Enum.TextXAlignment.Right,
			ZIndex = Z.IntroInner,
		})
		self:_RegisterTheme(introVer, "TextColor3", "SubText")

		local statusLbl = Mk("TextLabel", {
			Parent = intro,
			Position = UD2(0, 16, 0, 48),
			Size = UD2(1, -32, 0, 14),
			BackgroundTransparency = 1,
			Text = "initializing...",
			Font = Enum.Font.SourceSans,
			TextSize = 12,
			TextColor3 = self.Theme.SubText,
			TextXAlignment = Enum.TextXAlignment.Left,
			ZIndex = Z.IntroInner,
		})
		self:_RegisterTheme(statusLbl, "TextColor3", "SubText")

		local barBg = Mk("Frame", {
			Parent = intro,
			Position = UD2(0, 16, 0, 74),
			Size = UD2(1, -32, 0, 4),
			BackgroundColor3 = self.Theme.PanelDark,
			BorderSizePixel = 0,
			ZIndex = Z.IntroInner,
		})
		self:_RegisterTheme(barBg, "BackgroundColor3", "PanelDark")
		AddCorner(barBg, 2)

		local bar = Mk("Frame", {
			Parent = barBg,
			Size = UD2(0, 0, 1, 0),
			BackgroundColor3 = self.Theme.Accent,
			BorderSizePixel = 0,
			ZIndex = Z.IntroInner + 1,
		})
		self:_RegisterTheme(bar, "BackgroundColor3", "Accent")
		AddCorner(bar, 2)

		-- open intro
		Tw(intro, {
			Size = UD2(0, w, 0, h),
			Position = UD2(0.5, -w / 2, 0.5, -h / 2)
		}, 0.4, Enum.EasingStyle.Quart)
		Tw(accentLine, {Size = UD2(1, 0, 0, 2)}, 0.5, Enum.EasingStyle.Sine)

		task.wait(0.5)

		local steps = {
			{"loading theme engine...", 0.18, 0.2},
			{"registering components...", 0.38, 0.22},
			{"building spring system...", 0.56, 0.18},
			{"mounting interface...", 0.78, 0.22},
			{"validating environment...", 0.92, 0.16},
			{"ready.", 1, 0.14},
		}

		for _, step in ipairs(steps) do
			if not intro.Parent then return end
			statusLbl.Text = step[1]
			Tw(bar, {Size = UD2(step[2], 0, 1, 0)}, step[3], Enum.EasingStyle.Sine)
			task.wait(step[3])
		end

		task.wait(0.15)

		-- close intro
		Tw(intro, {
			Size = UD2(0, w, 0, 0),
			Position = UD2(0.5, -w / 2, 0.5, 0)
		}, 0.35, Enum.EasingStyle.Quart)

		task.wait(0.36)
		SafeDestroy(intro)

		if root and root.Parent then
			ShowRoot()
		end

		task.wait(0.35)
		if blur and blur.Parent then
			Tw(blur, {Size = 0}, 0.42)
			task.delay(0.44, function() SafeDestroy(blur) end)
		end
	end)

