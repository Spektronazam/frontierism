		local consoleLabels = {}

		local function ConsoleAddEntry(entry)
			if not entry or entry.message == "__CLEAR__" then return end
			local sev = LOG_SEVERITY[entry.severity] or LOG_SEVERITY.print
			local txt = format("[%s] [%s] %s", entry.timestamp, sev.tag, entry.message)

			local lbl = Mk("TextLabel", {
				Parent = consoleScroll,
				Size = UD2(1, -8, 0, 14),
				BackgroundTransparency = 1,
				Text = txt,
				Font = Enum.Font.Code,
				TextSize = 11,
				TextColor3 = sev.color,
				TextXAlignment = Enum.TextXAlignment.Left,
				TextWrapped = true,
				AutomaticSize = Enum.AutomaticSize.Y,
				RichText = false,
				ZIndex = Z.Element + 1,
			})
			tinsert(consoleLabels, lbl)

			-- update canvas
			task.defer(function()
				if not consoleLayout or not consoleLayout.Parent then return end
				consoleScroll.CanvasSize = UD2(0, 0, 0, consoleLayout.AbsoluteContentSize.Y + 10)
				if consoleAutoScroll then
					consoleScroll.CanvasPosition = V2(0, max(0, consoleLayout.AbsoluteContentSize.Y - 170))
				end
			end)
		end

		-- populate existing entries
		for _, entry in ipairs(FrontierLib:GetLogs()) do
			ConsoleAddEntry(entry)
		end

		-- subscribe to live entries
		FrontierLib._Signals.OnLog:Connect(function(entry)
			if entry.message == "__CLEAR__" then
				for _, lbl in ipairs(consoleLabels) do SafeDestroy(lbl) end
				table.clear(consoleLabels)
				consoleScroll.CanvasSize = UD2(0, 0, 0, 0)
				consoleScroll.CanvasPosition = V2(0, 0)
				return
			end
			ConsoleAddEntry(entry)
		end)

