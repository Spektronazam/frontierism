		-- AddTextArea (multi-line)
		function api:AddTextArea(p)
			p = p or {}
			local lines = p.Lines or 5
			local lineH = 16
			local boxH = lines * lineH + 8

			local row = Mk("Frame", {
				Parent = section._Holder,
				Size = UD2(1, 0, 0, boxH + 22),
				BackgroundTransparency = 1,
				ZIndex = Z.Element,
			})

			local label = Mk("TextLabel", {
				Parent = row,
				Size = UD2(1, 0, 0, 17),
				BackgroundTransparency = 1,
				Text = tostring(p.Text or "Text Area"),
				Font = Enum.Font.SourceSans,
				TextSize = 14,
				TextColor3 = FrontierLib.Theme.Text,
				TextXAlignment = Enum.TextXAlignment.Left,
				ZIndex = Z.ElementInner,
			})
			FrontierLib:_RegisterTheme(label, "TextColor3", "Text")

			local scrollFrame = Mk("ScrollingFrame", {
				Parent = row,
				Position = UD2(0, 0, 0, 22),
				Size = UD2(1, 0, 0, boxH),
				BackgroundColor3 = FrontierLib.Theme.PanelDark,
				BorderSizePixel = 0,
				ScrollBarThickness = 3,
				ScrollBarImageColor3 = FrontierLib.Theme.Accent,
				CanvasSize = UD2(0, 0, 0, 0),
				ZIndex = Z.ElementInner,
			})
			FrontierLib:_RegisterTheme(scrollFrame, "BackgroundColor3", "PanelDark")
			AddCorner(scrollFrame, 4)
			AddStroke(scrollFrame, "Border", 0.25, 1)

			local box = Mk("TextBox", {
				Parent = scrollFrame,
				Size = UD2(1, -8, 1, 0),
				Position = UD2(0, 4, 0, 0),
				BackgroundTransparency = 1,
				Text = tostring(p.Default or ""),
				Font = Enum.Font.Code,
				TextSize = 13,
				TextColor3 = FrontierLib.Theme.Text,
				TextXAlignment = Enum.TextXAlignment.Left,
				TextYAlignment = Enum.TextYAlignment.Top,
				MultiLine = true,
				TextWrapped = true,
				ClearTextOnFocus = false,
				ZIndex = Z.ElementInner + 1,
			})
			FrontierLib:_RegisterTheme(box, "TextColor3", "Text")

			Connect(box:GetPropertyChangedSignal("Text"), function()
				local h2 = TextHeight(box.Text, Enum.Font.Code, 13, scrollFrame.AbsoluteSize.X - 12) + 8
				scrollFrame.CanvasSize = UD2(0, 0, 0, max(h2, boxH))
			end)

			local obj = {}
			local function update(noCallback)
				SetFlag(p.Flag, box.Text)
				if not noCallback then FireCallback(p.Callback, box.Text) end
			end

			Connect(box.FocusLost, function() update(false) end)
			function obj:Set(v) box.Text = tostring(v or ""); update(false) end
			function obj:Get() return box.Text end
			function obj:SetVisible(v) row.Visible = v == true; section:_UpdateSize() end

			if p.Flag then FrontierLib.Pointers[p.Flag] = obj end
			if p.DependsOn then RegisterDependency(row, p.DependsOn, section) end

			update(true)
			RegisterElement(row, p.Text)
			section:_UpdateSize()
			return obj
		end

		-- AddPlayerPicker
		function api:AddPlayerPicker(p)
			p = p or {}
			local function getPlayerNames()
				local names = {}
				for _, plr in ipairs(plrs:GetPlayers()) do
					tinsert(names, plr.Name)
				end
				table.sort(names)
				return names
			end

			local dd = api:AddDropdown({
				Text = p.Text or "Player",
				Items = getPlayerNames(),
				Default = p.Default or (lp and lp.Name) or "None",
				Flag = p.Flag,
				Callback = p.Callback,
				Tip = p.Tip,
				TipDesc = p.TipDesc,
				DependsOn = p.DependsOn,
			})

			-- auto-refresh on player join/leave
			Connect(plrs.PlayerAdded, function()
				task.wait(0.1)
				dd:Refresh(getPlayerNames())
			end)
			Connect(plrs.PlayerRemoving, function()
				task.wait(0.1)
				dd:Refresh(getPlayerNames())
			end)

			return dd
		end

		return api
	end

