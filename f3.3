	Name = FrontierLib.SecureMode and RandomName() or "Frontier_Notifications",
	ResetOnSpawn = false,
	ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
	IgnoreGuiInset = true,
})
tinsert(FrontierLib._Guis, notifGui)

local NfStyle = {
	info    = { color = RGB(150, 180, 255), icon = "i"  },
	success = { color = RGB(90, 255, 140),  icon = "✓" },
	warning = { color = RGB(255, 210, 90),  icon = "!"  },
	error   = { color = RGB(255, 80, 80),   icon = "✗" },
	orbit   = { color = RGB(190, 120, 255), icon = "⟳" },
	custom  = { color = RGB(200, 200, 200), icon = "•"  },
}

local notifList = {}
local notifPosition = "TopRight"

function FrontierLib:SetNotificationPosition(pos)
	notifPosition = pos or "TopRight"
end

function FrontierLib:Notify(cfg)
	if not notifGui or not notifGui.Parent then return end

	if type(cfg) == "string" then
		cfg = { Title = cfg }
	end

	local title = cfg.Title or "Notification"
	local content = cfg.Content or ""
	local duration = cfg.Duration or 4
	local notifType = cfg.Type or "info"
	local actions = cfg.Actions or {}
	local style = NfStyle[notifType] or NfStyle.info

	if cfg.Color then
		style = { color = cfg.Color, icon = cfg.Icon or style.icon }
	end

	local hasContent = content ~= ""
	local hasActions = #actions > 0
	local frameH = 44
	if hasContent then frameH = frameH + 18 end
	if hasActions then frameH = frameH + 28 end

	local frameW = 300

	local frame = Mk("Frame", {
		Parent = notifGui,
		Size = UD2(0, frameW, 0, frameH),
		Position = UD2(1, frameW + 10, 0, -60),
		BackgroundColor3 = FrontierLib.Theme.PanelDark,
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		ClipsDescendants = true,
		ZIndex = Z.Notification,
	})
	AddCorner(frame, 5)
	local stroke = AddStroke(frame, "Border", 1, 1)

	local accent = Mk("Frame", {
		Parent = frame,
		Size = UD2(0, 3, 1, 0),
		BackgroundColor3 = style.color,
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		ZIndex = Z.NotificationInner,
	})

	local icon = Mk("TextLabel", {
		Parent = frame,
		Size = UD2(0, 32, 0, 28),
		Position = UD2(0, 5, 0, 4),
		BackgroundTransparency = 1,
		Text = style.icon,
		Font = Enum.Font.Code,
		TextSize = 16,
		TextColor3 = style.color,
		TextTransparency = 1,
		ZIndex = Z.NotificationInner,
	})

	local titleLbl = Mk("TextLabel", {
		Parent = frame,
		Position = UD2(0, 36, 0, 4),
		Size = UD2(1, -44, 0, 18),
		BackgroundTransparency = 1,
		Text = tostring(title),
		Font = Enum.Font.SourceSansSemibold,
		TextSize = 14,
		TextColor3 = FrontierLib.Theme.Text,
		TextTransparency = 1,
		TextXAlignment = Enum.TextXAlignment.Left,
		TextTruncate = Enum.TextTruncate.AtEnd,
		ZIndex = Z.NotificationInner,
	})
	FrontierLib:_RegisterTheme(titleLbl, "TextColor3", "Text")

	local contentLbl = nil
	if hasContent then
		contentLbl = Mk("TextLabel", {
			Parent = frame,
			Position = UD2(0, 36, 0, 22),
			Size = UD2(1, -44, 0, 16),
			BackgroundTransparency = 1,
			Text = tostring(content),
			Font = Enum.Font.SourceSans,
			TextSize = 13,
			TextColor3 = FrontierLib.Theme.SubText,
			TextTransparency = 1,
			TextXAlignment = Enum.TextXAlignment.Left,
			TextTruncate = Enum.TextTruncate.AtEnd,
			ZIndex = Z.NotificationInner,
		})
		FrontierLib:_RegisterTheme(contentLbl, "TextColor3", "SubText")
	end

	local actionBtns = {}
	if hasActions then
		local actionY = frameH - 28
		local btnX = 36
		for _, act in ipairs(actions) do
			local actBtn = Mk("TextButton", {
				Parent = frame,
				Position = UD2(0, btnX, 0, actionY),
				Size = UD2(0, 60, 0, 22),
				BackgroundColor3 = style.color,
				BackgroundTransparency = 0.85,
				BorderSizePixel = 0,
				Text = tostring(act.Text or "Action"),
				Font = Enum.Font.SourceSansSemibold,
				TextSize = 12,
				TextColor3 = style.color,
				TextTransparency = 1,
				AutoButtonColor = false,
				ZIndex = Z.NotificationInner + 1,
			})
			AddCorner(actBtn, 3)
			tinsert(actionBtns, actBtn)

			Connect(actBtn.MouseButton1Click, function()
				if act.Callback then pcall(act.Callback) end
			end)

			btnX = btnX + 66
		end
	end

	local prog = Mk("Frame", {
		Parent = frame,
		Size = UD2(1, 0, 0, 2),
		Position = UD2(0, 0, 1, -2),
		BackgroundColor3 = style.color,
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		ZIndex = Z.NotificationInner + 2,
	})

	-- click to dismiss
	local dismissBtn = Mk("TextButton", {
		Parent = frame,
		Size = UD2(0, 20, 0, 20),
		Position = UD2(1, -22, 0, 4),
		BackgroundTransparency = 1,
		Text = "×",
		Font = Enum.Font.SourceSans,
		TextSize = 16,
		TextColor3 = FrontierLib.Theme.SubText,
		TextTransparency = 1,
		AutoButtonColor = false,
		ZIndex = Z.NotificationInner + 2,
	})

	local n = {
		frame = frame,
		stroke = stroke,
		accent = accent,
		icon = icon,
		title = titleLbl,
		content = contentLbl,
		actions = actionBtns,
		prog = prog,
		dismiss = dismissBtn,
		born = tk(),
		life = duration,
		out = false,
		dismissed = false,
	}

	Connect(dismissBtn.MouseButton1Click, function()
		n.dismissed = true
	end)

	tinsert(notifList, n)

	-- history
	tinsert(FrontierLib._NotifHistory, {
		Title = title,
		Content = content,
		Type = notifType,
		Time = os.date("%H:%M:%S"),
	})
	if #FrontierLib._NotifHistory > 50 then
		tremove(FrontierLib._NotifHistory, 1)
	end

	-- fade in
	Tw(frame, {BackgroundTransparency = 0.04}, 0.24)
	Tw(stroke, {Transparency = 0.15}, 0.24)
	Tw(accent, {BackgroundTransparency = 0}, 0.24)
	Tw(icon, {TextTransparency = 0}, 0.24)
	Tw(titleLbl, {TextTransparency = 0}, 0.24)
	Tw(dismissBtn, {TextTransparency = 0.4}, 0.24)
	Tw(prog, {BackgroundTransparency = 0.15}, 0.24)
	if contentLbl then Tw(contentLbl, {TextTransparency = 0}, 0.24) end
	for _, ab in ipairs(actionBtns) do Tw(ab, {TextTransparency = 0}, 0.24) end

	FrontierLib._Signals.OnNotify:Fire(cfg)
end

local function FadeOutNotif(n)
	if n.out then return end
	n.out = true
	Tw(n.frame, {BackgroundTransparency = 1}, 0.22)
	Tw(n.stroke, {Transparency = 1}, 0.22)
	Tw(n.accent, {BackgroundTransparency = 1}, 0.22)
	Tw(n.icon, {TextTransparency = 1}, 0.22)
	Tw(n.title, {TextTransparency = 1}, 0.22)
	Tw(n.dismiss, {TextTransparency = 1}, 0.22)
	Tw(n.prog, {BackgroundTransparency = 1}, 0.22)
	if n.content then Tw(n.content, {TextTransparency = 1}, 0.22) end
	for _, ab in ipairs(n.actions or {}) do Tw(ab, {TextTransparency = 1}, 0.22) end
	task.delay(0.24, function() SafeDestroy(n.frame) end)
end

RegisterFrameCallback("Notifications", function(dt)
	if not notifGui or not notifGui.Parent then return end
	if #notifList == 0 then return end

	local now = tk()
	local dead = {}
	local gap = 8
	local vpSize = workspace.CurrentCamera and workspace.CurrentCamera.ViewportSize or V2(1920, 1080)

	for i, n in ipairs(notifList) do
		if not n.frame or not n.frame.Parent then
			tinsert(dead, i)
			continue
		end

		local age = now - n.born

		if (age >= n.life or n.dismissed) and not n.out then
			FadeOutNotif(n)
			tinsert(dead, i)
			continue
		end

		if not n.out then
			local pct = clamp(1 - (age / n.life), 0, 1)
			n.prog.Size = UD2(pct, 0, 0, 2)
		end

		local targetY = 34 + (i - 1) * (n.frame.AbsoluteSize.Y + gap)
		local targetX

		if notifPosition == "TopLeft" then
			targetX = 14
		elseif notifPosition == "BottomRight" then
			targetX = vpSize.X - n.frame.AbsoluteSize.X - 14
			targetY = vpSize.Y - 34 - i * (n.frame.AbsoluteSize.Y + gap)
		elseif notifPosition == "BottomLeft" then
			targetX = 14
			targetY = vpSize.Y - 34 - i * (n.frame.AbsoluteSize.Y + gap)
		else
			targetX = vpSize.X - n.frame.AbsoluteSize.X - 14
		end

		local curr = n.frame.Position
		n.frame.Position = UD2(0, curr.X.Offset + (targetX - curr.X.Offset) * min(dt * 14, 1), 0, curr.Y.Offset + (targetY - curr.Y.Offset) * min(dt * 14, 1))
	end

	for i = #dead, 1, -1 do
		tremove(notifList, dead[i])
	end
end)

----------------------------------------------------------------------------------------------------
-- Dialog / Prompt System
----------------------------------------------------------------------------------------------------

function FrontierLib:Prompt(cfg)
	cfg = cfg or {}
	local title = cfg.Title or "Confirm"
	local content = cfg.Content or ""
	local buttons = cfg.Buttons or {{Text = "OK"}}
	local autoDismiss = cfg.AutoDismiss

	local sg = notifGui or GuiParent:FindFirstChildOfClass("ScreenGui")
	if not sg then return end

	local overlay = Mk("Frame", {
		Parent = sg,
		Size = UD2(1, 0, 1, 0),
		BackgroundColor3 = RGB(0, 0, 0),
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		ZIndex = Z.Dialog - 1,
	})
	Tw(overlay, {BackgroundTransparency = 0.5}, 0.25)

	local contentH = TextHeight(content, Enum.Font.SourceSans, 14, 280) + 4
	local totalH = 50 + contentH + 42

	local dialog = Mk("Frame", {
		Parent = sg,
		Size = UD2(0, 320, 0, 0),
		Position = UD2(0.5, -160, 0.5, 0),
		BackgroundColor3 = self.Theme.Bg,
		BorderSizePixel = 0,
		ClipsDescendants = true,
		ZIndex = Z.Dialog,
	})
	self:_RegisterTheme(dialog, "BackgroundColor3", "Bg")
	AddCorner(dialog, 5)
	AddStroke(dialog, "Accent", 0.3, 1)

	Tw(dialog, {
		Size = UD2(0, 320, 0, totalH),
		Position = UD2(0.5, -160, 0.5, -totalH / 2),
	}, 0.3, Enum.EasingStyle.Quart)

	local titleLbl = Mk("TextLabel", {
		Parent = dialog,
		Position = UD2(0, 16, 0, 12),
		Size = UD2(1, -32, 0, 22),
		BackgroundTransparency = 1,
		Text = title,
		Font = Enum.Font.GothamBold,
		TextSize = 16,
		TextColor3 = self.Theme.Accent,
		TextXAlignment = Enum.TextXAlignment.Left,
		ZIndex = Z.DialogInner,
	})
	self:_RegisterTheme(titleLbl, "TextColor3", "Accent")

	local contentLbl = Mk("TextLabel", {
		Parent = dialog,
		Position = UD2(0, 16, 0, 40),
		Size = UD2(1, -32, 0, contentH),
		BackgroundTransparency = 1,
		Text = content,
		Font = Enum.Font.SourceSans,
		TextSize = 14,
		TextColor3 = self.Theme.Text,
		TextXAlignment = Enum.TextXAlignment.Left,
		TextYAlignment = Enum.TextYAlignment.Top,
		TextWrapped = true,
		ZIndex = Z.DialogInner,
	})
	self:_RegisterTheme(contentLbl, "TextColor3", "Text")

	local function dismiss()
		Tw(overlay, {BackgroundTransparency = 1}, 0.2)
		Tw(dialog, {
			Size = UD2(0, 320, 0, 0),
			Position = UD2(0.5, -160, 0.5, 0),
		}, 0.25, Enum.EasingStyle.Quart)
		task.delay(0.26, function()
			SafeDestroy(overlay)
			SafeDestroy(dialog)
		end)
	end

	local btnX = 16
	local btnY = 40 + contentH + 10
	for _, bCfg in ipairs(buttons) do
		local btn = Mk("TextButton", {
			Parent = dialog,
			Position = UD2(0, btnX, 0, btnY),
			Size = UD2(0, 80, 0, 28),
			BackgroundColor3 = self.Theme.PanelLight,
			BorderSizePixel = 0,
			Text = bCfg.Text or "OK",
			Font = Enum.Font.SourceSansSemibold,
			TextSize = 13,
			TextColor3 = self.Theme.Text,
			AutoButtonColor = false,
			ZIndex = Z.DialogInner + 1,
		})
		self:_RegisterTheme(btn, "BackgroundColor3", "PanelLight")
		self:_RegisterTheme(btn, "TextColor3", "Text")
		AddCorner(btn, 4)
		AddHover(btn, "PanelLight", "Hover")

		Connect(btn.MouseButton1Click, function()
			if bCfg.Callback then pcall(bCfg.Callback) end
			dismiss()
		end)
		btnX = btnX + 88
	end

	if autoDismiss then
		task.delay(autoDismiss, dismiss)
	end
end

----------------------------------------------------------------------------------------------------
-- Console / Log Viewer
----------------------------------------------------------------------------------------------------

local _LogBuffer = {}
local _LogMaxSize = 256
local _ConsoleHooked = false

local LOG_SEVERITY = {
	info  = { color = RGB(150, 180, 255), tag = "INFO" },
	warn  = { color = RGB(255, 210, 90),  tag = "WARN" },
	error = { color = RGB(255, 80, 80),   tag = "ERR " },
	print = { color = RGB(210, 210, 210), tag = "LOG " },
	debug = { color = RGB(140, 200, 140), tag = "DBG " },
}

function FrontierLib:Log(severity, ...)
	severity = LOG_SEVERITY[severity] and severity or "print"
	local parts = {}
	for i = 1, select("#", ...) do
		parts[i] = tostring(select(i, ...))
	end
	local message = table.concat(parts, " ")
	local entry = {
		severity = severity,
		message = message,
		timestamp = os.date("%H:%M:%S"),
		tick = tk(),
	}
	tinsert(_LogBuffer, entry)
	while #_LogBuffer > _LogMaxSize do
		tremove(_LogBuffer, 1)
	end
	self._Signals.OnLog:Fire(entry)
end

function FrontierLib:ClearLogs()
	table.clear(_LogBuffer)
	self._Signals.OnLog:Fire({
		severity = "info",
		message = "__CLEAR__",
		timestamp = os.date("%H:%M:%S"),
		tick = tk(),
	})
end

function FrontierLib:GetLogs()
	return _LogBuffer
end

function FrontierLib:SetLogBufferSize(n)
	_LogMaxSize = max(n or 256, 16)
	while #_LogBuffer > _LogMaxSize do
		tremove(_LogBuffer, 1)
	end
end

local _origPrint = print
local _origWarn = warn

function FrontierLib:HookConsole()
	if _ConsoleHooked then return end
	_ConsoleHooked = true

	print = function(...)
		_origPrint(...)
		FrontierLib:Log("print", ...)
	end

	warn = function(...)
		_origWarn(...)
		FrontierLib:Log("warn", ...)
	end
end

function FrontierLib:UnhookConsole()
	if not _ConsoleHooked then return end
	_ConsoleHooked = false
	print = _origPrint
	warn = _origWarn
end

