		local q = lower(searchBox.Text or "")
		for _, el in ipairs(WindowObj.Elements) do
			if el.Instance and el.Instance.Parent then
				if q == "" then
					el.Instance.Visible = true
				else
					el.Instance.Visible = find(lower(el.Name), q, 1, true) ~= nil
				end
			end
		end
		for _, section in ipairs(WindowObj.Sections) do
			if section and section._UpdateSize then section:_UpdateSize() end
		end
	end)

	------------------------------------------------------------------------------------------------
	-- Dependency System
	------------------------------------------------------------------------------------------------

	local function CheckDependency(depCfg)
		if type(depCfg) == "string" then
			return FrontierLib.Flags[depCfg] == true
		elseif type(depCfg) == "table" then
			local flag = depCfg.Flag
			local value = depCfg.Value
			if value ~= nil then
				return FrontierLib.Flags[flag] == value
			else
				return FrontierLib.Flags[flag] == true
			end
		end
		return true
	end

	local function RegisterDependency(row, depCfg, section)
		if not depCfg then return end
		local flagName = type(depCfg) == "string" and depCfg or depCfg.Flag
		if not self._DependencyMap[flagName] then
			self._DependencyMap[flagName] = {}
		end
		tinsert(self._DependencyMap[flagName], {
			Row = row,
			Config = depCfg,
			Section = section,
		})
		row.Visible = CheckDependency(depCfg)
	end

	self._Signals.OnFlagChanged:Connect(function(flag)
		local deps = self._DependencyMap[flag]
		if not deps then return end
		for _, dep in ipairs(deps) do
			local vis = CheckDependency(dep.Config)
			if dep.Row then
				dep.Row.Visible = vis
			end
			if dep.Section and dep.Section._UpdateSize then
				dep.Section:_UpdateSize()
			end
		end
	end)

	------------------------------------------------------------------------------------------------
	-- Component Factory
	------------------------------------------------------------------------------------------------

	local function RegisterElement(row, name)
		tinsert(WindowObj.Elements, { Instance = row, Name = tostring(name or "") })
	end

	local function SetFlag(flag, value)
		if flag then
			FrontierLib.Flags[flag] = value
			self._Signals.OnFlagChanged:Fire(flag, value)
		end
	end

	local function FireCallback(cb, ...)
		if cb then pcall(cb, ...) end
	end

	local function CreateSectionAPI(section)
		local api = section

		-- AddLabel
		function api:AddLabel(text)
			local lbl = Mk("TextLabel", {
				Parent = section._Holder,
				Size = UD2(1, 0, 0, 20),
				BackgroundTransparency = 1,
				Text = tostring(text or ""),
