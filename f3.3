				TextSize = 14,
				TextColor3 = FrontierLib.Theme.Accent,
				TextXAlignment = Enum.TextXAlignment.Left,
				ZIndex = Z.Element,
			})
			FrontierLib:_RegisterTheme(lbl, "TextColor3", "Accent")
			section:_UpdateSize()
			local obj = {}
			function obj:SetText(t) lbl.Text = tostring(t or "") end
			return obj
		end

