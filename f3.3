		-- AddProgressBar
		function api:AddProgressBar(p)
			p = p or {}
			local row = Mk("Frame", {
				Parent = section._Holder,
				Size = UD2(1, 0, 0, 36),
				BackgroundTransparency = 1,
				ZIndex = Z.Element,
			})

			local label = Mk("TextLabel", {
				Parent = row,
				Size = UD2(1, -50, 0, 16),
				BackgroundTransparency = 1,
				Text = tostring(p.Text or "Progress"),
				Font = Enum.Font.SourceSans,
				TextSize = 14,
				TextColor3 = FrontierLib.Theme.Text,
				TextXAlignment = Enum.TextXAlignment.Left,
				ZIndex = Z.ElementInner,
			})
			FrontierLib:_RegisterTheme(label, "TextColor3", "Text")

			local pctLabel = Mk("TextLabel", {
				Parent = row,
				Position = UD2(1, -48, 0, 0),
				Size = UD2(0, 48, 0, 16),
				BackgroundTransparency = 1,
				Text = "0%",
				Font = Enum.Font.SourceSans,
				TextSize = 14,
				TextColor3 = FrontierLib.Theme.Accent,
				TextXAlignment = Enum.TextXAlignment.Right,
				ZIndex = Z.ElementInner,
			})
			FrontierLib:_RegisterTheme(pctLabel, "TextColor3", "Accent")

			local track = Mk("Frame", {
				Parent = row,
				Position = UD2(0, 0, 0, 22),
				Size = UD2(1, 0, 0, 8),
				BackgroundColor3 = FrontierLib.Theme.PanelDark,
				BorderSizePixel = 0,
				ZIndex = Z.ElementInner,
			})
			FrontierLib:_RegisterTheme(track, "BackgroundColor3", "PanelDark")
			AddCorner(track, 4)

			local fill = Mk("Frame", {
				Parent = track,
				Size = UD2(0, 0, 1, 0),
				BackgroundColor3 = FrontierLib.Theme.Accent,
				BorderSizePixel = 0,
				ZIndex = Z.ElementInner + 1,
			})
			FrontierLib:_RegisterTheme(fill, "BackgroundColor3", "Accent")
			AddCorner(fill, 4)

			local value = p.Default or 0
			SetFlag(p.Flag, value)

			local obj = {}
			function obj:Set(v)
				v = clamp(tonumber(v) or 0, 0, 1)
				value = v
				SetFlag(p.Flag, value)
				Tw(fill, {Size = UD2(v, 0, 1, 0)}, 0.2)
				pctLabel.Text = floor(v * 100) .. "%"
			end
			function obj:Get() return value end

			obj:Set(value)
			RegisterElement(row, p.Text)
			section:_UpdateSize()
			return obj
		end

		-- AddCredits
		function api:AddCredits()
			WindowObj._Required.Credits = true
			local row = Mk("Frame", {
				Parent = section._Holder,
				Size = UD2(1, 0, 0, 48),
				BackgroundColor3 = FrontierLib.Theme.PanelDark,
				BorderSizePixel = 0,
				ZIndex = Z.Element,
			})
			FrontierLib:_RegisterTheme(row, "BackgroundColor3", "PanelDark")
			AddCorner(row, 4)
			AddStroke(row, "Border", 0.3, 1)

			local txt = Mk("TextLabel", {
				Parent = row,
				Size = UD2(1, 0, 1, 0),
				BackgroundTransparency = 1,
				Text = "made w/ love by frontier",
				Font = Enum.Font.GothamBold,
				TextSize = 18,
				TextColor3 = C3(1, 1, 1),
				ZIndex = Z.ElementInner,
			})

			local grad = Mk("UIGradient", {
				Parent = txt,
				Color = ColorSequence.new({
					ColorSequenceKeypoint.new(0, RGB(0, 0, 0)),
					ColorSequenceKeypoint.new(0.5, FrontierLib.Theme.Accent),
					ColorSequenceKeypoint.new(1, RGB(0, 0, 0)),
				}),
