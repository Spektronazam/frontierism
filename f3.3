				ZIndex = Z.ElementInner,
			})
			FrontierLib:_RegisterTheme(track, "BackgroundColor3", "PanelDark")
			AddCorner(track, 9)
			AddStroke(track, "Border", 0.2, 1)

			-- switch knob
			local knob = Mk("Frame", {
				Parent = track,
				Size = UD2(0, 14, 0, 14),
				Position = UD2(0, 2, 0.5, -7),
				BackgroundColor3 = FrontierLib.Theme.SubText,
				BorderSizePixel = 0,
				ZIndex = Z.ElementInner + 1,
			})
			AddCorner(knob, 7)

			local label = Mk("TextLabel", {
				Parent = row,
				Position = UD2(0, 44, 0, 0),
				Size = UD2(1, -44, 1, 0),
				BackgroundTransparency = 1,
				Text = tostring(p.Text or "Toggle"),
				Font = Enum.Font.SourceSans,
				TextSize = 14,
				TextColor3 = FrontierLib.Theme.Text,
				TextXAlignment = Enum.TextXAlignment.Left,
				ZIndex = Z.ElementInner,
			})
			FrontierLib:_RegisterTheme(label, "TextColor3", "Text")
			AddTooltip(row, p.Tip, p.TipDesc)

			local state = p.Default == true
			SetFlag(p.Flag, state)

			local obj = {}

			local function update(noCallback)
				SetFlag(p.Flag, state)
				if state then
					Tw(knob, {Position = UD2(0, 20, 0.5, -7), BackgroundColor3 = FrontierLib.Theme.Accent}, 0.18)
					Tw(track, {BackgroundColor3 = FrontierLib.Theme.Accent}, 0.18)
					track.BackgroundTransparency = 0.65
				else
					Tw(knob, {Position = UD2(0, 2, 0.5, -7), BackgroundColor3 = FrontierLib.Theme.SubText}, 0.18)
					Tw(track, {BackgroundColor3 = FrontierLib.Theme.PanelDark}, 0.18)
					track.BackgroundTransparency = 0
				end
				if not noCallback then FireCallback(p.Callback, state) end
			end

			Connect(track.MouseButton1Click, function()
				state = not state
				update(false)
			end)
			Connect(label.InputBegan, function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 then
					state = not state
					update(false)
				end
			end)

			function obj:Set(v) state = v == true; update(false) end
			function obj:Get() return state end
			function obj:SetVisible(v) row.Visible = v == true; section:_UpdateSize() end

			if p.Flag then FrontierLib.Pointers[p.Flag] = obj end
			if p.DependsOn then RegisterDependency(row, p.DependsOn, section) end

			update(true)
			RegisterElement(row, p.Text)
			section:_UpdateSize()
			return obj
		end

		-- AddSlider
		function api:AddSlider(p)
			p = p or {}
			local minVal = p.Min or 0
			local maxVal = p.Max or 100
			local decimals = p.Decimals or 0
			local suffix = p.Suffix or ""
			local value = p.Default
			if value == nil then value = minVal end

			local row = Mk("Frame", {
				Parent = section._Holder,
				Size = UD2(1, 0, 0, 44),
				BackgroundTransparency = 1,
				ZIndex = Z.Element,
			})

			local label = Mk("TextLabel", {
				Parent = row,
				Size = UD2(1, -65, 0, 17),
				BackgroundTransparency = 1,
				Text = tostring(p.Text or "Slider"),
				Font = Enum.Font.SourceSans,
				TextSize = 14,
				TextColor3 = FrontierLib.Theme.Text,
				TextXAlignment = Enum.TextXAlignment.Left,
				ZIndex = Z.ElementInner,
			})
			FrontierLib:_RegisterTheme(label, "TextColor3", "Text")

			local valueBox = Mk("TextBox", {
				Parent = row,
				Position = UD2(1, -63, 0, 0),
				Size = UD2(0, 63, 0, 17),
				BackgroundTransparency = 1,
				Text = "",
				Font = Enum.Font.SourceSans,
				TextSize = 14,
				TextColor3 = FrontierLib.Theme.Accent,
				TextXAlignment = Enum.TextXAlignment.Right,
				ClearTextOnFocus = false,
				ZIndex = Z.ElementInner,
			})
			FrontierLib:_RegisterTheme(valueBox, "TextColor3", "Accent")

			local trackFrame = Mk("TextButton", {
				Parent = row,
				Position = UD2(0, 0, 0, 24),
				Size = UD2(1, 0, 0, 10),
				BackgroundColor3 = FrontierLib.Theme.PanelDark,
				BorderSizePixel = 0,
				Text = "",
				AutoButtonColor = false,
				ZIndex = Z.ElementInner,
			})
			FrontierLib:_RegisterTheme(trackFrame, "BackgroundColor3", "PanelDark")
			AddCorner(trackFrame, 5)
			AddStroke(trackFrame, "Border", 0.3, 1)

			local fill = Mk("Frame", {
				Parent = trackFrame,
				Size = UD2(0, 0, 1, 0),
				BackgroundColor3 = FrontierLib.Theme.Accent,
				BackgroundTransparency = 0.15,
				BorderSizePixel = 0,
				ZIndex = Z.ElementInner + 1,
			})
			FrontierLib:_RegisterTheme(fill, "BackgroundColor3", "Accent")
			AddCorner(fill, 5)

			-- knob
			local sliderKnob = Mk("Frame", {
				Parent = trackFrame,
				Size = UD2(0, 14, 0, 14),
				Position = UD2(0, -7, 0.5, -7),
				BackgroundColor3 = FrontierLib.Theme.Accent,
				BorderSizePixel = 0,
				ZIndex = Z.ElementInner + 2,
			})
			FrontierLib:_RegisterTheme(sliderKnob, "BackgroundColor3", "Accent")
			AddCorner(sliderKnob, 7)
			AddStroke(sliderKnob, "Border", 0.1, 1)

			local dragging = false
			local obj = {}

			local function round(v)
				local mult = 10 ^ decimals
				return floor(v * mult + 0.5) / mult
			end

			local function setVal(v, noCallback)
				v = tonumber(v) or minVal
				value = round(clamp(v, minVal, maxVal))
				local pct = 0
				if maxVal ~= minVal then pct = (value - minVal) / (maxVal - minVal) end
				valueBox.Text = tostring(value) .. suffix
				Tw(fill, {Size = UD2(pct, 0, 1, 0)}, 0.08)
				sliderKnob.Position = UD2(pct, -7, 0.5, -7)
				SetFlag(p.Flag, value)
				if not noCallback then FireCallback(p.Callback, value) end
			end

			local function dragTo(input)
				local pct = clamp((input.Position.X - trackFrame.AbsolutePosition.X) / max(trackFrame.AbsoluteSize.X, 1), 0, 1)
				setVal(minVal + (maxVal - minVal) * pct, false)
			end

			Connect(trackFrame.InputBegan, function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 then
					dragging = true
					dragTo(input)
				end
			end)
			Connect(uis.InputChanged, function(input)
				if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then dragTo(input) end
			end)
			Connect(uis.InputEnded, function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
			end)
			Connect(valueBox.FocusLost, function()
				local n = tonumber(valueBox.Text:gsub(suffix, ""))
				if n then setVal(n, false) else valueBox.Text = tostring(value) .. suffix end
			end)

			function obj:Set(v) setVal(v, false) end
			function obj:Get() return value end
			function obj:SetVisible(v) row.Visible = v == true; section:_UpdateSize() end

			if p.Flag then FrontierLib.Pointers[p.Flag] = obj end
			if p.DependsOn then RegisterDependency(row, p.DependsOn, section) end

			AddTooltip(row, p.Tip, p.TipDesc)
			setVal(value, true)
			RegisterElement(row, p.Text)
			section:_UpdateSize()
			return obj
		end

		-- AddDropdown
		function api:AddDropdown(p)
			p = p or {}
			local items = p.Items or {}
			local isMulti = p.Multi == true

			local state
			if isMulti then
				state = {}
				if type(p.Default) == "table" then
					for k, v in pairs(p.Default) do
						if type(k) == "number" then state[v] = true else state[k] = v == true end
					end
				end
			else
				state = p.Default or items[1] or "None"
			end

			local row = Mk("Frame", {
				Parent = section._Holder,
				Size = UD2(1, 0, 0, 50),
				BackgroundTransparency = 1,
				ZIndex = Z.Element,
			})

			local label = Mk("TextLabel", {
				Parent = row,
				Size = UD2(1, 0, 0, 17),
				BackgroundTransparency = 1,
				Text = tostring(p.Text or "Dropdown"),
				Font = Enum.Font.SourceSans,
				TextSize = 14,
				TextColor3 = FrontierLib.Theme.Text,
				TextXAlignment = Enum.TextXAlignment.Left,
				ZIndex = Z.ElementInner,
			})
			FrontierLib:_RegisterTheme(label, "TextColor3", "Text")

			local btn = Mk("TextButton", {
				Parent = row,
				Position = UD2(0, 0, 0, 22),
				Size = UD2(1, 0, 0, 26),
				BackgroundColor3 = FrontierLib.Theme.PanelDark,
				BorderSizePixel = 0,
				Text = "",
				AutoButtonColor = false,
				ZIndex = Z.ElementInner,
			})
			FrontierLib:_RegisterTheme(btn, "BackgroundColor3", "PanelDark")
			AddCorner(btn, 4)
			AddStroke(btn, "Border", 0.25, 1)
			AddHover(btn, "PanelDark", "Hover")

			local valTxt = Mk("TextLabel", {
				Parent = btn,
				Position = UD2(0, 8, 0, 0),
				Size = UD2(1, -30, 1, 0),
				BackgroundTransparency = 1,
				Text = "",
				Font = Enum.Font.SourceSans,
				TextSize = 13,
				TextColor3 = FrontierLib.Theme.SubText,
				TextXAlignment = Enum.TextXAlignment.Left,
				TextTruncate = Enum.TextTruncate.AtEnd,
				ZIndex = Z.ElementInner + 1,
			})
			FrontierLib:_RegisterTheme(valTxt, "TextColor3", "SubText")

			local arrow = Mk("TextLabel", {
				Parent = btn,
				Position = UD2(1, -22, 0, 0),
				Size = UD2(0, 18, 1, 0),
				BackgroundTransparency = 1,
				Text = "▼",
				Font = Enum.Font.SourceSans,
				TextSize = 11,
				TextColor3 = FrontierLib.Theme.SubText,
				ZIndex = Z.ElementInner + 1,
			})
			FrontierLib:_RegisterTheme(arrow, "TextColor3", "SubText")

			local menuOpen = false
			local menuFrame = nil
			local obj = {}

			local function updateDisplay(noCallback)
				if isMulti then
					local selected = {}
					for _, item in ipairs(items) do
						if state[item] then tinsert(selected, tostring(item)) end
					end
					valTxt.Text = #selected > 0 and table.concat(selected, ", ") or "None"
					SetFlag(p.Flag, state)
				else
					valTxt.Text = tostring(state)
					SetFlag(p.Flag, state)
				end
				if not noCallback then FireCallback(p.Callback, state) end
			end

			local function closeMenu()
				if menuFrame then SafeDestroy(menuFrame); menuFrame = nil end
				menuOpen = false
				arrow.Text = "▼"
			end

			local function openMenu()
				if menuOpen then closeMenu(); return end
				menuOpen = true
				arrow.Text = "▲"

				local maxVisible = p.MaxVisible or 6
				local itemH = 25
				local searchH = isMulti and 30 or 0
				local height = min(#items * itemH + 4 + searchH, maxVisible * itemH + 4 + searchH)
				local ap = AbsPosAdjusted(btn)
				local x = btn.AbsolutePosition.X
				local y = btn.AbsolutePosition.Y + btn.AbsoluteSize.Y + 2

				local vpH = workspace.CurrentCamera and workspace.CurrentCamera.ViewportSize.Y or 1080
				if y + height > vpH then y = btn.AbsolutePosition.Y - height - 2 end

				menuFrame = Mk("Frame", {
					Parent = sg,
					Size = UD2(0, btn.AbsoluteSize.X, 0, height),
					Position = UD2(0, x, 0, y),
					BackgroundColor3 = FrontierLib.Theme.PanelDark,
					BorderSizePixel = 0,
					ClipsDescendants = true,
					ZIndex = Z.Dropdown,
				})
				FrontierLib:_RegisterTheme(menuFrame, "BackgroundColor3", "PanelDark")
				AddCorner(menuFrame, 4)
				AddStroke(menuFrame, "Border", 0, 1)

				local filterText = ""
				local itemContainer

				if isMulti then
					-- select all / deselect all row
					local ctrlRow = Mk("Frame", {
						Parent = menuFrame,
						Size = UD2(1, 0, 0, 26),
						BackgroundTransparency = 1,
						ZIndex = Z.DropdownItem,
					})
					local selAll = Mk("TextButton", {
						Parent = ctrlRow,
						Size = UD2(0.5, -1, 1, 0),
						BackgroundColor3 = FrontierLib.Theme.Panel,
						BorderSizePixel = 0,
						Text = "Select All",
						Font = Enum.Font.SourceSans,
						TextSize = 12,
						TextColor3 = FrontierLib.Theme.Accent,
						AutoButtonColor = false,
						ZIndex = Z.DropdownItem + 1,
					})
					AddCorner(selAll, 3)
					local deselAll = Mk("TextButton", {
						Parent = ctrlRow,
						Position = UD2(0.5, 1, 0, 0),
						Size = UD2(0.5, -1, 1, 0),
						BackgroundColor3 = FrontierLib.Theme.Panel,
						BorderSizePixel = 0,
						Text = "Deselect All",
						Font = Enum.Font.SourceSans,
						TextSize = 12,
						TextColor3 = FrontierLib.Theme.SubText,
						AutoButtonColor = false,
						ZIndex = Z.DropdownItem + 1,
					})
					AddCorner(deselAll, 3)

					Connect(selAll.MouseButton1Click, function()
						for _, it in ipairs(items) do state[it] = true end
						closeMenu()
						updateDisplay(false)
					end)
					Connect(deselAll.MouseButton1Click, function()
						for _, it in ipairs(items) do state[it] = nil end
						closeMenu()
						updateDisplay(false)
					end)
				end

				-- scrolling item list
				itemContainer = Mk("ScrollingFrame", {
					Parent = menuFrame,
					Size = UD2(1, 0, 1, isMulti and -28 or 0),
					Position = UD2(0, 0, 0, isMulti and 28 or 0),
					BackgroundTransparency = 1,
					BorderSizePixel = 0,
					ScrollBarThickness = 2,
					ScrollBarImageColor3 = FrontierLib.Theme.Accent,
					CanvasSize = UD2(0, 0, 0, 0),
					ZIndex = Z.DropdownItem,
				})
				local iLayout = AddList(itemContainer, 0)
				Connect(iLayout:GetPropertyChangedSignal("AbsoluteContentSize"), function()
					if itemContainer then itemContainer.CanvasSize = UD2(0, 0, 0, iLayout.AbsoluteContentSize.Y) end
				end)

				for _, item in ipairs(items) do
					local selected = isMulti and state[item] or state == item
					local itBtn = Mk("TextButton", {
						Parent = itemContainer,
						Size = UD2(1, 0, 0, itemH),
						BackgroundTransparency = 1,
						BorderSizePixel = 0,
						Text = "  " .. tostring(item),
						Font = Enum.Font.SourceSans,
						TextSize = 13,
						TextColor3 = selected and FrontierLib.Theme.Accent or FrontierLib.Theme.Text,
						TextXAlignment = Enum.TextXAlignment.Left,
						AutoButtonColor = false,
						ZIndex = Z.DropdownItem + 1,
					})
					AddHover(itBtn, "PanelDark", "Hover")

					Connect(itBtn.MouseButton1Click, function()
						if isMulti then
							state[item] = not state[item]
							itBtn.TextColor3 = state[item] and FrontierLib.Theme.Accent or FrontierLib.Theme.Text
						else
							state = item
							closeMenu()
						end
						updateDisplay(false)
					end)
				end
			end

			Connect(btn.MouseButton1Click, openMenu)

			Connect(uis.InputBegan, function(input)
				if menuOpen and input.UserInputType == Enum.UserInputType.MouseButton1 then
					if menuFrame and not IsMouseInside(menuFrame, input) and not IsMouseInside(btn, input) then
						closeMenu()
					end
				end
			end)

			function obj:Set(v)
				if isMulti then
					state = {}
					if type(v) == "table" then
						for k, val in pairs(v) do
							if type(k) == "number" then state[val] = true else state[k] = val == true end
						end
					end
				else
					state = v
				end
				updateDisplay(false)
			end
			function obj:Get() return state end
			function obj:Refresh(newItems, preferred)
				items = newItems or {}
				if isMulti then
					local valid = {}
					for _, item in ipairs(items) do valid[item] = true end
					for k in pairs(state) do if not valid[k] then state[k] = nil end end
				else
					local found = false
					for _, item in ipairs(items) do if item == state then found = true; break end end
					if preferred then state = preferred elseif not found then state = items[1] or "None" end
				end
				closeMenu()
				updateDisplay(false)
			end
			function obj:SetVisible(v) row.Visible = v == true; section:_UpdateSize() end

			if p.Flag then FrontierLib.Pointers[p.Flag] = obj end
			if p.DependsOn then RegisterDependency(row, p.DependsOn, section) end

			AddTooltip(row, p.Tip, p.TipDesc)
			updateDisplay(true)
			RegisterElement(row, p.Text)
			section:_UpdateSize()
			return obj
		end

