			AddCorner(cBtn, 4)
			AddStroke(cBtn, "Border", 0.15, 1)

			local menuOpen = false
			local popup = nil
			local hexBox, svMarker, hueMarker, preview = nil, nil, nil, nil
			local obj = {}

			local function closePopup()
				if popup then SafeDestroy(popup); popup = nil end
				menuOpen = false
			end

			local function updateColor(c, noCallback)
				if typeof(c) ~= "Color3" then return end
				color = c
				h, s, v = color:ToHSV()
				cBtn.BackgroundColor3 = color
				if preview then preview.BackgroundColor3 = color end
				if hexBox and hexBox.Parent then hexBox.Text = ColorToHex(color) end
				if svMarker and svMarker.Parent then svMarker.Position = UD2(s, -4, 1 - v, -4) end
				if hueMarker and hueMarker.Parent then hueMarker.Position = UD2(0, -2, h, -3) end
				SetFlag(p.Flag, ColorToHex(color))
				if not noCallback then FireCallback(p.Callback, color) end
			end

			local presetColors = {
				RGB(255,255,255), RGB(200,200,200), RGB(128,128,128), RGB(0,0,0),
				RGB(255,0,0), RGB(255,128,0), RGB(255,255,0), RGB(128,255,0),
				RGB(0,255,0), RGB(0,255,128), RGB(0,255,255), RGB(0,128,255),
				RGB(0,0,255), RGB(128,0,255), RGB(255,0,255), RGB(255,0,128),
			}

			local function buildPopup()
				closePopup()
				menuOpen = true

				local px = cBtn.AbsolutePosition.X - 200
				local py = cBtn.AbsolutePosition.Y + 28
				local popH = 234

				popup = Mk("Frame", {
					Parent = sg,
					Size = UD2(0, 248, 0, popH),
					Position = UD2(0, px, 0, py),
					BackgroundColor3 = FrontierLib.Theme.PanelDark,
					BorderSizePixel = 0,
					ZIndex = Z.ColorPicker,
				})
				FrontierLib:_RegisterTheme(popup, "BackgroundColor3", "PanelDark")
				AddCorner(popup, 5)
				AddStroke(popup, "Border", 0, 1)

				-- SV box
				local sv = Mk("TextButton", {
					Parent = popup,
					Position = UD2(0, 10, 0, 10),
					Size = UD2(0, 155, 0, 110),
					BackgroundColor3 = HSV(h, 1, 1),
					BorderSizePixel = 0,
					Text = "",
					AutoButtonColor = false,
					ZIndex = Z.ColorPickerInner,
				})
				AddCorner(sv, 3)

				Mk("Frame", {
					Parent = sv,
					Size = UD2(1, 0, 1, 0),
					BackgroundColor3 = C3(1, 1, 1),
					BorderSizePixel = 0,
					ZIndex = Z.ColorPickerInner + 1,
				})
				Mk("UIGradient", {
					Parent = sv:FindFirstChildOfClass("Frame"),
					Transparency = NumberSequence.new({NumberSequenceKeypoint.new(0, 0), NumberSequenceKeypoint.new(1, 1)}),
				})

				local blackFrame = Mk("Frame", {
					Parent = sv,
					Size = UD2(1, 0, 1, 0),
					BackgroundColor3 = C3(0, 0, 0),
					BorderSizePixel = 0,
					ZIndex = Z.ColorPickerInner + 2,
				})
				Mk("UIGradient", {
					Parent = blackFrame,
					Transparency = NumberSequence.new({NumberSequenceKeypoint.new(0, 1), NumberSequenceKeypoint.new(1, 0)}),
					Rotation = 90,
				})
				AddCorner(blackFrame, 3)

				svMarker = Mk("Frame", {
					Parent = sv,
					Size = UD2(0, 8, 0, 8),
					Position = UD2(s, -4, 1 - v, -4),
					BackgroundColor3 = C3(1, 1, 1),
					BorderSizePixel = 0,
					ZIndex = Z.ColorPickerInner + 4,
				})
				AddCorner(svMarker, 8)
				AddStroke(svMarker, "Border", 0, 1)

				-- hue bar
				local hueBar = Mk("TextButton", {
					Parent = popup,
					Position = UD2(0, 175, 0, 10),
					Size = UD2(0, 16, 0, 110),
					BackgroundColor3 = C3(1, 1, 1),
					BorderSizePixel = 0,
					Text = "",
					AutoButtonColor = false,
					ZIndex = Z.ColorPickerInner,
				})
				AddCorner(hueBar, 3)
				Mk("UIGradient", {
					Parent = hueBar,
					Rotation = 90,
					Color = ColorSequence.new({
						ColorSequenceKeypoint.new(0.000, RGB(255, 0, 0)),
						ColorSequenceKeypoint.new(0.167, RGB(255, 255, 0)),
						ColorSequenceKeypoint.new(0.333, RGB(0, 255, 0)),
						ColorSequenceKeypoint.new(0.500, RGB(0, 255, 255)),
						ColorSequenceKeypoint.new(0.667, RGB(0, 0, 255)),
						ColorSequenceKeypoint.new(0.833, RGB(255, 0, 255)),
						ColorSequenceKeypoint.new(1.000, RGB(255, 0, 0)),
					}),
				})

				hueMarker = Mk("Frame", {
					Parent = hueBar,
					Size = UD2(1, 4, 0, 6),
					Position = UD2(0, -2, h, -3),
					BackgroundColor3 = C3(1, 1, 1),
					BorderSizePixel = 0,
					ZIndex = Z.ColorPickerInner + 4,
				})
				AddCorner(hueMarker, 2)
				AddStroke(hueMarker, "Border", 0, 1)

				-- preview
				preview = Mk("Frame", {
					Parent = popup,
					Position = UD2(0, 200, 0, 10),
					Size = UD2(0, 38, 0, 110),
					BackgroundColor3 = color,
					BorderSizePixel = 0,
					ZIndex = Z.ColorPickerInner,
				})
				AddCorner(preview, 4)
				AddStroke(preview, "Border", 0.15, 1)

				-- preset row
				local presetFrame = Mk("Frame", {
					Parent = popup,
					Position = UD2(0, 10, 0, 128),
					Size = UD2(1, -20, 0, 28),
					BackgroundTransparency = 1,
					ZIndex = Z.ColorPickerInner,
				})
				local pLayout = Mk("UIGridLayout", {
					Parent = presetFrame,
					CellSize = UD2(0, 12, 0, 12),
					CellPadding = UD2(0, 3, 0, 3),
					SortOrder = Enum.SortOrder.LayoutOrder,
				})
				for _, pc in ipairs(presetColors) do
					local pBtn = Mk("TextButton", {
						Parent = presetFrame,
						BackgroundColor3 = pc,
						BorderSizePixel = 0,
						Text = "",
						AutoButtonColor = false,
						ZIndex = Z.ColorPickerInner + 1,
					})
					AddCorner(pBtn, 2)
					Connect(pBtn.MouseButton1Click, function()
						updateColor(pc, false)
						if sv and sv.Parent then sv.BackgroundColor3 = HSV(h, 1, 1) end
					end)
				end

				-- hex input
				hexBox = Mk("TextBox", {
					Parent = popup,
					Position = UD2(0, 10, 0, 164),
					Size = UD2(0.5, -14, 0, 24),
					BackgroundColor3 = FrontierLib.Theme.Bg,
					BorderSizePixel = 0,
					Text = ColorToHex(color),
					Font = Enum.Font.Code,
					TextSize = 13,
					TextColor3 = FrontierLib.Theme.Text,
					ClearTextOnFocus = false,
					ZIndex = Z.ColorPickerInner,
				})
				FrontierLib:_RegisterTheme(hexBox, "BackgroundColor3", "Bg")
				FrontierLib:_RegisterTheme(hexBox, "TextColor3", "Text")
				AddCorner(hexBox, 3)
				AddStroke(hexBox, "Border", 0.2, 1)

				-- copy button
				local copyBtn = Mk("TextButton", {
					Parent = popup,
					Position = UD2(0.5, 2, 0, 164),
					Size = UD2(0.5, -12, 0, 24),
					BackgroundColor3 = FrontierLib.Theme.Panel,
					BorderSizePixel = 0,
					Text = "Copy Hex",
					Font = Enum.Font.SourceSans,
					TextSize = 12,
					TextColor3 = FrontierLib.Theme.SubText,
					AutoButtonColor = false,
					ZIndex = Z.ColorPickerInner,
				})
				FrontierLib:_RegisterTheme(copyBtn, "BackgroundColor3", "Panel")
				AddCorner(copyBtn, 3)
				Connect(copyBtn.MouseButton1Click, function()
					pcall(setclipboard, ColorToHex(color))
					FrontierLib:Notify({Title = "Copied", Content = ColorToHex(color), Duration = 2, Type = "success"})
				end)

				-- RGB fields
				local rgbY = 196
				local function mkRGBField(labelT, getter, setter)
					local f = Mk("Frame", {
						Parent = popup,
						Size = UD2(0.33, -8, 0, 26),
						BackgroundTransparency = 1,
						ZIndex = Z.ColorPickerInner,
					})
					local fl = Mk("TextLabel", {
						Parent = f,
						Size = UD2(0, 14, 1, 0),
						BackgroundTransparency = 1,
						Text = labelT,
						Font = Enum.Font.SourceSansSemibold,
						TextSize = 12,
						TextColor3 = FrontierLib.Theme.SubText,
						ZIndex = Z.ColorPickerInner + 1,
					})
					local fb = Mk("TextBox", {
						Parent = f,
						Position = UD2(0, 16, 0, 0),
						Size = UD2(1, -16, 1, 0),
						BackgroundColor3 = FrontierLib.Theme.Bg,
						BorderSizePixel = 0,
						Text = tostring(getter()),
						Font = Enum.Font.Code,
						TextSize = 12,
						TextColor3 = FrontierLib.Theme.Text,
						ClearTextOnFocus = false,
						ZIndex = Z.ColorPickerInner + 1,
					})
					AddCorner(fb, 2)
					Connect(fb.FocusLost, function()
						local n = tonumber(fb.Text)
						if n then setter(clamp(floor(n), 0, 255)) end
					end)
					return f, fb
				end

				local rF, rBox = mkRGBField("R", function() return Byte(color.R) end, function(val)
					updateColor(RGB(val, Byte(color.G), Byte(color.B)), false)
					if sv and sv.Parent then sv.BackgroundColor3 = HSV(h, 1, 1) end
				end)
				rF.Position = UD2(0, 10, 0, rgbY)

				local gF, gBox = mkRGBField("G", function() return Byte(color.G) end, function(val)
					updateColor(RGB(Byte(color.R), val, Byte(color.B)), false)
					if sv and sv.Parent then sv.BackgroundColor3 = HSV(h, 1, 1) end
				end)
				gF.Position = UD2(0.33, 2, 0, rgbY)

				local bF, bBox = mkRGBField("B", function() return Byte(color.B) end, function(val)
					updateColor(RGB(Byte(color.R), Byte(color.G), val), false)
					if sv and sv.Parent then sv.BackgroundColor3 = HSV(h, 1, 1) end
				end)
				bF.Position = UD2(0.66, 2, 0, rgbY)

				-- dragging logic
				local svDragging = false
				local hueDragging = false

				Connect(sv.InputBegan, function(input)
					if input.UserInputType == Enum.UserInputType.MouseButton1 then
						svDragging = true
						local x = clamp((input.Position.X - sv.AbsolutePosition.X) / max(sv.AbsoluteSize.X, 1), 0, 1)
						local y = clamp((input.Position.Y - sv.AbsolutePosition.Y) / max(sv.AbsoluteSize.Y, 1), 0, 1)
						s, v = x, 1 - y
						updateColor(HSV(h, s, v), false)
					end
				end)

				Connect(hueBar.InputBegan, function(input)
					if input.UserInputType == Enum.UserInputType.MouseButton1 then
						hueDragging = true
						local y = clamp((input.Position.Y - hueBar.AbsolutePosition.Y) / max(hueBar.AbsoluteSize.Y, 1), 0, 1)
						h = y
						sv.BackgroundColor3 = HSV(h, 1, 1)
						updateColor(HSV(h, s, v), false)
					end
				end)

				Connect(uis.InputChanged, function(input)
					if input.UserInputType == Enum.UserInputType.MouseMovement then
						if svDragging then
							local x = clamp((input.Position.X - sv.AbsolutePosition.X) / max(sv.AbsoluteSize.X, 1), 0, 1)
							local y = clamp((input.Position.Y - sv.AbsolutePosition.Y) / max(sv.AbsoluteSize.Y, 1), 0, 1)
							s, v = x, 1 - y
							updateColor(HSV(h, s, v), false)
						elseif hueDragging then
							local y = clamp((input.Position.Y - hueBar.AbsolutePosition.Y) / max(hueBar.AbsoluteSize.Y, 1), 0, 1)
							h = y
							sv.BackgroundColor3 = HSV(h, 1, 1)
							updateColor(HSV(h, s, v), false)
						end
					end
				end)

				Connect(uis.InputEnded, function(input)
					if input.UserInputType == Enum.UserInputType.MouseButton1 then
						svDragging = false
						hueDragging = false
					end
				end)

				Connect(hexBox.FocusLost, function()
					local c = HexToColor(hexBox.Text)
					if c then
						updateColor(c, false)
						if sv and sv.Parent then sv.BackgroundColor3 = HSV(h, 1, 1) end
					else
						hexBox.Text = ColorToHex(color)
					end
				end)
			end

			Connect(cBtn.MouseButton1Click, function()
				if menuOpen then closePopup() else buildPopup() end
			end)

			Connect(uis.InputBegan, function(input)
				if menuOpen and input.UserInputType == Enum.UserInputType.MouseButton1 then
					if popup and not IsMouseInside(popup, input) and not IsMouseInside(cBtn, input) then
						closePopup()
					end
				end
			end)

			function obj:Set(c)
				if typeof(c) == "string" then c = HexToColor(c) end
				updateColor(c, false)
			end
			function obj:Get() return color end
			function obj:SetVisible(vv) row.Visible = vv == true; section:_UpdateSize() end

			if p.Flag then FrontierLib.Pointers[p.Flag] = obj end
			if p.DependsOn then RegisterDependency(row, p.DependsOn, section) end

			AddTooltip(row, p.Tip, p.TipDesc)
			updateColor(color, true)
			RegisterElement(row, p.Text)
			section:_UpdateSize()
			return obj
		end

		-- AddKeybind (with modifiers)
		function api:AddKeybind(p)
			p = p or {}
			local key = tostring(p.Default or "None")
			if typeof(p.Default) == "EnumItem" then key = p.Default.Name end
			local modifiers = { Ctrl = false, Shift = false, Alt = false }

			local row = Mk("Frame", {
				Parent = section._Holder,
				Size = UD2(1, 0, 0, 28),
				BackgroundTransparency = 1,
				ZIndex = Z.Element,
			})

			local label = Mk("TextLabel", {
				Parent = row,
				Size = UD2(1, -95, 1, 0),
				BackgroundTransparency = 1,
				Text = tostring(p.Text or "Keybind"),
				Font = Enum.Font.SourceSans,
				TextSize = 14,
				TextColor3 = FrontierLib.Theme.Text,
				TextXAlignment = Enum.TextXAlignment.Left,
				ZIndex = Z.ElementInner,
			})
			FrontierLib:_RegisterTheme(label, "TextColor3", "Text")

			local btn = Mk("TextButton", {
				Parent = row,
				Position = UD2(1, -90, 0, 3),
				Size = UD2(0, 90, 0, 22),
				BackgroundColor3 = FrontierLib.Theme.PanelDark,
				BorderSizePixel = 0,
				Text = "[" .. key .. "]",
				Font = Enum.Font.Code,
				TextSize = 12,
				TextColor3 = FrontierLib.Theme.SubText,
				AutoButtonColor = false,
				ZIndex = Z.ElementInner,
			})
			FrontierLib:_RegisterTheme(btn, "BackgroundColor3", "PanelDark")
			FrontierLib:_RegisterTheme(btn, "TextColor3", "SubText")
			AddCorner(btn, 4)
			AddStroke(btn, "Border", 0.25, 1)
			AddHover(btn, "PanelDark", "Hover")

			local binding = false
			local obj = {}

			local function getDisplayName()
				local parts = {}
				if modifiers.Ctrl then tinsert(parts, "Ctrl") end
				if modifiers.Shift then tinsert(parts, "Shift") end
				if modifiers.Alt then tinsert(parts, "Alt") end
				tinsert(parts, key)
				return "[" .. table.concat(parts, "+") .. "]"
			end

			local function updateBind(noCallback)
				btn.Text = getDisplayName()
				SetFlag(p.Flag, key)
				if key == "None" then
					FrontierLib.Keybinds[p.Text] = nil
				else
					FrontierLib.Keybinds[p.Text] = {
						Name = p.Text or "Keybind",
						Key = key,
						Modifiers = tclone(modifiers),
						OnPressed = p.OnPressed,
					}
				end
				if not noCallback then FireCallback(p.Callback, key) end
			end

			Connect(btn.MouseButton1Click, function()
				if binding then return end
				binding = true
				btn.Text = "[...]"
				local c
				c = uis.InputBegan:Connect(function(input)
					if input.UserInputType == Enum.UserInputType.Keyboard or input.UserInputType.Name:find("MouseButton") then
						local name = InputToName(input)
						if name == "Escape" or name == "Backspace" then
							key = "None"
							modifiers = { Ctrl = false, Shift = false, Alt = false }
						elseif name == "LeftControl" or name == "RightControl" then
							return
						elseif name == "LeftShift" or name == "RightShift" then
							return
						elseif name == "LeftAlt" or name == "RightAlt" then
							return
						else
							key = name
							modifiers.Ctrl = uis:IsKeyDown(Enum.KeyCode.LeftControl) or uis:IsKeyDown(Enum.KeyCode.RightControl)
							modifiers.Shift = uis:IsKeyDown(Enum.KeyCode.LeftShift) or uis:IsKeyDown(Enum.KeyCode.RightShift)
							modifiers.Alt = uis:IsKeyDown(Enum.KeyCode.LeftAlt) or uis:IsKeyDown(Enum.KeyCode.RightAlt)
						end
						binding = false
						updateBind(false)
						if c then c:Disconnect() end
					end
				end)
			end)

			function obj:Set(k)
				if typeof(k) == "EnumItem" then key = k.Name else key = tostring(k or "None") end
				updateBind(false)
			end
			function obj:Get() return key end
			function obj:SetVisible(v) row.Visible = v == true; section:_UpdateSize() end

			if p.Flag then FrontierLib.Pointers[p.Flag] = obj end
			if p.DependsOn then RegisterDependency(row, p.DependsOn, section) end

			AddTooltip(row, p.Tip, p.TipDesc)
			updateBind(true)
			RegisterElement(row, p.Text)
			section:_UpdateSize()
			return obj
		end

