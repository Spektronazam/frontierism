	function WindowObj:AddTab(name, opts)
		opts = opts or {}
		local icon = opts.Icon or ""

		local tab = {
			Name = tostring(name or "Tab"),
			Icon = icon,
			Sections = {},
			DefaultSection = nil,
		}

		local displayText = (icon ~= "" and (icon .. "  ") or "  ") .. tab.Name

		local btn = Mk("TextButton", {
			Parent = tabList,
			Size = UD2(1, 0, 0, 32),
			BackgroundColor3 = FrontierLib.Theme.PanelDark,
			BackgroundTransparency = 1,
			BorderSizePixel = 0,
			Text = displayText,
			Font = Enum.Font.SourceSans,
			TextSize = 14,
			TextColor3 = FrontierLib.Theme.SubText,
			TextXAlignment = Enum.TextXAlignment.Left,
			AutoButtonColor = false,
			ZIndex = Z.SidebarEl,
		})
		FrontierLib:_RegisterTheme(btn, "BackgroundColor3", "PanelDark")

		local indicator = Mk("Frame", {
			Parent = btn,
			Size = UD2(0, 3, 1, -10),
			Position = UD2(0, 0, 0, 5),
			BackgroundColor3 = FrontierLib.Theme.Accent,
			BackgroundTransparency = 1,
			BorderSizePixel = 0,
			ZIndex = Z.SidebarEl + 1,
		})
		FrontierLib:_RegisterTheme(indicator, "BackgroundColor3", "Accent")
		AddCorner(indicator, 2)

		local page = Mk("ScrollingFrame", {
			Parent = content,
			Size = UD2(1, 0, 1, 0),
			Position = UD2(1, 0, 0, 0),
			BackgroundTransparency = 1,
			Visible = false,
			ScrollBarThickness = 4,
			ScrollBarImageColor3 = FrontierLib.Theme.Accent,
			BorderSizePixel = 0,
			CanvasSize = UD2(0, 0, 0, 0),
			ZIndex = Z.Content + 1,
		})
		FrontierLib:_RegisterTheme(page, "ScrollBarImageColor3", "Accent")

		local pageLayout = AddList(page, 8)
		AddPadding(page, 10, 10, 10, 10)

		Connect(pageLayout:GetPropertyChangedSignal("AbsoluteContentSize"), function()
			page.CanvasSize = UD2(0, 0, 0, pageLayout.AbsoluteContentSize.Y + 22)
		end)

		tab.Button = btn
		tab.Indicator = indicator
		tab.Page = page
		tab.Layout = pageLayout

		local function selectTab()
			if WindowObj.ActiveTab == tab then return end
			local oldTab = WindowObj.ActiveTab
			WindowObj.ActiveTab = tab

			btn.BackgroundTransparency = 0.2
			btn.TextColor3 = FrontierLib.Theme.Text
			Tw(indicator, {BackgroundTransparency = 0}, 0.16)
			page.Visible = true

			if oldTab then
				page.Position = UD2(1, 0, 0, 0)
				Tw(page, {Position = UD2(0, 0, 0, 0)}, 0.32, Enum.EasingStyle.Quart)
				oldTab.Button.BackgroundTransparency = 1
				oldTab.Button.TextColor3 = FrontierLib.Theme.SubText
				Tw(oldTab.Indicator, {BackgroundTransparency = 1}, 0.16)
				local oldPage = oldTab.Page
				Tw(oldPage, {Position = UD2(-1, 0, 0, 0)}, 0.32, Enum.EasingStyle.Quart)
				task.delay(0.32, function()
					if WindowObj.ActiveTab ~= oldTab and oldPage then oldPage.Visible = false end
				end)
			else
				page.Position = UD2(0, 0, 0, 0)
			end

			self._Signals.OnTabChanged:Fire(tab.Name)
		end

		Connect(btn.MouseButton1Click, selectTab)
		Connect(btn.MouseEnter, function()
			if WindowObj.ActiveTab ~= tab then btn.BackgroundTransparency = 0.7 end
		end)
		Connect(btn.MouseLeave, function()
			if WindowObj.ActiveTab ~= tab then btn.BackgroundTransparency = 1 end
		end)

		function tab:AddSection(title)
			local sectionFrame = Mk("Frame", {
				Parent = page,
				Size = UD2(1, 0, 0, 40),
				BackgroundColor3 = FrontierLib.Theme.Panel,
				BorderSizePixel = 0,
				ZIndex = Z.Section,
			})
			FrontierLib:_RegisterTheme(sectionFrame, "BackgroundColor3", "Panel")
			AddCorner(sectionFrame, 4)
			AddStroke(sectionFrame, "Border", 0.12, 1)

			-- gradient header underline
			local headerLine = Mk("Frame", {
				Parent = sectionFrame,
				Position = UD2(0, 8, 0, 26),
				Size = UD2(1, -16, 0, 1),
				BackgroundColor3 = FrontierLib.Theme.Accent,
				BackgroundTransparency = 0.75,
				BorderSizePixel = 0,
				ZIndex = Z.SectionHeader,
			})
			FrontierLib:_RegisterTheme(headerLine, "BackgroundColor3", "Accent")

			local header = Mk("TextLabel", {
				Parent = sectionFrame,
				Position = UD2(0, 8, 0, 0),
				Size = UD2(1, -16, 0, 26),
				BackgroundTransparency = 1,
				Text = tostring(title or "Section"),
				Font = Enum.Font.SourceSansSemibold,
				TextSize = 14,
				TextColor3 = FrontierLib.Theme.Accent,
				TextXAlignment = Enum.TextXAlignment.Left,
				ZIndex = Z.SectionHeader,
			})
			FrontierLib:_RegisterTheme(header, "TextColor3", "Accent")

			local holder = Mk("Frame", {
				Parent = sectionFrame,
				Position = UD2(0, 8, 0, 32),
				Size = UD2(1, -16, 0, 0),
				BackgroundTransparency = 1,
				ZIndex = Z.SectionHeader,
			})
			local holderLayout = AddList(holder, 6)

			local sectionObj = {
				_Tab = tab,
				_Frame = sectionFrame,
				_Holder = holder,
				_Header = header,
				_Layout = holderLayout,
			}

			function sectionObj:_UpdateSize()
				task.defer(function()
					if not sectionFrame or not sectionFrame.Parent then return end
					local visibleCount = 0
					for _, child in ipairs(holder:GetChildren()) do
						if child:IsA("GuiObject") and child.Visible then visibleCount += 1 end
					end
					local height = holderLayout.AbsoluteContentSize.Y
					holder.Size = UD2(1, -16, 0, height)
					sectionFrame.Size = UD2(1, 0, 0, height + 42)
					sectionFrame.Visible = visibleCount > 0 or searchBox.Text == ""
				end)
			end

			Connect(holderLayout:GetPropertyChangedSignal("AbsoluteContentSize"), function()
				sectionObj:_UpdateSize()
			end)

			CreateSectionAPI(sectionObj)
			tinsert(tab.Sections, sectionObj)
			tinsert(WindowObj.Sections, sectionObj)
			sectionObj:_UpdateSize()
			return sectionObj
		end

		-- default section
		tab.DefaultSection = tab:AddSection(tab.Name)

		-- FIXED: direct method forwarding (calls through to DefaultSection)
		local directMethods = {
			"AddLabel", "AddDivider", "AddParagraph", "AddImage", "AddProgressBar",
			"AddCredits", "AddButton", "AddToggle", "AddSlider", "AddDropdown",
			"AddColorPicker", "AddKeybind", "AddTextInput", "AddTextArea", "AddPlayerPicker",
		}
		for _, method in ipairs(directMethods) do
			tab[method] = function(_, ...)
				return tab.DefaultSection[method](tab.DefaultSection, ...)
			end
		end

		tinsert(WindowObj.Tabs, tab)
		if #WindowObj.Tabs == 1 then task.defer(selectTab) end
		return tab
	end

	------------------------------------------------------------------------------------------------
	-- Config System
	------------------------------------------------------------------------------------------------

	local function EnsureFolders()
		if not HasFileSystem then return false end
		if not isfolder("Frontierism") then pcall(makefolder, "Frontierism") end
		local hubFolder = "Frontierism/" .. self.ConfigFolder
		if not isfolder(hubFolder) then pcall(makefolder, hubFolder) end
		return true, hubFolder
	end

	local function GetConfigs(hubFolder)
		local cfgs = {}
		if HasFileSystem and hubFolder then
			local ok, files = pcall(listfiles, hubFolder)
			if ok and files then
				for _, file in ipairs(files) do
					local name = tostring(file):match("([^/\\]+)%.json$")
					if name then tinsert(cfgs, name) end
				end
			end
		end
		if #cfgs == 0 then tinsert(cfgs, "Default") end
		table.sort(cfgs)
		return cfgs
	end

	function WindowObj:SaveConfig(name)
		local okFolder, hubFolder = EnsureFolders()
		if not okFolder then
			FrontierLib:Notify({Title = "Error", Content = "File system unavailable.", Duration = 3, Type = "error"})
			return false
		end
		name = SanitizeFileName(name or FrontierLib.Flags.SelectedConfig or "Default")
		local data = {
			Flags = FrontierLib.Flags,
			Theme = {},
			ToggleKey = FrontierLib.ToggleKey.Name,
		}
		for k, v in pairs(FrontierLib.Theme) do
			if typeof(v) == "Color3" then data.Theme[k] = ColorToHex(v) end
		end
		local encoded = hs:JSONEncode(data)
		local ok = pcall(writefile, hubFolder .. "/" .. name .. ".json", encoded)
		if ok then
			FrontierLib:Notify({Title = "Config Saved", Content = name, Duration = 2, Type = "success"})
			self._Signals.OnConfigSaved:Fire(name)
			return true
		else
			FrontierLib:Notify({Title = "Error", Content = "Failed to save config.", Duration = 3, Type = "error"})
			return false
		end
	end

	function WindowObj:LoadConfig(name)
		local okFolder, hubFolder = EnsureFolders()
		if not okFolder then
			FrontierLib:Notify({Title = "Error", Content = "File system unavailable.", Duration = 3, Type = "error"})
			return false
		end
		name = SanitizeFileName(name or FrontierLib.Flags.SelectedConfig or "Default")
		local path = hubFolder .. "/" .. name .. ".json"
		if not isfile(path) then
			FrontierLib:Notify({Title = "Error", Content = "Config not found.", Duration = 3, Type = "error"})
			return false
		end
		local ok, data = pcall(function() return hs:JSONDecode(readfile(path)) end)
		if not ok or type(data) ~= "table" then
			FrontierLib:Notify({Title = "Error", Content = "Invalid config JSON.", Duration = 3, Type = "error"})
			return false
		end
		local flags = data.Flags or data
		if type(flags) == "table" then
			for flag, value in pairs(flags) do
				FrontierLib.Flags[flag] = value
				if FrontierLib.Pointers[flag] and FrontierLib.Pointers[flag].Set then
					pcall(function() FrontierLib.Pointers[flag]:Set(value) end)
				end
			end
		end
		if type(data.Theme) == "table" then
			for key, hex in pairs(data.Theme) do
				local c = HexToColor(hex)
				if c then FrontierLib:SetThemeKey(key, c) end
			end
		end
		if data.ToggleKey then
			local keyItem = NameToKeyCode(data.ToggleKey)
			if keyItem then FrontierLib.ToggleKey = keyItem end
		end
		FrontierLib:Notify({Title = "Config Loaded", Content = name, Duration = 2, Type = "info"})
		self._Signals.OnConfigLoaded:Fire(name)
		return true
	end

