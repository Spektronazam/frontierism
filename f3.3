		wmVisible = opts.Visible ~= false
		wmGui.Visible = wmVisible

		if opts.Position == "TopLeft" then
			wmGui.Position = UD2(0, 14, 0, 10)
		elseif opts.Position == "BottomRight" then
			wmGui.Position = UD2(1, -254, 1, -40)
		elseif opts.Position == "BottomLeft" then
			wmGui.Position = UD2(0, 14, 1, -40)
		else
			wmGui.Position = UD2(1, -254, 0, 10)
		end
	end

	local wmUpdateTimer = 0
	RegisterFrameCallback("Watermark", function(dt)
		if not wmVisible or not wmGui.Visible then return end
		wmUpdateTimer = wmUpdateTimer + dt
		if wmUpdateTimer < 0.25 then return end
		wmUpdateTimer = 0

		-- FPS
		fpsIdx = fpsIdx + 1
		if fpsIdx > fpsBufSize then fpsIdx = 1 end
		fpsBuffer[fpsIdx] = 1 / max(dt, 0.001)
		local fpsSum = 0
		local fpsCount = 0
		for _, v2 in ipairs(fpsBuffer) do fpsSum = fpsSum + v2; fpsCount = fpsCount + 1 end
		local fps = floor(fpsSum / max(fpsCount, 1))

		-- Ping
		local ping = 0
		pcall(function() ping = floor(stats.Network.ServerStatsItem["Data Ping"]:GetValue()) end)

		-- Time
		local timeStr = os.date("%H:%M:%S")

		-- User
		local userName = lp and lp.Name or "User"

		local text = wmTemplate
		text = text:gsub("{fps}", tostring(fps))
		text = text:gsub("{ping}", tostring(ping))
		text = text:gsub("{time}", timeStr)
		text = text:gsub("{user}", userName)
		wmLabel.Text = text

		local w = TextWidth(text, Enum.Font.Code, 12) + 24
		wmGui.Size = UD2(0, max(w, 120), 0, 26)
	end)

	-- Watermark drag
	local wmDrag = { active = false, start = ZV2, startPos = nil }
	Connect(wmGui.InputBegan, function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			wmDrag.active = true
			wmDrag.start = V2(input.Position.X, input.Position.Y)
			wmDrag.startPos = wmGui.Position
		end
	end)
	Connect(uis.InputChanged, function(input)
		if wmDrag.active and input.UserInputType == Enum.UserInputType.MouseMovement then
			local delta = V2(input.Position.X, input.Position.Y) - wmDrag.start
			wmGui.Position = UD2(0, wmDrag.startPos.X.Offset + delta.X, 0, wmDrag.startPos.Y.Offset + delta.Y)
		end
	end)
	Connect(uis.InputEnded, function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then wmDrag.active = false end
	end)

	------------------------------------------------------------------------------------------------
	-- Keybinds Widget (event-driven update)
	------------------------------------------------------------------------------------------------

	local kbWidget = Mk("Frame", {
		Parent = sg,
		Position = UD2(0, 20, 0, 200),
		Size = UD2(0, 195, 0, 32),
		BackgroundColor3 = self.Theme.PanelDark,
		BorderSizePixel = 0,
		Visible = false,
		ZIndex = Z.Watermark,
	})
	self:_RegisterTheme(kbWidget, "BackgroundColor3", "PanelDark")
	AddCorner(kbWidget, 4)
	AddStroke(kbWidget, "Accent", 0.3, 1)

	local kbHeader = Mk("TextLabel", {
		Parent = kbWidget,
		Size = UD2(1, 0, 0, 30),
		BackgroundTransparency = 1,
		Text = " Keybinds",
		Font = Enum.Font.SourceSansSemibold,
		TextSize = 13,
		TextColor3 = self.Theme.Accent,
		TextXAlignment = Enum.TextXAlignment.Left,
		ZIndex = Z.Watermark + 1,
	})
	self:_RegisterTheme(kbHeader, "TextColor3", "Accent")

	local kbList = Mk("Frame", {
		Parent = kbWidget,
		Position = UD2(0, 0, 0, 30),
		Size = UD2(1, 0, 1, -30),
		BackgroundTransparency = 1,
		ZIndex = Z.Watermark + 1,
	})
	AddList(kbList, 0)
	local kbLabels = {}

	local function UpdateKeybindsWidget()
		if not FrontierLib.Flags.ShowKeybindsWidget then
			kbWidget.Visible = false
			return
		end

		local count = 0
		local index = 1

		for id, bind in pairs(FrontierLib.Keybinds) do
			local name = id
			local key = bind
			if type(bind) == "table" then
				name = bind.Name or id
				key = bind.Key or "None"
			end
			if key ~= "None" then
				count += 1
				if not kbLabels[index] then
					local lbl = Mk("TextLabel", {
						Parent = kbList,
						Size = UD2(1, 0, 0, 20),
						BackgroundTransparency = 1,
						Font = Enum.Font.Code,
						TextSize = 12,
						TextColor3 = FrontierLib.Theme.Text,
						TextXAlignment = Enum.TextXAlignment.Left,
						ZIndex = Z.Watermark + 2,
					})
					FrontierLib:_RegisterTheme(lbl, "TextColor3", "Text")
					kbLabels[index] = lbl
				end
				kbLabels[index].Text = format(" %s: [%s]", tostring(name), tostring(key))
				kbLabels[index].Visible = true
				index += 1
			end
		end

		for i = index, #kbLabels do kbLabels[i].Visible = false end
		kbWidget.Visible = count > 0
		kbWidget.Size = UD2(0, 195, 0, 34 + count * 20)
	end

	-- update on flag change instead of every frame
	self._Signals.OnFlagChanged:Connect(function(flag)
		if flag == "ShowKeybindsWidget" then
			UpdateKeybindsWidget()
		end
	end)

	-- also update periodically but much less frequently
	local kbTimer = 0
	RegisterFrameCallback("KeybindWidget", function(dt)
		kbTimer = kbTimer + dt
		if kbTimer < 1 then return end
		kbTimer = 0
		UpdateKeybindsWidget()
	end)

	-- Widget drag
	local kbDrag = { active = false, start = ZV2, startPos = nil }
	Connect(kbHeader.InputBegan, function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			kbDrag.active = true
			kbDrag.start = V2(input.Position.X, input.Position.Y)
			kbDrag.startPos = kbWidget.Position
		end
	end)
	Connect(uis.InputChanged, function(input)
		if kbDrag.active and input.UserInputType == Enum.UserInputType.MouseMovement then
			local delta = V2(input.Position.X, input.Position.Y) - kbDrag.start
			kbWidget.Position = UD2(0, kbDrag.startPos.X.Offset + delta.X, 0, kbDrag.startPos.Y.Offset + delta.Y)
		end
	end)
	Connect(uis.InputEnded, function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then kbDrag.active = false end
	end)

	------------------------------------------------------------------------------------------------
	-- Auto-Save
	------------------------------------------------------------------------------------------------

	if cfg.AutoSave then
		RegisterFrameCallback("AutoSave", function(dt)
			if not WindowObj._AutoSave then return end
			local now = tk()
			if now - WindowObj._LastAutoSave >= WindowObj._AutoSaveInterval then
				WindowObj._LastAutoSave = now
				local name = FrontierLib.Flags.SelectedConfig or "Default"
				WindowObj:SaveConfig(name)
			end
		end)
	end

	------------------------------------------------------------------------------------------------
	-- Global Input
	------------------------------------------------------------------------------------------------

	Connect(uis.InputBegan, function(input, gpe)
		if gpe or uis:GetFocusedTextBox() then return end

		if input.KeyCode == FrontierLib.ToggleKey then
			WindowObj:Toggle()
			return
		end

		for _, bind in pairs(FrontierLib.Keybinds) do
			if type(bind) == "table" and bind.OnPressed and InputMatches(input, bind.Key) then
				-- check modifiers
				local mods = bind.Modifiers or {}
				local ctrlOk = not mods.Ctrl or uis:IsKeyDown(Enum.KeyCode.LeftControl) or uis:IsKeyDown(Enum.KeyCode.RightControl)
				local shiftOk = not mods.Shift or uis:IsKeyDown(Enum.KeyCode.LeftShift) or uis:IsKeyDown(Enum.KeyCode.RightShift)
				local altOk = not mods.Alt or uis:IsKeyDown(Enum.KeyCode.LeftAlt) or uis:IsKeyDown(Enum.KeyCode.RightAlt)
				if ctrlOk and shiftOk and altOk then
					pcall(bind.OnPressed, input)
				end
			end
		end
	end)

	------------------------------------------------------------------------------------------------
	-- Key System
	------------------------------------------------------------------------------------------------

	if cfg.KeySystem then
		local ks = cfg.KeySettings or {}
		local ksTitle = ks.Title or "Key System"
		local ksNote = ks.Note or "Enter your key below"
		local ksKeys = ks.Keys or {}
		local ksSave = ks.SaveKey ~= false
		local ksFile = "Frontierism/" .. SanitizeFileName(ks.FileName or "key") .. ".key"
		local ksMaxAttempts = ks.MaxAttempts or 5
		local ksAttempts = 0

		-- check saved key
		local savedKey = ""
		if ksSave and HasFileSystem then
			pcall(function()
				if isfile(ksFile) then savedKey = readfile(ksFile) end
			end)
		end

		local function validateKey(input)
			-- check against local keys
			for _, k in ipairs(ksKeys) do
				if type(k) == "string" then
					if k:match("^https?://") then
						-- remote key
						local ok, remote = pcall(function()
							return game:HttpGet(k)
						end)
						if ok and remote and remote:gsub("%s+", "") == input:gsub("%s+", "") then
							return true
						end
					elseif k == input then
						return true
					end
				end
			end
			return false
		end

		if savedKey ~= "" and validateKey(savedKey) then
			-- already authenticated
		else
			root.Visible = false

			local ksOverlay = Mk("Frame", {
				Parent = sg,
				Size = UD2(1, 0, 1, 0),
				BackgroundColor3 = RGB(0, 0, 0),
				BackgroundTransparency = 0.3,
				BorderSizePixel = 0,
				ZIndex = Z.KeySystem - 1,
			})

			local ksFrame = Mk("Frame", {
				Parent = sg,
				Size = UD2(0, 340, 0, 200),
				Position = UD2(0.5, -170, 0.5, -100),
				BackgroundColor3 = self.Theme.Bg,
				BorderSizePixel = 0,
				ZIndex = Z.KeySystem,
			})
			self:_RegisterTheme(ksFrame, "BackgroundColor3", "Bg")
			AddCorner(ksFrame, 6)
			AddStroke(ksFrame, "Accent", 0.2, 1)

			local ksAccent = Mk("Frame", {
				Parent = ksFrame,
				Size = UD2(1, 0, 0, 2),
				BackgroundColor3 = self.Theme.Accent,
				BorderSizePixel = 0,
				ZIndex = Z.KeySystemInner,
			})
			self:_RegisterTheme(ksAccent, "BackgroundColor3", "Accent")

			local ksTitleLbl = Mk("TextLabel", {
				Parent = ksFrame,
				Position = UD2(0, 20, 0, 16),
				Size = UD2(1, -40, 0, 24),
				BackgroundTransparency = 1,
				Text = ksTitle,
				Font = Enum.Font.GothamBold,
				TextSize = 18,
				TextColor3 = self.Theme.Text,
				TextXAlignment = Enum.TextXAlignment.Left,
				ZIndex = Z.KeySystemInner,
			})
			self:_RegisterTheme(ksTitleLbl, "TextColor3", "Text")

			local ksNoteLbl = Mk("TextLabel", {
				Parent = ksFrame,
				Position = UD2(0, 20, 0, 44),
				Size = UD2(1, -40, 0, 18),
				BackgroundTransparency = 1,
				Text = ksNote,
				Font = Enum.Font.SourceSans,
				TextSize = 14,
				TextColor3 = self.Theme.SubText,
				TextXAlignment = Enum.TextXAlignment.Left,
				ZIndex = Z.KeySystemInner,
			})
			self:_RegisterTheme(ksNoteLbl, "TextColor3", "SubText")

			local ksInput = Mk("TextBox", {
				Parent = ksFrame,
				Position = UD2(0, 20, 0, 80),
				Size = UD2(1, -40, 0, 32),
				BackgroundColor3 = self.Theme.PanelDark,
				BorderSizePixel = 0,
				PlaceholderText = "Enter key...",
				PlaceholderColor3 = self.Theme.SubText,
				Text = "",
				Font = Enum.Font.Code,
				TextSize = 14,
				TextColor3 = self.Theme.Text,
				ClearTextOnFocus = false,
				ZIndex = Z.KeySystemInner,
			})
			self:_RegisterTheme(ksInput, "BackgroundColor3", "PanelDark")
			self:_RegisterTheme(ksInput, "TextColor3", "Text")
			AddCorner(ksInput, 4)
			AddStroke(ksInput, "Border", 0.2, 1)

			local ksStatus = Mk("TextLabel", {
				Parent = ksFrame,
				Position = UD2(0, 20, 0, 120),
				Size = UD2(1, -40, 0, 16),
				BackgroundTransparency = 1,
				Text = "",
				Font = Enum.Font.SourceSans,
				TextSize = 13,
				TextColor3 = self.Theme.Error,
				TextXAlignment = Enum.TextXAlignment.Left,
				ZIndex = Z.KeySystemInner,
			})

			local ksBtn = Mk("TextButton", {
				Parent = ksFrame,
				Position = UD2(0, 20, 0, 148),
				Size = UD2(1, -40, 0, 34),
				BackgroundColor3 = self.Theme.Accent,
				BorderSizePixel = 0,
				Text = "Validate",
				Font = Enum.Font.SourceSansSemibold,
				TextSize = 15,
				TextColor3 = self.Theme.Bg,
				AutoButtonColor = false,
				ZIndex = Z.KeySystemInner,
			})
			self:_RegisterTheme(ksBtn, "BackgroundColor3", "Accent")
			AddCorner(ksBtn, 4)

			Connect(ksBtn.MouseButton1Click, function()
				local input = ksInput.Text:gsub("^%s+", ""):gsub("%s+$", "")
				if input == "" then
					ksStatus.Text = "Please enter a key."
					return
				end

				ksAttempts = ksAttempts + 1
				if ksAttempts > ksMaxAttempts then
					ksStatus.Text = "Too many attempts."
					return
				end

				if validateKey(input) then
					-- save key
					if ksSave and HasFileSystem then
						pcall(function()
							if not isfolder("Frontierism") then makefolder("Frontierism") end
							writefile(ksFile, input)
						end)
					end

					-- remove key UI
					SafeDestroy(ksOverlay)
					SafeDestroy(ksFrame)

					-- show main window
					if root and root.Parent then ShowRoot() end
				else
					ksStatus.Text = format("Invalid key. (%d/%d attempts)", ksAttempts, ksMaxAttempts)
					Tw(ksInput, {Position = UD2(0, 14, 0, 80)}, 0.05)
					task.delay(0.05, function()
						Tw(ksInput, {Position = UD2(0, 26, 0, 80)}, 0.05)
						task.delay(0.05, function()
							Tw(ksInput, {Position = UD2(0, 20, 0, 80)}, 0.05)
						end)
					end)
				end
			end)
		end
	end

	return WindowObj
end

----------------------------------------------------------------------------------------------------
-- Secure Mode
----------------------------------------------------------------------------------------------------

function FrontierLib:SetSecure(enabled)
	self.SecureMode = enabled == true
	if enabled then
		for _, gui in ipairs(self._Guis) do
			if gui and gui.Parent then
				pcall(function() gui.Name = RandomName() end)
			end
		end
	end
end

----------------------------------------------------------------------------------------------------
-- Destroy
----------------------------------------------------------------------------------------------------

function FrontierLib:Destroy()
	self._Alive = false
	DisconnectAll()
	self._FrameCallbacks = {}

	-- restore hooked globals
	self:UnhookConsole()
	table.clear(_LogBuffer)

	for inst, tween in pairs(TwCache) do
		pcall(function() tween:Cancel() end)
		TwCache[inst] = nil
	end

	for _, gui in ipairs(self._Guis or {}) do SafeDestroy(gui) end
	self._Guis = {}

	pcall(function()
		local ui = GuiParent:FindFirstChild("Frontierism_UI")
		if ui then ui:Destroy() end
	end)
	pcall(function()
		local nf = GuiParent:FindFirstChild("Frontier_Notifications")
		if nf then nf:Destroy() end
	end)
	pcall(function()
		local blur = lighting:FindFirstChild("Frontier_Blur")
		if blur then blur:Destroy() end
	end)

	self.Flags = {}
	self.Pointers = {}
	self.Keybinds = {}
	self._ThemeIndex = {}
	self._Windows = {}
	self._DependencyMap = {}
	self._NotifHistory = {}
end

return FrontierLib
