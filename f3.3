	-- Window methods
	function WindowObj:SetBackground(imgId, transparency, color)
		if imgId then
			local id = tostring(imgId)
			bgImage.Image = id:find("rbxassetid://") and id or ("rbxassetid://" .. id)
			bgImage.ImageColor3 = color or C3(1, 1, 1)
			Tw(bgImage, {ImageTransparency = transparency or 0.65}, 0.35)
		else
			Tw(bgImage, {ImageTransparency = 1}, 0.35)
		end
	end

	function WindowObj:SetToggleKey(key)
		local item = NameToKeyCode(key)
		if item then FrontierLib.ToggleKey = item end
	end

	function WindowObj:Show() ShowRoot() end
	function WindowObj:Hide() HideRoot() end
	function WindowObj:Toggle()
		if root.Visible and WindowObj.Open then HideRoot() else ShowRoot() end
	end
	function WindowObj:Destroy() FrontierLib:Destroy() end

