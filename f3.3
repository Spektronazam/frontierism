			Text = "Auto-scroll",
			Default = true,
			Callback = function(v) consoleAutoScroll = v end,
		})

		consoleSec:AddToggle({
			Text = "Hook print/warn Output",
			Default = false,
			Tip = "Captures print() and warn() calls into the console log",
			Callback = function(v)
				if v then FrontierLib:HookConsole() else FrontierLib:UnhookConsole() end
			end,
		})

		consoleSec:AddButton({
			Text = "Copy Log",
			Tip = "Copy all log entries to clipboard",
			Callback = function()
				local lines = {}
				for _, entry in ipairs(FrontierLib:GetLogs()) do
					local sev = LOG_SEVERITY[entry.severity] or LOG_SEVERITY.print
					tinsert(lines, format("[%s] [%s] %s", entry.timestamp, sev.tag, entry.message))
				end
				pcall(setclipboard, table.concat(lines, "\n"))
				FrontierLib:Notify({Title = "Console", Content = #lines .. " entries copied", Duration = 2, Type = "success"})
			end,
		})

		consoleSec:AddButton({
			Text = "Clear Log",
			Callback = function()
				FrontierLib:ClearLogs()
				FrontierLib:Notify({Title = "Console", Content = "Log cleared", Duration = 1.5, Type = "info"})
			end,
		})

		consoleSec:_UpdateSize()

		-- autoload
		if HasFileSystem and autoLoadFile and isfile(autoLoadFile) then
			local autoCfg = readfile(autoLoadFile)
			if autoCfg and autoCfg ~= "" then
				task.delay(0.75, function() WindowObj:LoadConfig(autoCfg) end)
			end
		end
	end)

