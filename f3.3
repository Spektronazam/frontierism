		function api:AddToggle(p)
			p = p or {}
			local row = Mk("Frame", {
				Parent = section._Holder,
				Size = UD2(1, 0, 0, 28),
				BackgroundTransparency = 1,
				ZIndex = Z.Element,
			})

			-- switch track
			local track = Mk("TextButton", {
				Parent = row,
				Size = UD2(0, 36, 0, 18),
