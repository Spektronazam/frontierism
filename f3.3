				TextYAlignment = Enum.TextYAlignment.Top,
				ZIndex = Z.ElementInner,
			})
			FrontierLib:_RegisterTheme(bLbl, "TextColor3", "SubText")

			RegisterElement(row, p.Title or "paragraph")
			section:_UpdateSize()

			local obj = {}
			function obj:SetTitle(t) if title ~= "" then end end
			function obj:SetContent(t) bLbl.Text = tostring(t or "") end
