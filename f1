-- ── NOTIFICATION SYSTEM ───────────────────────────────────────
local NfStyles = {
    info    = { color = C3(100, 160, 255), icon = "i"  },
    success = { color = C3( 80, 215, 120), icon = "✓"  },
    warning = { color = C3(255, 200,  70), icon = "!"  },
    error   = { color = C3(255,  75,  75), icon = "✕"  },
    hint    = { color = C3(190, 120, 255), icon = "?"  },
}

local Nf = { active = {}, pool = {} }

-- Draws a rounded rectangle via 4 quads + fill (approximated with squares for compat.)
local NFW, NFH_BASE, NF_PAD_X, NF_PAD_Y, NF_GAP =
    320, 0, 16, 10, 8
local NF_FONT = HasDrawing and Drawing.Fonts.Plex or nil

local function nfSlot()
    return {
        bg   = mkDraw("Square", { Filled=true,  ZIndex=11001 }),
        bord = mkDraw("Square", { Filled=false, ZIndex=11002, Thickness=1 }),
        tx   = mkDraw("Text",   { Size=14,      ZIndex=11003, Outline=true, Font=NF_FONT }),
        icon = mkDraw("Text",   { Size=15,      ZIndex=11003, Outline=false, Font=NF_FONT }),
        prog = mkDraw("Square", { Filled=true,  ZIndex=11002 }),
        accent= mkDraw("Square",{ Filled=true,  ZIndex=11002 }),
    }
end

function DespairUI:Notify(msg, dur, ntype)
    if not HasDrawing then return end
    local sty  = NfStyles[ntype] or NfStyles.info
    local slot = trem(Nf.pool) or nfSlot()
    slot.msg     = ssub(tostring(msg or ""), 1, 200)
    slot.born    = tk()
    slot.life    = dur or 3.5
    slot.color   = sty.color
    slot.iconStr = sty.icon
    slot.slideY  = -24        -- starts above, springs into place
    tins(Nf.active, slot)
end

hook(RS.RenderStepped:Connect(function(dt)
    local now = tk()
    local baseX  = Screen.W - NFW - 16
    local baseY  = 20
    local dead

    for idx, n in ipairs(Nf.active) do
        local age = now - n.born
        -- Fade in over 0.18s, fade out over 0.3s at end
        local a   = mn(clamp(age / 0.18, 0, 1), clamp((n.life - age) / 0.30, 0, 1))
        -- Spring slide-in
        n.slideY  = damp(n.slideY, 0, 0.45, dt)

        if age > n.life then
            dead = dead or {}
            tins(dead, idx)
            for _, d in pairs({ n.bg, n.bord, n.tx, n.icon, n.prog, n.accent }) do
                if d then d.Visible = false end
            end
        else
            if n.tx then n.tx.Text = n.msg end
            local tb = (n.tx and n.tx.TextBounds) or V2(NFW - 50, 16)
            local bh = tb.Y + NF_PAD_Y * 2
            local bw = NFW
            local px = baseX
            local py = baseY + (idx - 1) * (bh + NF_GAP) + n.slideY

            -- Transparencies: Drawing uses 0=opaque, 1=transparent
            local bgT    = 1 - (a * 0.96)
            local bordT  = 1 - (a * 0.7)
            local textT  = 1 - a

            if n.bg then
                n.bg.Size=V2(bw,bh); n.bg.Position=V2(px,py)
                n.bg.Color=C3(22,22,28); n.bg.Transparency=bgT; n.bg.Visible=true
            end
            if n.bord then
                n.bord.Size=V2(bw,bh); n.bord.Position=V2(px,py)
                n.bord.Color=n.color; n.bord.Transparency=bordT; n.bord.Visible=true
            end
            if n.accent then
                -- left-side accent strip
                n.accent.Size=V2(3,bh); n.accent.Position=V2(px,py)
                n.accent.Color=n.color; n.accent.Transparency=textT; n.accent.Visible=true
            end
            if n.icon then
                n.icon.Text=n.iconStr; n.icon.Color=n.color
                n.icon.Position=V2(px+14, py + bh/2 - 8)
                n.icon.Transparency=textT; n.icon.Visible=true
            end
            if n.tx then
                n.tx.Color=WHITE; n.tx.Position=V2(px+34, py+NF_PAD_Y-1)
                n.tx.Transparency=textT; n.tx.Visible=true
            end
            -- Progress bar at bottom
            local pct = clamp(1 - (age / n.life), 0, 1)
            if n.prog then
                n.prog.Size=V2(bw*pct,2); n.prog.Position=V2(px, py+bh-2)
                n.prog.Color=n.color; n.prog.Transparency=textT; n.prog.Visible=true
            end
        end
    end

    if dead then
        for j = #dead, 1, -1 do
            local n = trem(Nf.active, dead[j])
            for _, d in pairs({ n.bg, n.bord, n.tx, n.icon, n.prog, n.accent }) do
                if d then d.Visible = false end
            end
            tins(Nf.pool, n)
        end
    end
end))

