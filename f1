                Parent = page, ZIndex = 7,
                Size = UD2(1,0,0,24), BackgroundTransparency=1,
            })
            mk("Frame", {
                Parent=sec, ZIndex=7,
                Size=UD2(1,0,0,1), Position=UD2(0,0,0.5,0),
                BackgroundColor3=Theme.Border,
            })
            mk("TextLabel", {
                Parent=sec, ZIndex=8,
                Size=UD2(0,0,1,0),
                AutomaticSize=Enum.AutomaticSize.X,
                Position=UD2(0,6,0,0),
                BackgroundColor3=Theme.Bg, BackgroundTransparency=0,
                Text=" "..text.." ",
                Font=Enum.Font.GothamBold, TextSize=11,
                TextColor3=Accent,
            })
        end

        -- Label
        function tab:AddLabel(text)
