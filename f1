        -- Toggle (pill design)
        function tab:AddToggle(p)
            local state = p.Default or false
            local row = mk("Frame", {Parent=page,ZIndex=7,Size=UD2(1,0,0,30),BackgroundColor3=Theme.Panel})
            corner(row,6)
            stroke(row,Theme.Border)
            addTooltip(row, p.Tip)

            mk("TextLabel",{Parent=row,ZIndex=8,Position=UD2(0,10,0,0),Size=UD2(1,-56,1,0),BackgroundTransparency=1,Text=p.Text,Font=Enum.Font.GothamMedium,TextSize=13,TextColor3=Theme.Text,TextXAlignment=Enum.TextXAlignment.Left})

            -- Pill track
            local track = mk("Frame",{Parent=row,ZIndex=8,Position=UD2(1,-44,0.5,-9),Size=UD2(0,36,0,18),BackgroundColor3=state and Accent or Theme.Dark})
            corner(track,9)
            stroke(track,Theme.Border)
            -- Pill thumb
            local thumb = mk("Frame",{Parent=track,ZIndex=9,Position=UD2(0,state and 18 or 1,0.5,-8),Size=UD2(0,16,0,16),BackgroundColor3=WHITE})
            corner(thumb,8)

            local trackBtn = mk("TextButton",{Parent=track,ZIndex=10,Size=UD2(1,0,1,0),BackgroundTransparency=1,Text=""})

            local function setState(v)
                state = v
                Tw(track,{BackgroundColor3= v and Accent or Theme.Dark},0.18)
                Tw(thumb,{Position= v and UD2(0,19,0.5,-8) or UD2(0,1,0.5,-8)},0.18,Enum.EasingStyle.Back)
                if p.Callback then pcall(p.Callback, state) end
            end
            hook(trackBtn.MouseButton1Click:Connect(function() setState(not state) end))
            tins(Window.Elements,{i=row,name=p.Text})
            return { Set=function(v) setState(v) end, Get=function() return state end }
        end

        -- Slider (with thumb knob + manual input)
        function tab:AddSlider(p)
            local mn2,mx2,dec = p.Min, p.Max, p.Decimals or 0
            local val = clamp(p.Default or mn2, mn2, mx2)

            local row = mk("Frame",{Parent=page,ZIndex=7,Size=UD2(1,0,0,42),BackgroundColor3=Theme.Panel})
            corner(row,6); stroke(row,Theme.Border)
            addTooltip(row,p.Tip)

            mk("TextLabel",{Parent=row,ZIndex=8,Position=UD2(0,10,0,2),Size=UD2(0.6,0,0,18),BackgroundTransparency=1,Text=p.Text,Font=Enum.Font.GothamMedium,TextSize=13,TextColor3=Theme.Text,TextXAlignment=Enum.TextXAlignment.Left})

            local valBox = mk("TextBox",{Parent=row,ZIndex=8,Position=UD2(1,-56,0,2),Size=UD2(0,50,0,18),BackgroundTransparency=1,Text="",Font=Enum.Font.GothamMedium,TextSize=13,TextColor3=Accent,TextXAlignment=Enum.TextXAlignment.Right,ClearTextOnFocus=false})

            local track = mk("Frame",{Parent=row,ZIndex=8,Position=UD2(0,10,0,26),Size=UD2(1,-20,0,6),BackgroundColor3=Theme.Dark})
            corner(track,3)

            local fill = mk("Frame",{Parent=track,ZIndex=9,Size=UD2(0,0,1,0),BackgroundColor3=Accent})
            corner(fill,3)

            local thumb = mk("Frame",{Parent=track,ZIndex=10,Size=UD2(0,14,0,14),Position=UD2(0,-7,0.5,-7),BackgroundColor3=WHITE})
            corner(thumb,7)
            stroke(thumb,Accent,2)

            local dragging = false

            local function setVal(v)
                local mult = 10^dec
                val = floor(clamp(v,mn2,mx2)*mult+0.5)/mult
                local pct = (mx2==mn2) and 0 or (val-mn2)/(mx2-mn2)
                valBox.Text = tostring(val)
                Tw(fill,{Size=UD2(pct,0,1,0)},0.08)
                Tw(thumb,{Position=UD2(pct,-7,0.5,-7)},0.08)
                if p.Callback then pcall(p.Callback,val) end
            end

            local trackBtn = mk("TextButton",{Parent=track,ZIndex=11,Size=UD2(1,14,1,14),Position=UD2(0,-7,0,-4),BackgroundTransparency=1,Text=""})

            local function onDrag(i)
                local pct = clamp((i.Position.X - track.AbsolutePosition.X)/track.AbsoluteSize.X,0,1)
                setVal(mn2+(mx2-mn2)*pct)
            end

            hook(trackBtn.InputBegan:Connect(function(i)
                if i.UserInputType==Enum.UserInputType.MouseButton1 then dragging=true; onDrag(i) end
            end))
            hook(UIS.InputChanged:Connect(function(i)
                if dragging and i.UserInputType==Enum.UserInputType.MouseMovement then onDrag(i) end
            end))
            hook(UIS.InputEnded:Connect(function(i)
                if i.UserInputType==Enum.UserInputType.MouseButton1 then dragging=false end
            end))
            hook(valBox.FocusLost:Connect(function()
                local nv=tonumber(valBox.Text)
                if nv then setVal(nv) else valBox.Text=tostring(val) end
            end))

            setVal(val)
            tins(Window.Elements,{i=row,name=p.Text})
            return { Set=setVal, Get=function() return val end }
        end

        -- Dropdown (single or multi-select)
        function tab:AddDropdown(p)
            local isMulti = p.Multi or false
            local items   = p.Items or {}
            local state   = isMulti and (p.Default or {}) or (p.Default or items[1])

            local row = mk("Frame",{Parent=page,ZIndex=7,Size=UD2(1,0,0,48),BackgroundColor3=Theme.Panel})
            corner(row,6); stroke(row,Theme.Border)
            addTooltip(row,p.Tip)

            mk("TextLabel",{Parent=row,ZIndex=8,Position=UD2(0,10,0,2),Size=UD2(1,-10,0,18),BackgroundTransparency=1,Text=p.Text,Font=Enum.Font.GothamMedium,TextSize=13,TextColor3=Theme.Text,TextXAlignment=Enum.TextXAlignment.Left})

            local btn = mk("TextButton",{Parent=row,ZIndex=8,Position=UD2(0,10,0,24),Size=UD2(1,-20,0,20),BackgroundColor3=Theme.Dark,Text="",AutoButtonColor=false})
            corner(btn,5); stroke(btn,Theme.Border)
            hoverFX(btn,Theme.Dark,Theme.Hover)

            local valTxt = mk("TextLabel",{Parent=btn,ZIndex=9,Position=UD2(0,8,0,0),Size=UD2(1,-28,1,0),BackgroundTransparency=1,Font=Enum.Font.Gotham,TextSize=12,TextColor3=Theme.SubText,TextXAlignment=Enum.TextXAlignment.Left,TextTruncate=Enum.TextTruncate.AtEnd})
            mk("TextLabel",{Parent=btn,ZIndex=9,Position=UD2(1,-18,0,0),Size=UD2(0,14,1,0),BackgroundTransparency=1,Text="▾",Font=Enum.Font.GothamBold,TextSize=12,TextColor3=Theme.SubText})

            local menuOpen=false; local menuFrame=nil

            local function closeMenu()
                if menuFrame then kill(menuFrame); menuFrame=nil; menuOpen=false end
            end

            local function updateDisplay()
                if isMulti then
                    local s={}; for k,v in pairs(state) do if v then s[#s+1]=k end end
                    valTxt.Text = #s>0 and table.concat(s,", ") or "None"
                else
                    valTxt.Text = tostring(state or "None")
                end
            end

            hook(btn.MouseButton1Click:Connect(function()
                if menuOpen then closeMenu(); return end
                menuOpen=true
                local itemH=24; local maxH=180
                menuFrame=mk("ScrollingFrame",{
                    Parent=sg, ZIndex=60,
                    Position=UD2(0,btn.AbsolutePosition.X, 0, btn.AbsolutePosition.Y+btn.AbsoluteSize.Y+2),
                    Size=UD2(0,btn.AbsoluteSize.X, 0, mn(#items*itemH+2,maxH)),
                    BackgroundColor3=Theme.Dark,
                    ScrollBarThickness=2, ScrollBarImageColor3=Accent,
                    BorderSizePixel=0, CanvasSize=UD2(0,0,0,0),
                })
                corner(menuFrame,6); stroke(menuFrame,Theme.Border)

                local ml=mk("UIListLayout",{Parent=menuFrame,SortOrder=Enum.SortOrder.LayoutOrder})
                hook(ml:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
                    menuFrame.CanvasSize=UD2(0,0,0,ml.AbsoluteContentSize.Y)
                end))

                for _,it in ipairs(items) do
                    local sel = isMulti and state[it] or (state==it)
                    local itBtn=mk("TextButton",{Parent=menuFrame,ZIndex=61,Size=UD2(1,0,0,itemH),BackgroundTransparency=1,Text="  "..it,Font=Enum.Font.Gotham,TextSize=12,TextColor3=sel and Accent or Theme.Text,TextXAlignment=Enum.TextXAlignment.Left,AutoButtonColor=false})
                    hoverFX(itBtn,Color3.new(0,0,0),Theme.Hover)  -- uses transparency approach via hover; fine

                    hook(itBtn.MouseButton1Click:Connect(function()
                        if isMulti then
                            state[it]=not state[it]
                            itBtn.TextColor3 = state[it] and Accent or Theme.Text
                        else
                            state=it; closeMenu()
                        end
                        updateDisplay()
                        if p.Callback then pcall(p.Callback,state) end
                    end))
                end
            end))

            -- Close on outside click
            hook(UIS.InputBegan:Connect(function(i)
                if not menuOpen or i.UserInputType~=Enum.UserInputType.MouseButton1 then return end
                local mp=i.Position
                local function inBounds(f)
                    local fp=f.AbsolutePosition; local fs=f.AbsoluteSize
                    return mp.X>=fp.X and mp.X<=fp.X+fs.X and mp.Y>=fp.Y and mp.Y<=fp.Y+fs.Y
                end
                if menuFrame and not inBounds(menuFrame) and not inBounds(btn) then closeMenu() end
            end))

            updateDisplay()
            if p.Callback then pcall(p.Callback,state) end
            tins(Window.Elements,{i=row,name=p.Text})

            return {
                Set     = function(v) state=v; updateDisplay(); if p.Callback then pcall(p.Callback,state) end end,
                Refresh = function(ni) items=ni; closeMenu() end,
                Get     = function() return state end,
            }
        end

        -- Color Picker (HSV square + hue bar)
        function tab:AddColorPicker(p)
            local col = p.Default or WHITE
            local h,s,v = rgbToHsv(col.R,col.G,col.B)

            local row = mk("Frame",{Parent=page,ZIndex=7,Size=UD2(1,0,0,30),BackgroundColor3=Theme.Panel})
            corner(row,6); stroke(row,Theme.Border)
            addTooltip(row,p.Tip)

            mk("TextLabel",{Parent=row,ZIndex=8,Position=UD2(0,10,0,0),Size=UD2(1,-52,1,0),BackgroundTransparency=1,Text=p.Text,Font=Enum.Font.GothamMedium,TextSize=13,TextColor3=Theme.Text,TextXAlignment=Enum.TextXAlignment.Left})

            local swatch=mk("TextButton",{Parent=row,ZIndex=8,Position=UD2(1,-42,0.5,-11),Size=UD2(0,36,0,22),BackgroundColor3=col,Text="",AutoButtonColor=false})
            corner(swatch,5); stroke(swatch,Theme.Border)

            local picker=nil; local pickerOpen=false

            local function closePicker() if picker then kill(picker); picker=nil; pickerOpen=false end end

            local function applyColor()
                local r,g,b=hsvToRgb(h,s,v)
                col=Color3.new(r,g,b)
                swatch.BackgroundColor3=col
                if p.Callback then pcall(p.Callback,col) end
            end

            hook(swatch.MouseButton1Click:Connect(function()
                if pickerOpen then closePicker(); return end
                pickerOpen=true

                picker=mk("Frame",{
                    Parent=sg, ZIndex=70,
                    Size=UD2(0,220,0,190),
                    Position=UD2(0, swatch.AbsolutePosition.X-180, 0, swatch.AbsolutePosition.Y+30),
                    BackgroundColor3=Theme.Dark,
                })
                corner(picker,8); stroke(picker,Theme.Border)
                mk("UIPadding",{Parent=picker,PaddingTop=UDS(0,8),PaddingLeft=UDS(0,8),PaddingRight=UDS(0,8),PaddingBottom=UDS(0,8)})

                -- SV Square (gradient overlay approach via ImageLabel gradients)
                local sqW,sqH=204,120
                local sq=mk("Frame",{Parent=picker,ZIndex=71,Size=UD2(0,sqW,0,sqH),BackgroundColor3=Color3.new(1,0,0)})
                corner(sq,5)

                -- White → transparent horizontal gradient
                local gradW=mk("ImageLabel",{Parent=sq,ZIndex=72,Size=UD2(1,0,1,0),BackgroundTransparency=1,Image="rbxassetid://4155801252"})
                -- Black → transparent vertical gradient
                local gradB=mk("ImageLabel",{Parent=sq,ZIndex=73,Size=UD2(1,0,1,0),BackgroundTransparency=1,Image="rbxassetid://4155801252",ImageColor3=BLACK,Rotation=270})

                local svCursor=mk("Frame",{Parent=sq,ZIndex=74,Size=UD2(0,12,0,12),BackgroundColor3=WHITE})
                corner(svCursor,6); stroke(svCursor,BLACK,2)

                -- Hue bar
                local hueBar=mk("ImageLabel",{Parent=picker,ZIndex=71,Position=UD2(0,0,0,sqH+8),Size=UD2(1,0,0,14),Image="rbxassetid://4155801252",BackgroundColor3=WHITE})
                corner(hueBar,4)
                local hueCursor=mk("Frame",{Parent=hueBar,ZIndex=72,Size=UD2(0,8,1,0),BackgroundColor3=WHITE})
                corner(hueCursor,3); stroke(hueCursor,BLACK,1)

                -- RGB display
                local rgbLabel=mk("TextLabel",{Parent=picker,ZIndex=71,Position=UD2(0,0,0,sqH+28),Size=UD2(1,0,0,16),BackgroundTransparency=1,Font=Enum.Font.GothamMedium,TextSize=11,TextColor3=Theme.SubText,TextXAlignment=Enum.TextXAlignment.Left})

                local function refreshCursors()
                    sq.BackgroundColor3=Color3.new(hsvToRgb(h,1,1))
                    svCursor.Position=UD2(s,-6,1-v,-6)
                    hueCursor.Position=UD2(h,-4,0,0)
                    local r2,g2,b2=hsvToRgb(h,s,v)
                    rgbLabel.Text=fmt("R:%d G:%d B:%d",r2*255,g2*255,b2*255)
                    applyColor()
                end

                local svDrag=false; local hueDrag=false

                local sqBtn=mk("TextButton",{Parent=sq,ZIndex=75,Size=UD2(1,0,1,0),BackgroundTransparency=1,Text=""})
                local hueBtn=mk("TextButton",{Parent=hueBar,ZIndex=73,Size=UD2(1,0,1,0),BackgroundTransparency=1,Text=""})

                hook(sqBtn.InputBegan:Connect(function(i)
                    if i.UserInputType==Enum.UserInputType.MouseButton1 then svDrag=true end
                end))
                hook(hueBtn.InputBegan:Connect(function(i)
                    if i.UserInputType==Enum.UserInputType.MouseButton1 then hueDrag=true end
                end))
                hook(UIS.InputChanged:Connect(function(i)
                    if i.UserInputType~=Enum.UserInputType.MouseMovement then return end
                    if svDrag then
                        s=clamp((i.Position.X-sq.AbsolutePosition.X)/sq.AbsoluteSize.X,0,1)
                        v=1-clamp((i.Position.Y-sq.AbsolutePosition.Y)/sq.AbsoluteSize.Y,0,1)
                        refreshCursors()
                    elseif hueDrag then
                        h=clamp((i.Position.X-hueBar.AbsolutePosition.X)/hueBar.AbsoluteSize.X,0,1)
                        refreshCursors()
                    end
                end))
                hook(UIS.InputEnded:Connect(function(i)
                    if i.UserInputType==Enum.UserInputType.MouseButton1 then svDrag=false; hueDrag=false end
                end))

                -- Close on outside click
                hook(UIS.InputBegan:Connect(function(i)
                    if not pickerOpen or i.UserInputType~=Enum.UserInputType.MouseButton1 then return end
                    local mp=i.Position; local fp=picker.AbsolutePosition; local fs=picker.AbsoluteSize
                    local sp=swatch.AbsolutePosition; local ss=swatch.AbsoluteSize
                    local inPicker= mp.X>=fp.X and mp.X<=fp.X+fs.X and mp.Y>=fp.Y and mp.Y<=fp.Y+fs.Y
                    local inSwatch= mp.X>=sp.X and mp.X<=sp.X+ss.X and mp.Y>=sp.Y and mp.Y<=sp.Y+ss.Y
                    if not inPicker and not inSwatch then closePicker() end
                end))

                refreshCursors()
            end))

            tins(Window.Elements,{i=row,name=p.Text})
            return {
                Set=function(c)
                    col=c; h,s,v=rgbToHsv(c.R,c.G,c.B)
                    swatch.BackgroundColor3=col
                    if p.Callback then pcall(p.Callback,col) end
                end,
                Get=function() return col end,
            }
        end

        -- Keybind
        function tab:AddKeybind(p)
            local key=p.Default or "None"
            local row=mk("Frame",{Parent=page,ZIndex=7,Size=UD2(1,0,0,30),BackgroundColor3=Theme.Panel})
            corner(row,6); stroke(row,Theme.Border)
            addTooltip(row,p.Tip)

            mk("TextLabel",{Parent=row,ZIndex=8,Position=UD2(0,10,0,0),Size=UD2(0.5,0,1,0),BackgroundTransparency=1,Text=p.Text,Font=Enum.Font.GothamMedium,TextSize=13,TextColor3=Theme.Text,TextXAlignment=Enum.TextXAlignment.Left})

            local kbBtn=mk("TextButton",{Parent=row,ZIndex=8,Position=UD2(1,-90,0.5,-11),Size=UD2(0,84,0,22),BackgroundColor3=Theme.Dark,Text="["..key.."]",Font=Enum.Font.GothamMedium,TextSize=12,TextColor3=Theme.SubText,AutoButtonColor=false})
            corner(kbBtn,5); stroke(kbBtn,Theme.Border)
            hoverFX(kbBtn,Theme.Dark,Theme.Hover)

            if key~="None" then Window.Keybinds[p.Text]=key end

            local binding=false
            hook(kbBtn.MouseButton1Click:Connect(function()
                if binding then return end
                binding=true; kbBtn.Text="[ ... ]"; kbBtn.TextColor3=Accent
                local conn; conn=UIS.InputBegan:Connect(function(i)
                    if i.UserInputType~=Enum.UserInputType.Keyboard and not i.UserInputType.Name:find("MouseButton") then return end
                    local kn=i.KeyCode.Name; local mt=i.UserInputType.Name
                    local res=(kn=="Unknown" and mt) or kn
                    if res=="Escape" or res=="Backspace" then
                        key="None"; Window.Keybinds[p.Text]=nil
                    else
                        key=res; Window.Keybinds[p.Text]=key
                    end
                    kbBtn.Text="["..key.."]"; kbBtn.TextColor3=Theme.SubText
                    binding=false
                    if p.Callback then pcall(p.Callback,key) end
                    conn:Disconnect()
                end)
            end))

            tins(Window.Elements,{i=row,name=p.Text})
            return { Get=function() return key end }
        end

