    local tweenEngine = self._window._tweenEngine

    local configKey = self._name .. "_" .. config.Text .. "_toggle"
    local savedValue = self._window:_LoadValue(configKey)
    local state: boolean = if savedValue ~= nil then savedValue else (config.Default or false)

    local row: Frame = mk("Frame", {
        Parent = self._page,
        Size = UDim2.new(1, 0, 0, 24),
        BackgroundTransparency = 1,
    }) :: Frame

    local box: TextButton = mk("TextButton", {
        Parent = row,
        Size = UDim2.new(0, 16, 0, 16),
        Position = UDim2.new(0, 0, 0.5, -8),
        BackgroundColor3 = theme.PanelDark,
        BorderColor3 = theme.Border,
        Text = "",
        AutoButtonColor = false,
    }) :: TextButton

    local fill: Frame = mk("Frame", {
        Parent = box,
        Size = UDim2.new(1, -4, 1, -4),
        Position = UDim2.new(0, 2, 0, 2),
        BackgroundColor3 = config.Risky and theme.Risky or accent,
        BorderSizePixel = 0,
        Visible = state,
    }) :: Frame

    local lbl: TextLabel = mk("TextLabel", {
