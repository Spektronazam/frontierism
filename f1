    local function update(silent: boolean?)
        fill.Visible = state
        if config.Callback and not silent then
            pcall(config.Callback, state)
        end
        self._window:_SaveValue(configKey, state)
    end

    Connection.new(box.MouseButton1Click:Connect(function()
        state = not state
        update()
    end))

    update(true)

    local api = {
        Set = function(value: boolean, silent: boolean?)
            state = value
            update(silent)
        end,
        Get = function(): boolean
            return state
        end,
        Destroy = function()
            row:Destroy()
        end,
    }

    self._window:_RegisterElement(row, config.Text, api)
    return api
end

function Tab:AddSlider(config: SliderConfig): {
    Set: (number, boolean?) -> (),
    Get: () -> number,
    Destroy: () -> (),
}
    local theme = self._window._theme
    local accent = self._window._accent

    local configKey = self._name .. "_" .. config.Text .. "_slider"
    local savedValue = self._window:_LoadValue(configKey)
    local val: number = if savedValue ~= nil then savedValue else (config.Default or config.Min)
    local min: number = config.Min
    local max: number = config.Max
    local dec: number = config.Decimals or 0

    local row: Frame = mk("Frame", {
        Parent = self._page,
        Size = UDim2.new(1, 0, 0, config.Compact and 24 or 36),
        BackgroundTransparency = 1,
    }) :: Frame

    local lbl: TextLabel = mk("TextLabel", {
        Parent = row,
        Position = UDim2.new(0, 0, 0, 0),
        Size = UDim2.new(config.Compact and 0.3 or 0.5, 0, 0, 16),
        BackgroundTransparency = 1,
        Text = config.Text,
        Font = Enum.Font.Ubuntu,
        TextSize = 13,
        TextColor3 = theme.Text,
        TextXAlignment = Enum.TextXAlignment.Left,
    }) :: TextLabel

    local valBox: TextBox = mk("TextBox", {
        Parent = row,
        Position = UDim2.new(1, -50, 0, 0),
        Size = UDim2.new(0, 50, 0, 16),
        BackgroundTransparency = 1,
        Text = "",
        Font = Enum.Font.Ubuntu,
        TextSize = 13,
        TextColor3 = accent,
        TextXAlignment = Enum.TextXAlignment.Right,
    }) :: TextBox

    addTooltip(row, config.Tip, self._window._tooltipFrame, self._window._tooltipText)

    local track: TextButton = mk("TextButton", {
        Parent = row,
        Position = UDim2.new(0, 0, 0, config.Compact and 14 or 22),
        Size = UDim2.new(1, 0, 0, 8),
        BackgroundColor3 = theme.PanelDark,
        BorderColor3 = theme.Border,
        Text = "",
        AutoButtonColor = false,
    }) :: TextButton

    local fill: Frame = mk("Frame", {
        Parent = track,
        Size = UDim2.new(0, 0, 1, 0),
        BackgroundColor3 = accent,
        BorderSizePixel = 0,
    }) :: Frame

    local dragging = false

    local function setValue(v: number, silent: boolean?)
        val = math.clamp(v, min, max)
        local mult = 10 ^ dec
        val = math.floor(val * mult + 0.5) / mult
        valBox.Text = tostring(val) .. (config.Suffix or "")
        fill.Size = UDim2.new((max == min) and 0 or (val - min) / (max - min), 0, 1, 0)
        if config.Callback and not silent then
            pcall(config.Callback, val)
        end
        self._window:_SaveValue(configKey, val)
    end

    local function updateDrag(input: InputObject)
        local pct = math.clamp((input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
        setValue(min + (max - min) * pct)
    end

    Connection.new(track.InputBegan:Connect(function(input: InputObject)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            updateDrag(input)
        end
    end))
    Connection.new(UserInputService.InputChanged:Connect(function(input: InputObject)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            updateDrag(input)
        end
    end))
    Connection.new(UserInputService.InputEnded:Connect(function(input: InputObject)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end))
    Connection.new(valBox.FocusLost:Connect(function()
        local num = tonumber(string.gsub(valBox.Text, "[^%d%.%-]", ""))
        if num then
            setValue(num)
        else
            setValue(val, true)
        end
    end))

    setValue(val, true)

    local api = {
        Set = function(value: number, silent: boolean?)
            setValue(value, silent)
        end,
        Get = function(): number
            return val
        end,
        Destroy = function()
            row:Destroy()
        end,
    }

    self._window:_RegisterElement(row, config.Text, api)
    return api
end

function Tab:AddDropdown(config: DropdownConfig): {
    Set: (string, boolean?) -> (),
    Get: () -> string,
    Refresh: ({ string }, boolean?) -> (),
    Destroy: () -> (),
}
    local theme = self._window._theme
    local accent = self._window._accent

    local configKey = self._name .. "_" .. config.Text .. "_dropdown"
    local savedValue = self._window:_LoadValue(configKey)
    local state: string = if savedValue ~= nil then savedValue else (config.Default or config.Items[1] or "")

    local row: Frame = mk("Frame", {
        Parent = self._page,
        Size = UDim2.new(1, 0, 0, 44),
        BackgroundTransparency = 1,
    }) :: Frame

    local lbl: TextLabel = mk("TextLabel", {
        Parent = row,
        Position = UDim2.new(0, 0, 0, 0),
        Size = UDim2.new(1, 0, 0, 16),
        BackgroundTransparency = 1,
        Text = config.Text,
        Font = Enum.Font.Ubuntu,
        TextSize = 13,
        TextColor3 = theme.Text,
        TextXAlignment = Enum.TextXAlignment.Left,
    }) :: TextLabel

    addTooltip(row, config.Tip, self._window._tooltipFrame, self._window._tooltipText)

    local btn: TextButton = mk("TextButton", {
        Parent = row,
        Position = UDim2.new(0, 0, 0, 20),
        Size = UDim2.new(1, 0, 0, 24),
        BackgroundColor3 = theme.PanelDark,
        BorderColor3 = theme.Border,
        Text = "",
        AutoButtonColor = false,
    }) :: TextButton

    addHover(btn, self._window._tweenEngine, theme.PanelDark, theme.Hover)

    local valTxt: TextLabel = mk("TextLabel", {
        Parent = btn,
        Position = UDim2.new(0, 6, 0, 0),
        Size = UDim2.new(1, -24, 1, 0),
        BackgroundTransparency = 1,
        Text = state,
        Font = Enum.Font.Ubuntu,
        TextSize = 12,
        TextColor3 = theme.SubText,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextTruncate = Enum.TextTruncate.AtEnd,
    }) :: TextLabel

    mk("TextLabel", {
        Parent = btn,
        Position = UDim2.new(1, -16, 0, 0),
        Size = UDim2.new(0, 12, 1, 0),
        BackgroundTransparency = 1,
        Text = "▼",
        Font = Enum.Font.Ubuntu,
        TextSize = 10,
        TextColor3 = theme.SubText,
    })

    local menuOpen = false
    local menuFrame: ScrollingFrame? = nil

    local function closeMenu()
        if menuFrame then
            pcall(function() menuFrame:Destroy() end)
            menuFrame = nil
        end
        menuOpen = false
    end

    local function updateDisplay()
        valTxt.Text = state
    end

    local function openMenu()
        if menuOpen then closeMenu() return end
        menuOpen = true

        menuFrame = mk("ScrollingFrame", {
            Parent = self._window._screenGui,
            Size = UDim2.new(0, btn.AbsoluteSize.X, 0, math.min(#config.Items * 24 + 2, 150)),
            Position = UDim2.new(0, btn.AbsolutePosition.X, 0, btn.AbsolutePosition.Y + btn.AbsoluteSize.Y + 1),
            BackgroundColor3 = theme.PanelDark,
            BorderColor3 = theme.Border,
            ZIndex = 50,
            ScrollBarThickness = 2,
            ScrollBarImageColor3 = accent,
        }) :: ScrollingFrame

        local ml: UIListLayout = mk("UIListLayout", {
            Parent = menuFrame,
            SortOrder = Enum.SortOrder.LayoutOrder,
        }) :: UIListLayout

        Connection.new(ml:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
            menuFrame.CanvasSize = UDim2.new(0, 0, 0, ml.AbsoluteContentSize.Y)
        end))

        for _, item in ipairs(config.Items) do
            local itBtn: TextButton = mk("TextButton", {
                Parent = menuFrame,
                Size = UDim2.new(1, 0, 0, 24),
                BackgroundTransparency = 1,
                Text = "  " .. item,
                Font = Enum.Font.Ubuntu,
                TextSize = 12,
                TextColor3 = state == item and accent or theme.Text,
                TextXAlignment = Enum.TextXAlignment.Left,
                AutoButtonColor = false,
            }) :: TextButton

            addHover(itBtn, self._window._tweenEngine, theme.PanelDark, theme.Hover)

            Connection.new(itBtn.MouseButton1Click:Connect(function()
                state = item
                updateDisplay()
                closeMenu()
                if config.Callback then
                    pcall(config.Callback, state)
                end
                self._window:_SaveValue(configKey, state)
            end))
        end
    end

    Connection.new(btn.MouseButton1Click:Connect(openMenu))
    Connection.new(UserInputService.InputBegan:Connect(function(input: InputObject)
        if menuOpen and input.UserInputType == Enum.UserInputType.MouseButton1 then
            local mp = input.Position
            local mf = menuFrame :: Frame
            local bp, bs = btn.AbsolutePosition, btn.AbsoluteSize
            local inMenu = mp.X >= mf.AbsolutePosition.X and mp.X <= mf.AbsolutePosition.X + mf.AbsoluteSize.X
                and mp.Y >= mf.AbsolutePosition.Y and mp.Y <= mf.AbsolutePosition.Y + mf.AbsoluteSize.Y
            local inBtn = mp.X >= bp.X and mp.X <= bp.X + bs.X and mp.Y >= bp.Y and mp.Y <= bp.Y + bs.Y
            if not inMenu and not inBtn then
                closeMenu()
            end
        end
    end))

    if config.Callback then
        pcall(config.Callback, state)
    end

    local api = {
        Set = function(value: string, silent: boolean?)
            state = value
            updateDisplay()
            if config.Callback and not silent then
                pcall(config.Callback, state)
            end
            self._window:_SaveValue(configKey, state)
        end,
        Get = function(): string
            return state
        end,
        Refresh = function(items: { string }, keepSelection: boolean?)
            config.Items = items
            if not keepSelection or table.find(items, state) == nil then
                state = items[1] or ""
                updateDisplay()
                if config.Callback then
                    pcall(config.Callback, state)
                end
            end
            closeMenu()
        end,
        Destroy = function()
            closeMenu()
            row:Destroy()
        end,
    }

    self._window:_RegisterElement(row, config.Text, api)
    return api
end

function Tab:AddMultiDropdown(config: MultiDropdownConfig): {
    Set: ({ string }, boolean?) -> (),
    Get: () -> { [string]: boolean },
    Refresh: ({ string }) -> (),
    Destroy: () -> (),
}
    local theme = self._window._theme
    local accent = self._window._accent

    local configKey = self._name .. "_" .. config.Text .. "_multidrop"
    local savedValue = self._window:_LoadValue(configKey)
    local state: { [string]: boolean } = if savedValue ~= nil then savedValue else {}
    if config.Default then
        for _, v in ipairs(config.Default) do
            state[v] = true
        end
    end

    local row: Frame = mk("Frame", {
        Parent = self._page,
        Size = UDim2.new(1, 0, 0, 44),
        BackgroundTransparency = 1,
    }) :: Frame

    local lbl: TextLabel = mk("TextLabel", {
        Parent = row,
        Position = UDim2.new(0, 0, 0, 0),
        Size = UDim2.new(1, 0, 0, 16),
        BackgroundTransparency = 1,
        Text = config.Text,
        Font = Enum.Font.Ubuntu,
        TextSize = 13,
        TextColor3 = theme.Text,
        TextXAlignment = Enum.TextXAlignment.Left,
    }) :: TextLabel

    addTooltip(row, config.Tip, self._window._tooltipFrame, self._window._tooltipText)

    local btn: TextButton = mk("TextButton", {
        Parent = row,
        Position = UDim2.new(0, 0, 0, 20),
        Size = UDim2.new(1, 0, 0, 24),
        BackgroundColor3 = theme.PanelDark,
        BorderColor3 = theme.Border,
        Text = "",
        AutoButtonColor = false,
    }) :: TextButton

    addHover(btn, self._window._tweenEngine, theme.PanelDark, theme.Hover)

    local valTxt: TextLabel = mk("TextLabel", {
        Parent = btn,
        Position = UDim2.new(0, 6, 0, 0),
        Size = UDim2.new(1, -24, 1, 0),
        BackgroundTransparency = 1,
        Text = "",
        Font = Enum.Font.Ubuntu,
        TextSize = 12,
        TextColor3 = theme.SubText,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextTruncate = Enum.TextTruncate.AtEnd,
    }) :: TextLabel

    mk("TextLabel", {
        Parent = btn,
        Position = UDim2.new(1, -16, 0, 0),
        Size = UDim2.new(0, 12, 1, 0),
        BackgroundTransparency = 1,
        Text = "▼",
        Font = Enum.Font.Ubuntu,
        TextSize = 10,
        TextColor3 = theme.SubText,
    })

    local menuOpen = false
    local menuFrame: ScrollingFrame? = nil

    local function closeMenu()
        if menuFrame then
            pcall(function() menuFrame:Destroy() end)
            menuFrame = nil
        end
        menuOpen = false
    end

    local function updateDisplay()
        local selected: { string } = {}
        for k, v in pairs(state) do
            if v then table.insert(selected, k) end
        end
        valTxt.Text = #selected > 0 and table.concat(selected, ", ") or "None"
    end

    local function openMenu()
        if menuOpen then closeMenu() return end
        menuOpen = true

        menuFrame = mk("ScrollingFrame", {
            Parent = self._window._screenGui,
            Size = UDim2.new(0, btn.AbsoluteSize.X, 0, math.min(#config.Items * 24 + 2, 150)),
            Position = UDim2.new(0, btn.AbsolutePosition.X, 0, btn.AbsolutePosition.Y + btn.AbsoluteSize.Y + 1),
            BackgroundColor3 = theme.PanelDark,
            BorderColor3 = theme.Border,
            ZIndex = 50,
            ScrollBarThickness = 2,
            ScrollBarImageColor3 = accent,
        }) :: ScrollingFrame

        local ml: UIListLayout = mk("UIListLayout", {
            Parent = menuFrame,
            SortOrder = Enum.SortOrder.LayoutOrder,
        }) :: UIListLayout

        Connection.new(ml:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
            menuFrame.CanvasSize = UDim2.new(0, 0, 0, ml.AbsoluteContentSize.Y)
        end))

        for _, item in ipairs(config.Items) do
            local itBtn: TextButton = mk("TextButton", {
                Parent = menuFrame,
                Size = UDim2.new(1, 0, 0, 24),
                BackgroundTransparency = 1,
                Text = (state[item] and "✓ " or "   ") .. item,
                Font = Enum.Font.Ubuntu,
                TextSize = 12,
                TextColor3 = state[item] and accent or theme.Text,
                TextXAlignment = Enum.TextXAlignment.Left,
                AutoButtonColor = false,
            }) :: TextButton

            addHover(itBtn, self._window._tweenEngine, theme.PanelDark, theme.Hover)

            Connection.new(itBtn.MouseButton1Click:Connect(function()
                state[item] = not state[item]
                itBtn.Text = (state[item] and "✓ " or "   ") .. item
                itBtn.TextColor3 = state[item] and accent or theme.Text
                updateDisplay()
                if config.Callback then
                    pcall(config.Callback, state)
                end
                self._window:_SaveValue(configKey, state)
            end))
        end
    end

    Connection.new(btn.MouseButton1Click:Connect(openMenu))
    Connection.new(UserInputService.InputBegan:Connect(function(input: InputObject)
        if menuOpen and input.UserInputType == Enum.UserInputType.MouseButton1 then
            local mp = input.Position
            local mf = menuFrame :: Frame
            local bp, bs = btn.AbsolutePosition, btn.AbsoluteSize
            local inMenu = mp.X >= mf.AbsolutePosition.X and mp.X <= mf.AbsolutePosition.X + mf.AbsoluteSize.X
                and mp.Y >= mf.AbsolutePosition.Y and mp.Y <= mf.AbsolutePosition.Y + mf.AbsoluteSize.Y
            local inBtn = mp.X >= bp.X and mp.X <= bp.X + bs.X and mp.Y >= bp.Y and mp.Y <= bp.Y + bs.Y
            if not inMenu and not inBtn then
                closeMenu()
            end
        end
    end))

    updateDisplay()
    if config.Callback then
        pcall(config.Callback, state)
    end

    local api = {
        Set = function(values: { string }, silent: boolean?)
            table.clear(state)
            for _, v in ipairs(values) do
                state[v] = true
            end
            updateDisplay()
            if config.Callback and not silent then
                pcall(config.Callback, state)
            end
            self._window:_SaveValue(configKey, state)
        end,
        Get = function(): { [string]: boolean }
            return state
        end,
        Refresh = function(items: { string })
            config.Items = items
            local newState: { [string]: boolean } = {}
            for k, v in pairs(state) do
                if table.find(items, k) then
                    newState[k] = v
                end
            end
            state = newState
            updateDisplay()
            closeMenu()
        end,
        Destroy = function()
            closeMenu()
            row:Destroy()
        end,
    }

    self._window:_RegisterElement(row, config.Text, api)
    return api
end

function Tab:AddColorPicker(config: ColorPickerConfig): {
    Set: (Color3, boolean?) -> (),
    Get: () -> Color3,
    Destroy: () -> (),
}
    local theme = self._window._theme
    local accent = self._window._accent

    local configKey = self._name .. "_" .. config.Text .. "_color"
    local savedValue = self._window:_LoadValue(configKey)
    local col: Color3 = if savedValue and typeof(savedValue) == "table"
        then Color3.fromRGB(savedValue.R, savedValue.G, savedValue.B)
        else (config.Default or Color3.fromRGB(255, 255, 255))

    local row: Frame = mk("Frame", {
        Parent = self._page,
        Size = UDim2.new(1, 0, 0, 24),
        BackgroundTransparency = 1,
    }) :: Frame

    local lbl: TextLabel = mk("TextLabel", {
        Parent = row,
        Position = UDim2.new(0, 0, 0, 0),
        Size = UDim2.new(0.5, 0, 1, 0),
        BackgroundTransparency = 1,
        Text = config.Text,
        Font = Enum.Font.Ubuntu,
        TextSize = 13,
        TextColor3 = theme.Text,
        TextXAlignment = Enum.TextXAlignment.Left,
    }) :: TextLabel

    addTooltip(row, config.Tip, self._window._tooltipFrame, self._window._tooltipText)

    local cBtn: TextButton = mk("TextButton", {
        Parent = row,
        Position = UDim2.new(1, -40, 0, 0),
        Size = UDim2.new(0, 40, 1, 0),
        BackgroundColor3 = col,
        BorderColor3 = theme.Border,
        Text = "",
        AutoButtonColor = false,
    }) :: TextButton

    local menuOpen = false
    local mFrame: Frame? = nil

    local function closeMenu()
        if mFrame then
            pcall(function() mFrame:Destroy() end)
            mFrame = nil
        end
        menuOpen = false
    end

    local function update(c: Color3, silent: boolean?)
        col = c
        cBtn.BackgroundColor3 = col
        if config.Callback and not silent then
            pcall(config.Callback, col)
        end
        self._window:_SaveValue(configKey, { R = math.floor(col.R * 255), G = math.floor(col.G * 255), B = math.floor(col.B * 255) })
    end

    Connection.new(cBtn.MouseButton1Click:Connect(function()
        if menuOpen then closeMenu() return end
        menuOpen = true

        mFrame = mk("Frame", {
            Parent = self._window._screenGui,
            Size = UDim2.new(0, 160, 0, 110),
            Position = UDim2.new(0, cBtn.AbsolutePosition.X - 120, 0, cBtn.AbsolutePosition.Y + 28),
            BackgroundColor3 = theme.PanelDark,
            BorderColor3 = theme.Border,
            ZIndex = 50,
        }) :: Frame

        local function mkInp(x: number, cv: number, label: string): TextBox
            mk("TextLabel", {
                Parent = mFrame,
                Position = UDim2.new(0, x, 0, 4),
                Size = UDim2.new(0, 36, 0, 14),
                BackgroundTransparency = 1,
                Text = label,
                Font = Enum.Font.Ubuntu,
                TextSize = 10,
                TextColor3 = theme.SubText,
            })
            return mk("TextBox", {
                Parent = mFrame,
                Position = UDim2.new(0, x, 0, 18),
                Size = UDim2.new(0, 36, 0, 22),
                BackgroundColor3 = theme.Bg,
                BorderColor3 = theme.Border,
                Text = tostring(math.floor(cv * 255)),
                Font = Enum.Font.Ubuntu,
                TextSize = 12,
                TextColor3 = theme.Text,
            }) :: TextBox
        end

        local rBox = mkInp(10, col.R, "R")
        local gBox = mkInp(56, col.G, "G")
        local bBox = mkInp(102, col.B, "B")

        local function onTxt()
            local r = math.clamp(tonumber(rBox.Text) or 255, 0, 255)
            local g = math.clamp(tonumber(gBox.Text) or 255, 0, 255)
            local b = math.clamp(tonumber(bBox.Text) or 255, 0, 255)
            update(Color3.fromRGB(r, g, b))
        end

        Connection.new(rBox.FocusLost:Connect(onTxt))
        Connection.new(gBox.FocusLost:Connect(onTxt))
        Connection.new(bBox.FocusLost:Connect(onTxt))

        local presets = {
            Color3.fromRGB(255, 0, 0), Color3.fromRGB(0, 255, 0), Color3.fromRGB(0, 0, 255),
            Color3.fromRGB(255, 255, 0), Color3.fromRGB(0, 255, 255), Color3.fromRGB(255, 0, 255),
            Color3.fromRGB(255, 255, 255), Color3.fromRGB(0, 0, 0),
        }
        for i, preset in ipairs(presets) do
            local pBtn: TextButton = mk("TextButton", {
                Parent = mFrame,
                Position = UDim2.new(0, 10 + ((i - 1) % 4) * 36, 0, 50 + math.floor((i - 1) / 4) * 26),
                Size = UDim2.new(0, 28, 0, 20),
                BackgroundColor3 = preset,
                BorderColor3 = theme.Border,
                Text = "",
            }) :: TextButton
            Connection.new(pBtn.MouseButton1Click:Connect(function()
                update(preset)
                rBox.Text = tostring(math.floor(preset.R * 255))
                gBox.Text = tostring(math.floor(preset.G * 255))
                bBox.Text = tostring(math.floor(preset.B * 255))
            end))
        end
    end))

    local api = {
        Set = function(color: Color3, silent: boolean?)
            update(color, silent)
        end,
        Get = function(): Color3
            return col
        end,
        Destroy = function()
            closeMenu()
            row:Destroy()
        end,
    }

    self._window:_RegisterElement(row, config.Text, api)
    return api
end

function Tab:AddKeybind(config: KeybindConfig): {
    Set: ((Enum.KeyCode | Enum.UserInputType)?, boolean?) -> (),
    Get: () -> (Enum.KeyCode | Enum.UserInputType)?,
    Destroy: () -> (),
}
    local theme = self._window._theme
    local accent = self._window._accent

    local configKey = self._name .. "_" .. config.Text .. "_keybind"
    local savedValue = self._window:_LoadValue(configKey)
    local key: (Enum.KeyCode | Enum.UserInputType)? = if savedValue ~= nil
        then (Enum.KeyCode[savedValue :: string] or Enum.UserInputType[savedValue :: string])
        else config.Default
    local mode: KeybindMode = config.Mode or "Press"

    local row: Frame = mk("Frame", {
        Parent = self._page,
        Size = UDim2.new(1, 0, 0, 24),
        BackgroundTransparency = 1,
    }) :: Frame

    local lbl: TextLabel = mk("TextLabel", {
        Parent = row,
        Position = UDim2.new(0, 0, 0, 0),
        Size = UDim2.new(0.5, 0, 1, 0),
        BackgroundTransparency = 1,
        Text = config.Text,
        Font = Enum.Font.Ubuntu,
        TextSize = 13,
        TextColor3 = theme.Text,
        TextXAlignment = Enum.TextXAlignment.Left,
    }) :: TextLabel

    addTooltip(row, config.Tip, self._window._tooltipFrame, self._window._tooltipText)

    local btn: TextButton = mk("TextButton", {
        Parent = row,
        Position = UDim2.new(1, -80, 0, 0),
        Size = UDim2.new(0, 80, 1, 0),
        BackgroundColor3 = theme.PanelDark,
        BorderColor3 = theme.Border,
        Text = "[" .. (key and (key :: any).Name or "None") .. "]",
        Font = Enum.Font.Ubuntu,
        TextSize = 12,
        TextColor3 = theme.SubText,
        AutoButtonColor = false,
    }) :: TextButton

    addHover(btn, self._window._tweenEngine, theme.PanelDark, theme.Hover)

    local binding = false
    local holdActive = false

    Connection.new(btn.MouseButton1Click:Connect(function()
        binding = true
        btn.Text = "[...]"
        local c: RBXScriptConnection? = nil
        c = UserInputService.InputBegan:Connect(function(input: InputObject)
            if binding then
                local isKeyboard = input.UserInputType == Enum.UserInputType.Keyboard
                local isMouse = input.UserInputType.Name:find("MouseButton") ~= nil
                if isKeyboard or isMouse then
                    local kn = input.KeyCode.Name
                    local mt = input.UserInputType.Name
                    local res = (kn == "Unknown" and mt) or kn
                    if res == "Escape" or res == "Backspace" then
                        key = nil
                    else
                        key = input.KeyCode ~= Enum.KeyCode.Unknown and input.KeyCode or input.UserInputType
                    end
                    binding = false
                    btn.Text = "[" .. (key and (key :: any).Name or "None") .. "]"
                    if key then
                        self._window._keybinds[config.Text] = (key :: any).Name
                    else
                        self._window._keybinds[config.Text] = nil
                    end
                    self._window:_SaveValue(configKey, key and (key :: any).Name or nil)
                    if config.Callback then
                        pcall(config.Callback, mode)
                    end
                    if c then c:Disconnect() end
                end
            end
        end)
    end))

    Connection.new(UserInputService.InputBegan:Connect(function(input: InputObject, gpe: boolean)
        if gpe or binding then return end
        if not key then return end
        local match = false
        if typeof(key) == "EnumItem" then
            if (key :: any).EnumType == Enum.KeyCode and input.KeyCode == key then
                match = true
            elseif (key :: any).EnumType == Enum.UserInputType and input.UserInputType == key then
                match = true
            end
        end
        if match then
            if mode == "Press" then
                if config.Callback then pcall(config.Callback, mode) end
            elseif mode == "Toggle" then
                holdActive = not holdActive
                if config.Callback then pcall(config.Callback, mode, holdActive) end
            elseif mode == "Hold" then
                holdActive = true
                if config.Callback then pcall(config.Callback, mode, true) end
            end
        end
    end))

    Connection.new(UserInputService.InputEnded:Connect(function(input: InputObject)
        if not key then return end
        local match = false
        if typeof(key) == "EnumItem" then
            if (key :: any).EnumType == Enum.KeyCode and input.KeyCode == key then
                match = true
            elseif (key :: any).EnumType == Enum.UserInputType and input.UserInputType == key then
                match = true
            end
        end
        if match and mode == "Hold" then
            holdActive = false
            if config.Callback then pcall(config.Callback, mode, false) end
        end
    end))

    if key then
        self._window._keybinds[config.Text] = (key :: any).Name
    end

    local api = {
        Set = function(input: (Enum.KeyCode | Enum.UserInputType)?, silent: boolean?)
            key = input
            btn.Text = "[" .. (key and (key :: any).Name or "None") .. "]"
            if key then
                self._window._keybinds[config.Text] = (key :: any).Name
            else
                self._window._keybinds[config.Text] = nil
            end
            self._window:_SaveValue(configKey, key and (key :: any).Name or nil)
            if config.Callback and not silent then
                pcall(config.Callback, mode)
            end
        end,
        Get = function(): (Enum.KeyCode | Enum.UserInputType)?
            return key
        end,
        Destroy = function()
            row:Destroy()
            self._window._keybinds[config.Text] = nil
        end,
    }

    self._window:_RegisterElement(row, config.Text, api)
    return api
end

function Tab:AddButton(config: ButtonConfig): {
    Fire: () -> (),
    Destroy: () -> (),
}
    local theme = self._window._theme
    local accent = self._window._accent
    local tweenEngine = self._window._tweenEngine

    local row: Frame = mk("Frame", {
        Parent = self._page,
        Size = UDim2.new(1, 0, 0, 28),
        BackgroundTransparency = 1,
    }) :: Frame

    local btn: TextButton = mk("TextButton", {
        Parent = row,
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundColor3 = config.Risky and theme.Risky or theme.PanelDark,
        BorderColor3 = theme.Border,
        Text = config.Text,
        Font = Enum.Font.Ubuntu,
        TextSize = 13,
        TextColor3 = theme.Text,
        AutoButtonColor = false,
    }) :: TextButton

    addTooltip(row, config.Tip, self._window._tooltipFrame, self._window._tooltipText)
    addHover(btn, tweenEngine, config.Risky and theme.Risky or theme.PanelDark, theme.Hover)

    Connection.new(btn.MouseButton1Click:Connect(function()
        tweenEngine:Tween(btn, { BackgroundColor3 = accent }, 0.06)
        task.delay(0.08, function()
            tweenEngine:Tween(btn, { BackgroundColor3 = config.Risky and theme.Risky or theme.Hover }, 0.1)
        end)
        if config.Callback then
            pcall(config.Callback)
        end
