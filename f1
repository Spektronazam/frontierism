function Window:AddTab(name: string): Tab
    local theme = self._theme
    local accent = self._accent

    local btn: TextButton = mk("TextButton", {
        Parent = self._tabList,
        Size = UDim2.new(1, 0, 0, 30),
        BackgroundColor3 = theme.Sidebar,
        BorderSizePixel = 0,
        Text = "  " .. name,
        Font = Enum.Font.Ubuntu,
        TextSize = 13,
        TextColor3 = theme.SubText,
        TextXAlignment = Enum.TextXAlignment.Left,
        AutoButtonColor = false,
    }) :: TextButton

    local indicator: Frame = mk("Frame", {
        Parent = btn,
        Size = UDim2.new(0, 3, 1, 0),
        BackgroundColor3 = accent,
        BorderSizePixel = 0,
        Visible = false,
    }) :: Frame

    local page: ScrollingFrame = mk("ScrollingFrame", {
        Parent = self._content,
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        Visible = false,
        ScrollBarThickness = 4,
        ScrollBarImageColor3 = accent,
        BorderSizePixel = 0,
    }) :: ScrollingFrame

    local layout: UIListLayout = mk("UIListLayout", {
        Parent = page,
        SortOrder = Enum.SortOrder.LayoutOrder,
        Padding = UDim.new(0, 6),
    }) :: UIListLayout

    mk("UIPadding", {
        Parent = page,
        PaddingTop = UDim.new(0, 10),
        PaddingLeft = UDim.new(0, 10),
        PaddingRight = UDim.new(0, 10),
        PaddingBottom = UDim.new(0, 10),
    })

    Connection.new(layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        page.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + 20)
    end))

    local tab: Tab = setmetatable({
        _name = name,
        _button = btn,
        _indicator = indicator,
        _page = page,
        _layout = layout,
        _window = self,
    }, Tab) :: any

    table.insert(self._tabs, tab)

    local function selectTab()
        if self._activeTab == tab then return end
        if self._activeTab then
            self._activeTab._page.Visible = false
            self._activeTab._button.BackgroundColor3 = theme.Sidebar
            self._activeTab._button.TextColor3 = theme.SubText
            self._activeTab._indicator.Visible = false
        end
        self._activeTab = tab
        tab._page.Visible = true
        tab._button.BackgroundColor3 = theme.PanelDark
        tab._button.TextColor3 = theme.Text
        tab._indicator.Visible = true
    end

    Connection.new(btn.MouseButton1Click:Connect(selectTab))

    if #self._tabs == 1 then
        task.defer(selectTab)
    end

    return tab
end

