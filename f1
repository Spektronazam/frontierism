-- ── HELPERS ──────────────────────────────────────────────────
local function hook(c)
    if c and typeof(c) == "RBXScriptConnection" then tins(DespairUI.Connections, c) end
    return c
end

-- Create instance with property table; silently ignores invalid props
local function mk(cn, props)
    local ok, inst = pcall(Instance.new, cn)
    if not ok then return nil end
    if props then
        for k, v in pairs(props) do pcall(function() inst[k] = v end) end
    end
    return inst
end

-- Convenience: add a UICorner
local function corner(parent, radius)
    return mk("UICorner", { Parent = parent, CornerRadius = UDS(0, radius or 6) })
end

-- Convenience: add a UIStroke
local function stroke(parent, color, thick, trans)
    return mk("UIStroke", {
        Parent       = parent,
        Color        = color or Theme.Border,
        Thickness    = thick or 1,
        Transparency = trans or 0,
    })
end

-- Tween with cancellation
local TwCache = {}
local function Tw(inst, props, dur, style, dir)
    if not inst then return end
    dur   = dur   or 0.18
    style = style or Enum.EasingStyle.Quart
    dir   = dir   or Enum.EasingDirection.Out
    local old = TwCache[inst]
    if old then pcall(old.Cancel, old) end
    local ok, t = pcall(function()
        return TS:Create(inst, TweenInfo.new(dur, style, dir), props)
    end)
    if not ok or not t then return end
    TwCache[inst] = t
    t:Play()
    t.Completed:Once(function() if TwCache[inst] == t then TwCache[inst] = nil end end)
    return t
end

-- Smooth spring-like damping (frame-rate independent)
local function damp(cur, goal, speed, dt)
    return cur + (goal - cur) * clamp(1 - exp(-speed * dt * 12), 0, 1)
end

-- Destroy a GUI instance safely
local function kill(inst)
    if inst and inst.Parent then pcall(inst.Destroy, inst) end
end

-- HSV ↔ RGB helpers
local function hsvToRgb(h, s, v)
    if s == 0 then return v, v, v end
    h = h % 1; local i = floor(h * 6)
    local f = h * 6 - i
    local p, q, t = v*(1-s), v*(1-f*s), v*(1-(1-f)*s)
    local r,g,b
    i = i % 6
    if     i==0 then r,g,b=v,t,p
    elseif i==1 then r,g,b=q,v,p
    elseif i==2 then r,g,b=p,v,t
    elseif i==3 then r,g,b=p,q,v
    elseif i==4 then r,g,b=t,p,v
    else             r,g,b=v,p,q end
    return r, g, b
end

local function rgbToHsv(r, g, b)
    local mx2, mn2 = mx(r,g,b), mn(r,g,b)
    local v = mx2; local d = mx2 - mn2
    local s = mx2 == 0 and 0 or d / mx2
    if d == 0 then return 0, s, v end
    local h
    if mx2 == r then h = (g-b)/d + (g < b and 6 or 0)
    elseif mx2 == g then h = (b-r)/d + 2
    else h = (r-g)/d + 4 end
    return h/6, s, v
end

-- ── DRAWING CAPABILITY CHECK ──────────────────────────────────
local HasDrawing = pcall(function()
    local d = Drawing.new("Line"); d:Remove()
end)

local function mkDraw(kind, props)
    if not HasDrawing then return nil end
    local ok, d = pcall(Drawing.new, kind)
    if not ok or not d then return nil end
    DespairUI.DrawCache[d] = true
    tins(DespairUI.Drawings, d)
    if props then for k, v in pairs(props) do pcall(function() d[k] = v end) end end
    pcall(function() d.Visible = props and props.Visible or false end)
    return d
end

