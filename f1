			Mk("TextLabel", {Parent=row, Position=UDim2.new(0,0,0,0), Size=UDim2.new(1,0,0,16), BackgroundTransparency=1, Text=p.Text, Font=Enum.Font.SourceSans, TextSize=14, TextColor3=FrontierLib.Theme.Text, TextXAlignment=Enum.TextXAlignment.Left})
			addTooltip(row, p.Tip)
			
			local btn = Mk("TextButton", {Parent=row, Position=UDim2.new(0,0,0,20), Size=UDim2.new(1,0,0,24), BackgroundColor3=FrontierLib.Theme.PanelDark, BorderColor3=FrontierLib.Theme.Border, Text="", AutoButtonColor=false})
			AddHover(btn, FrontierLib.Theme.PanelDark, FrontierLib.Theme.Hover)
			local valTxt = Mk("TextLabel", {Parent=btn, Position=UDim2.new(0,6,0,0), Size=UDim2.new(1,-24,1,0), BackgroundTransparency=1, Text="", Font=Enum.Font.SourceSans, TextSize=14, TextColor3=FrontierLib.Theme.SubText, TextXAlignment=Enum.TextXAlignment.Left, TextTruncate=Enum.TextTruncate.AtEnd})
			Mk("TextLabel", {Parent=btn, Position=UDim2.new(1,-16,0,0), Size=UDim2.new(0,12,1,0), BackgroundTransparency=1, Text="▼", Font=Enum.Font.SourceSans, TextSize=12, TextColor3=FrontierLib.Theme.SubText})

			local isMulti = p.Multi or false
			local items = p.Items or {}
			local state = isMulti and (p.Default or {}) or (p.Default or items[1])
			
			local function updateDisplay()
				if isMulti then
					local s={}; for k,v in pairs(state) do if v then s[#s+1]=k end end
					valTxt.Text = #s>0 and table.concat(s,", ") or "None"
				else valTxt.Text = tostring(state) end
				if p.Flag then FrontierLib.Flags[p.Flag] = state end
			end
			
			local menuOpen = false; local menuFrame = nil
			local function closeMenu() if menuFrame then menuFrame:Destroy(); menuFrame=nil; menuOpen=false end end
			
			btn.MouseButton1Click:Connect(function()
				if menuOpen then closeMenu(); return end
				menuOpen = true
				menuFrame = Mk("ScrollingFrame", {Parent=sg, Size=UDim2.new(0,btn.AbsoluteSize.X,0,math.min(#items*24+2, 150)), BackgroundColor3=FrontierLib.Theme.PanelDark, BorderColor3=FrontierLib.Theme.Border, ZIndex=1000, ScrollBarThickness=2, ScrollBarImageColor3=FrontierLib.Theme.Accent})
				menuFrame.Position = UDim2.new(0, btn.AbsolutePosition.X, 0, btn.AbsolutePosition.Y + btn.AbsoluteSize.Y)
				local ml = Mk("UIListLayout", {Parent=menuFrame, SortOrder=Enum.SortOrder.LayoutOrder})
				ml:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function() menuFrame.CanvasSize=UDim2.new(0,0,0,ml.AbsoluteContentSize.Y) end)
				
				for _, it in ipairs(items) do
					local itBtn = Mk("TextButton", {Parent=menuFrame, Size=UDim2.new(1,0,0,24), BackgroundTransparency=1, Text="  "..it, Font=Enum.Font.SourceSans, TextSize=14, TextColor3=FrontierLib.Theme.Text, TextXAlignment=Enum.TextXAlignment.Left, AutoButtonColor=false, ZIndex=1001})
					AddHover(itBtn, FrontierLib.Theme.PanelDark, FrontierLib.Theme.Hover)
					local isSel = isMulti and state[it] or state==it
					if isSel then itBtn.TextColor3 = FrontierLib.Theme.Accent end
					itBtn.MouseButton1Click:Connect(function()
						if isMulti then state[it] = not state[it]; isSel = state[it]
						else state = it; closeMenu() end
						itBtn.TextColor3 = isSel and FrontierLib.Theme.Accent or FrontierLib.Theme.Text
						updateDisplay(); if p.Callback then pcall(p.Callback, state) end
					end)
				end
			end)
			
			uis.InputBegan:Connect(function(i)
				if menuOpen and i.UserInputType==Enum.UserInputType.MouseButton1 then
					local mp = i.Position
					if not (mp.X >= menuFrame.AbsolutePosition.X and mp.X <= menuFrame.AbsolutePosition.X + menuFrame.AbsoluteSize.X and mp.Y >= menuFrame.AbsolutePosition.Y and mp.Y <= menuFrame.AbsolutePosition.Y + menuFrame.AbsoluteSize.Y) then
						local bp = btn.AbsolutePosition; local bs = btn.AbsoluteSize
						if not (mp.X >= bp.X and mp.X <= bp.X + bs.X and mp.Y >= bp.Y and mp.Y <= bp.Y + bs.Y) then closeMenu() end
					end
				end
			end)

			updateDisplay(); if p.Callback then pcall(p.Callback, state) end
			tinsert(WindowObj.Elements, {i=row, name=p.Text})
			return {Set=function(v) state=v; updateDisplay(); if p.Callback then pcall(p.Callback, state) end end, Refresh=function(ni) items=ni; closeMenu() end}
		end

		function tab:AddColorPicker(p)
			local row = Mk("Frame", {Parent=page, Size=UDim2.new(1,0,0,24), BackgroundTransparency=1})
			Mk("TextLabel", {Parent=row, Position=UDim2.new(0,0,0,0), Size=UDim2.new(0.5,0,1,0), BackgroundTransparency=1, Text=p.Text, Font=Enum.Font.SourceSans, TextSize=14, TextColor3=FrontierLib.Theme.Text, TextXAlignment=Enum.TextXAlignment.Left})
			addTooltip(row, p.Tip)
			
			local cBtn = Mk("TextButton", {Parent=row, Position=UDim2.new(1,-40,0,0), Size=UDim2.new(0,40,1,0), BackgroundColor3=p.Default or C3(1,1,1), BorderColor3=FrontierLib.Theme.Border, Text="", AutoButtonColor=false})
			
			local col = p.Default or C3(1,1,1)
			local rBox, gBox, bBox
			local menuOpen = false; local mFrame = nil
			local function closeMenu() if mFrame then mFrame:Destroy(); mFrame=nil; menuOpen=false end end
			local function update(c) 
				col=c; cBtn.BackgroundColor3=col; 
				if p.Flag then FrontierLib.Flags[p.Flag] = col end
				if p.Callback then pcall(p.Callback, col) end 
			end
			
			cBtn.MouseButton1Click:Connect(function()
				if menuOpen then closeMenu(); return end
				menuOpen = true
				mFrame = Mk("Frame", {Parent=sg, Size=UDim2.new(0,140,0,36), BackgroundColor3=FrontierLib.Theme.PanelDark, BorderColor3=FrontierLib.Theme.Border, ZIndex=1000})
				mFrame.Position = UDim2.new(0, cBtn.AbsolutePosition.X - 100, 0, cBtn.AbsolutePosition.Y + 28)
				
				local function mkInp(x, cv)
					local bx = Mk("TextBox", {Parent=mFrame, Position=UDim2.new(0,x,0,6), Size=UDim2.new(0,36,0,24), BackgroundColor3=FrontierLib.Theme.Bg, BorderColor3=FrontierLib.Theme.Border, Text=tostring(floor(cv*255)), Font=Enum.Font.SourceSans, TextSize=13, TextColor3=FrontierLib.Theme.Text, ZIndex=1001})
					return bx
				end
				rBox=mkInp(8, col.R); gBox=mkInp(52, col.G); bBox=mkInp(96, col.B)
				
				local function onTxt()
					local r,g,b = clamp(tonumber(rBox.Text) or 255,0,255), clamp(tonumber(gBox.Text) or 255,0,255), clamp(tonumber(bBox.Text) or 255,0,255)
					update(Color3.fromRGB(r,g,b))
				end
				rBox.FocusLost:Connect(onTxt); gBox.FocusLost:Connect(onTxt); bBox.FocusLost:Connect(onTxt)
			end)
			
			uis.InputBegan:Connect(function(i)
				if menuOpen and i.UserInputType==Enum.UserInputType.MouseButton1 then
					local mp = i.Position
					if mFrame and not (mp.X >= mFrame.AbsolutePosition.X and mp.X <= mFrame.AbsolutePosition.X + mFrame.AbsoluteSize.X and mp.Y >= mFrame.AbsolutePosition.Y and mp.Y <= mFrame.AbsolutePosition.Y + mFrame.AbsoluteSize.Y) then
						local bp = cBtn.AbsolutePosition; local bs = cBtn.AbsoluteSize
						if not (mp.X >= bp.X and mp.X <= bp.X + bs.X and mp.Y >= bp.Y and mp.Y <= bp.Y + bs.Y) then closeMenu() end
					end
				end
			end)

			if p.Flag then FrontierLib.Flags[p.Flag] = col end
			tinsert(WindowObj.Elements, {i=row, name=p.Text})
			return {Set=function(c) update(c) end}
		end

		function tab:AddKeybind(p)
			local row = Mk("Frame", {Parent=page, Size=UDim2.new(1,0,0,24), BackgroundTransparency=1})
			Mk("TextLabel", {Parent=row, Position=UDim2.new(0,0,0,0), Size=UDim2.new(0.5,0,1,0), BackgroundTransparency=1, Text=p.Text, Font=Enum.Font.SourceSans, TextSize=14, TextColor3=FrontierLib.Theme.Text, TextXAlignment=Enum.TextXAlignment.Left})
			addTooltip(row, p.Tip)
			
			local btn = Mk("TextButton", {Parent=row, Position=UDim2.new(1,-80,0,0), Size=UDim2.new(0,80,1,0), BackgroundColor3=FrontierLib.Theme.PanelDark, BorderColor3=FrontierLib.Theme.Border, Text="["..(p.Default or "None").."]", Font=Enum.Font.SourceSans, TextSize=13, TextColor3=FrontierLib.Theme.SubText, AutoButtonColor=false})
			AddHover(btn, FrontierLib.Theme.PanelDark, FrontierLib.Theme.Hover)
			
			local key = p.Default or "None"
			if key ~= "None" then FrontierLib.Keybinds[p.Text] = key end
			if p.Flag then FrontierLib.Flags[p.Flag] = key end
			
			local binding = false
			btn.MouseButton1Click:Connect(function()
				binding = true; btn.Text = "[...]"
				local c; c = uis.InputBegan:Connect(function(i)
					if i.UserInputType == Enum.UserInputType.Keyboard or i.UserInputType.Name:find("MouseButton") then
						local kn = i.KeyCode.Name
						local mt = i.UserInputType.Name
						local res = (kn == "Unknown" and mt) or kn
						if res == "Escape" or res == "Backspace" then key = "None" else key = res end
						btn.Text = "["..key.."]"; binding = false
						if key == "None" then FrontierLib.Keybinds[p.Text] = nil else FrontierLib.Keybinds[p.Text] = key end
						if p.Flag then FrontierLib.Flags[p.Flag] = key end
						if p.Callback then pcall(p.Callback, key) end
						c:Disconnect()
					end
				end)
			end)
			tinsert(WindowObj.Elements, {i=row, name=p.Text})
			return {Get=function() return key end}
		end
		
		function tab:AddButton(p)
			local row = Mk("Frame", {Parent=page, Size=UDim2.new(1,0,0,28), BackgroundTransparency=1})
			local btn = Mk("TextButton", {Parent=row, Size=UDim2.new(1,0,1,0), BackgroundColor3=FrontierLib.Theme.PanelDark, BorderColor3=FrontierLib.Theme.Border, Text=p.Text, Font=Enum.Font.SourceSans, TextSize=14, TextColor3=FrontierLib.Theme.Text, AutoButtonColor=false})
			addTooltip(row, p.Tip)
			AddHover(btn, FrontierLib.Theme.PanelDark, FrontierLib.Theme.Hover)
			
			btn.MouseButton1Click:Connect(function()
				btn.BackgroundColor3 = FrontierLib.Theme.Accent
				task.delay(.06,function() btn.BackgroundColor3 = FrontierLib.Theme.Hover end)
				if p.Callback then pcall(p.Callback) end
			end)
			tinsert(WindowObj.Elements, {i=row, name=p.Text})
		end

		function tab:AddTextInput(p)
			local row = Mk("Frame", {Parent=page, Size=UDim2.new(1,0,0,44), BackgroundTransparency=1})
			Mk("TextLabel", {Parent=row, Position=UDim2.new(0,0,0,0), Size=UDim2.new(1,0,0,16), BackgroundTransparency=1, Text=p.Text, Font=Enum.Font.SourceSans, TextSize=14, TextColor3=FrontierLib.Theme.Text, TextXAlignment=Enum.TextXAlignment.Left})
			addTooltip(row, p.Tip)
			
			local bx = Mk("TextBox", {Parent=row, Position=UDim2.new(0,0,0,20), Size=UDim2.new(1,0,0,24), BackgroundColor3=FrontierLib.Theme.Bg, BorderColor3=FrontierLib.Theme.Border, Text=p.Default or "", PlaceholderText=p.Placeholder or "...", Font=Enum.Font.SourceSans, TextSize=13, TextColor3=FrontierLib.Theme.Text, ClearTextOnFocus=false})
			if p.Flag then FrontierLib.Flags[p.Flag] = bx.Text end
			bx.FocusLost:Connect(function() 
				if p.Flag then FrontierLib.Flags[p.Flag] = bx.Text end
				if p.Callback then pcall(p.Callback, bx.Text) end 
			end)
			tinsert(WindowObj.Elements, {i=row, name=p.Text})
			return {Get=function() return bx.Text end, Set=function(v) bx.Text = tostring(v) end}
		end

		return tab
	end

	-- Keybinds Widget
	local kbWidget = Mk("Frame", {Parent=sg, Position=UDim2.new(0,20,0,200), Size=UDim2.new(0,180,0,30), BackgroundColor3=FrontierLib.Theme.PanelDark, BorderColor3=FrontierLib.Theme.Accent, BorderSizePixel=1, ZIndex=100, Visible=false})
	local kbHeader = Mk("TextLabel", {Parent=kbWidget, Size=UDim2.new(1,0,0,30), BackgroundTransparency=1, Text=" Keybinds", Font=Enum.Font.SourceSansSemibold, TextSize=14, TextColor3=FrontierLib.Theme.Accent, TextXAlignment=Enum.TextXAlignment.Left})
	local kbList = Mk("Frame", {Parent=kbWidget, Position=UDim2.new(0,0,0,30), Size=UDim2.new(1,0,1,-30), BackgroundTransparency=1})
	local kbLayout = Mk("UIListLayout", {Parent=kbList, SortOrder=Enum.SortOrder.LayoutOrder})
	
	local kbDrag = {act=false, st=ZV2, sp=nil}
	kbHeader.InputBegan:Connect(function(i) 
		if i.UserInputType==Enum.UserInputType.MouseButton1 then 
			kbDrag.act=true; kbDrag.st=V2(i.Position.X, i.Position.Y); kbDrag.sp=kbWidget.Position 
		end 
	end)
	uis.InputChanged:Connect(function(i) 
		if kbDrag.act and i.UserInputType==Enum.UserInputType.MouseMovement then 
			local d = V2(i.Position.X, i.Position.Y) - kbDrag.st
			kbWidget.Position = UDim2.new(0, kbDrag.sp.X.Offset + d.X, 0, kbDrag.sp.Y.Offset + d.Y) 
		end 
	end)
	kbHeader.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then kbDrag.act=false end end)

	local kbLabels = {}
	rs.RenderStepped:Connect(function()
		if not FrontierLib.Flags["ShowKeybindsWidget"] then 
			kbWidget.Visible = false 
			return 
		end
		
		local h = 30; local i = 1; local count = 0
		for name, k in pairs(FrontierLib.Keybinds) do
			count = count + 1
			local str = string.format(" %s: [%s]", name, k)
			if not kbLabels[i] then
				kbLabels[i] = Mk("TextLabel", {Parent=kbList, Size=UDim2.new(1,0,0,20), BackgroundTransparency=1, Font=Enum.Font.SourceSans, TextSize=13, TextColor3=FrontierLib.Theme.Text, TextXAlignment=Enum.TextXAlignment.Left})
			end
			kbLabels[i].Text = str; kbLabels[i].Visible = true
			h = h + 20; i = i + 1
		end
		for j = i, #kbLabels do kbLabels[j].Visible = false end
		
		if count == 0 then kbWidget.Visible = false else
			kbWidget.Visible = true
			kbWidget.Size = UDim2.new(0, 180, 0, h + 5)
		end
	end)

	-- Open/Close Insert logic
	uis.InputBegan:Connect(function(i, gpe)
		if gpe or uis:GetFocusedTextBox() then return end
		if i.KeyCode == Enum.KeyCode.Insert then root.Visible = not root.Visible end
	end)

	return WindowObj
end

return FrontierLib
