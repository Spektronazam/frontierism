                Parent=page, ZIndex=7,
                Size=UD2(1,0,0,20), BackgroundTransparency=1,
                Text=text, Font=Enum.Font.GothamMedium, TextSize=13,
                TextColor3=Theme.SubText, TextXAlignment=Enum.TextXAlignment.Left,
            })
            return { SetText=function(t) lbl.Text=t end }
        end

        -- Paragraph
        function tab:AddParagraph(title, body)
            local wrap = mk("Frame", {
                Parent=page, ZIndex=7,
                Size=UD2(1,0,0,0), AutomaticSize=Enum.AutomaticSize.Y,
                BackgroundColor3=Theme.Dark,
            })
            corner(wrap,6)
