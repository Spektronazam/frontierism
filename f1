-- ── UTILITY ──
local Connection = {}
Connection.__index = Connection
export type Connection = typeof(setmetatable({} :: {
    _conn: RBXScriptConnection?,
    _active: boolean,
}, Connection))

function Connection.new(conn: RBXScriptConnection?): Connection
    local self = setmetatable({}, Connection)
    self._conn = conn
    self._active = conn ~= nil
    return self
end

function Connection:Disconnect(): ()
    if self._conn and self._active then
        self._conn:Disconnect()
        self._active = false
    end
end

function Connection:IsActive(): boolean
    return self._active
end

local Signal = {}
Signal.__index = Signal
export type Signal<T...> = typeof(setmetatable({} :: {
    _connections: { { Callback: (T...) -> (), Connection: Connection } },
    _destroyed: boolean,
}, Signal))

function Signal.new<T...>(): Signal<T...>
    local self = setmetatable({}, Signal) :: any
    self._connections = {}
    self._destroyed = false
    return self
end

function Signal:Connect<T...>(fn: (T...) -> ()): Connection
    assert(not self._destroyed, "Cannot connect to destroyed Signal")
    local conn = Connection.new()
    table.insert(self._connections, { Callback = fn, Connection = conn })
    return conn
end

function Signal:Fire<T...>(...: T...)
    if self._destroyed then return end
    for _, data in ipairs(self._connections) do
        if data.Connection:IsActive() then
            task.spawn(data.Callback, ...)
        end
    end
end

function Signal:Destroy(): ()
    self._destroyed = true
    for _, data in ipairs(self._connections) do
        data.Connection:Disconnect()
    end
    table.clear(self._connections)
end

local TweenEngine = {}
TweenEngine.__index = TweenEngine
export type TweenEngine = typeof(setmetatable({} :: {
    _cache: { [Instance]: Tween },
}, TweenEngine))

function TweenEngine.new(): TweenEngine
    local self = setmetatable({}, TweenEngine)
    self._cache = setmetatable({}, { __mode = "k" })
    return self
end

function TweenEngine:Tween(
    object: Instance,
    properties: { [string]: any },
    duration: number?,
    style: Enum.EasingStyle?,
    direction: Enum.EasingDirection?
): Tween?
    if not object then return nil end
    duration = duration or 0.15
    style = style or Enum.EasingStyle.Quad
    direction = direction or Enum.EasingDirection.Out

    local existing = self._cache[object]
    if existing then
        pcall(function() existing:Cancel() end)
    end

    local ok, tween = pcall(function()
        return TweenService:Create(object, TweenInfo.new(duration :: number, style, direction), properties)
    end)

    if ok and tween then
        self._cache[object] = tween
        tween.Completed:Once(function()
            if self._cache[object] == tween then
                self._cache[object] = nil
            end
        end)
        tween:Play()
        return tween
    end
    return nil
end

function TweenEngine:Destroy(): ()
    for _, tween in pairs(self._cache) do
        pcall(function() tween:Cancel() end)
    end
    table.clear(self._cache)
end

-- ── DRAWING API ──
local DrawingCapable: boolean = pcall(function()
    local d = Drawing.new("Square")
    d:Remove()
end)

local DrawingFonts = DrawingCapable and Drawing.Fonts or { UI = 0, System = 1, Plex = 2, Monospace = 3 }

local DrawPool = {}
DrawPool.__index = DrawPool
export type DrawPool = typeof(setmetatable({} :: {
    _available: { any },
    _inUse: { any },
    _type: string,
}, DrawPool))

function DrawPool.new(typeName: string): DrawPool
    local self = setmetatable({}, DrawPool)
    self._available = {}
    self._inUse = {}
    self._type = typeName
    return self
end

function DrawPool:Acquire(props: { [string]: any }?): any
    local obj = table.remove(self._available)
    if not obj then
        local ok, d = pcall(Drawing.new, self._type)
        if ok then
            obj = d
        else
            return nil
        end
    end
    if props then
        for k, v in pairs(props) do
            pcall(function() obj[k] = v end)
        end
    end
    table.insert(self._inUse, obj)
    return obj
end

function DrawPool:Release(obj: any): ()
    for i, v in ipairs(self._inUse) do
        if v == obj then
            table.remove(self._inUse, i)
            pcall(function() obj.Visible = false end)
            table.insert(self._available, obj)
            break
        end
    end
end

function DrawPool:Clear(): ()
    for _, obj in ipairs(self._inUse) do
        pcall(function() obj:Remove() end)
    end
    for _, obj in ipairs(self._available) do
        pcall(function() obj:Remove() end)
    end
    table.clear(self._inUse)
    table.clear(self._available)
end

-- ── NOTIFICATION SYSTEM ──
local NotificationSystem = {}
NotificationSystem.__index = NotificationSystem
export type NotificationSystem = typeof(setmetatable({} :: {
    _active: { any },
    _pool: DrawPool,
    _screenSize: Vector2,
    _conn: Connection?,
    _styles: { [NotificationType]: { color: Color3, icon: string } },
}, NotificationSystem))

function NotificationSystem.new(): NotificationSystem
    local self = setmetatable({}, NotificationSystem)
    self._active = {}
    self._pool = DrawPool.new("Square")
    self._screenSize = Camera.ViewportSize
    self._styles = {
        info = { color = Color3.fromRGB(150, 180, 255), icon = "i" },
        success = { color = Color3.fromRGB(90, 255, 140), icon = "✓" },
        warning = { color = Color3.fromRGB(255, 210, 90), icon = "!" },
        error = { color = Color3.fromRGB(255, 80, 80), icon = "x" },
        orbit = { color = Color3.fromRGB(190, 120, 255), icon = "⟳" },
    }

    self._conn = Connection.new(RunService.RenderStepped:Connect(function(dt: number)
        self:_update(dt)
    end))

    return self
end

function NotificationSystem:_update(dt: number): ()
    local ok, vp = pcall(function() return Camera.ViewportSize end)
    if ok then
        self._screenSize = Vector2.new(math.max(vp.X, 1), math.max(vp.Y, 1))
    end

    local scale = 1.0
    local padX, padY = 14 * scale, 10 * scale
    local gap = 8 * scale
    local centerX = self._screenSize.X * 0.5
    local topY = 35
    local now = tick()
    local dead: { number }? = nil

    for i, n in ipairs(self._active) do
        local age = now - n.born
        local life = n.life
        local fadeIn = math.clamp(age / 0.14, 0, 1)
        local fadeOut = math.clamp((life - age) / 0.22, 0, 1)
        local alpha = math.min(fadeIn, fadeOut)

        n.offY = n.offY + (0 - n.offY) * math.clamp(1 - math.exp(-0.35 * dt * 12), 0, 1)

        if age > life then
            dead = dead or {}
            table.insert(dead, i)
            for _, obj in ipairs(n.objects) do
                pcall(function() obj.Visible = false end)
            end
        else
            n.textObj.Text = n.msg
            n.textObj.Color = Color3.fromRGB(255, 255, 255)
            local tb = n.textObj.TextBounds
            local bw = tb.X + padX * 2 + 34 * scale
            local bh = math.max(tb.Y + padY * 2, 32)
            local px, py = centerX - bw / 2, topY + (i - 1) * (bh + gap) + n.offY

            n.bg.Size = Vector2.new(bw, bh)
            n.bg.Position = Vector2.new(px, py)
            n.bg.Color = Color3.fromRGB(30, 30, 30)
            n.bg.Transparency = 0.95 * alpha
            n.bg.Visible = true

            n.bord.Size = Vector2.new(bw, bh)
            n.bord.Position = Vector2.new(px, py)
            n.bord.Color = Color3.fromRGB(20, 20, 20)
            n.bord.Transparency = 0.8 * alpha
            n.bord.Visible = true

            n.icon.Text = n.iconStr
            n.icon.Color = n.color
            n.icon.Position = Vector2.new(px + 18 * scale, py + bh / 2 - 7 * scale)
            n.icon.Transparency = 0.95 * alpha
            n.icon.Visible = true

            n.textObj.Position = Vector2.new(px + 34 * scale, py + padY - 1)
            n.textObj.Transparency = 0.95 * alpha
            n.textObj.Visible = true

            local pct = math.clamp(1 - (age / life), 0, 1)
            n.prog.Size = Vector2.new(bw * pct, 2)
            n.prog.Position = Vector2.new(px, py + bh - 2)
            n.prog.Color = n.color
            n.prog.Transparency = 0.8 * alpha
            n.prog.Visible = true
        end
    end

    if dead then
        for j = #dead, 1, -1 do
            local idx = dead[j]
            local n = table.remove(self._active, idx)
            for _, obj in ipairs(n.objects) do
                pcall(function() obj.Visible = false end)
                self._pool:Release(obj)
            end
        end
    end
end

function NotificationSystem:Notify(config: NotificationConfig): ()
    if not DrawingCapable then return end

    local style = self._styles[config.Type or "info"] or self._styles.info
    local msg = string.sub(tostring(config.Message), 1, 160)
    local life = config.Duration or 3

    local bg = self._pool:Acquire({ Filled = true, ZIndex = 11001 })
    local bord = self._pool:Acquire({ Filled = false, Thickness = 1, ZIndex = 11002 })
    local tx = self._pool:Acquire({ Size = 14, ZIndex = 11003, Outline = true, Font = DrawingFonts.Plex })
    local icon = self._pool:Acquire({ Size = 14, ZIndex = 11003, Center = true, Outline = true, Font = DrawingFonts.Plex })
    local prog = self._pool:Acquire({ Filled = true, ZIndex = 11002 })

    if not (bg and bord and tx and icon and prog) then return end

    table.insert(self._active, {
        msg = msg,
        born = tick(),
        life = life,
        color = style.color,
        iconStr = style.icon,
        offY = -18,
        objects = { bg, bord, tx, icon, prog },
        bg = bg,
        bord = bord,
        textObj = tx,
        icon = icon,
        prog = prog,
    })
end

function NotificationSystem:Destroy(): ()
    if self._conn then
        self._conn:Disconnect()
    end
    self._pool:Clear()
    table.clear(self._active)
end

-- ── CONFIG SYSTEM ──
local ConfigSystem = {}
ConfigSystem.__index = ConfigSystem
export type ConfigSystem = typeof(setmetatable({} :: {
    _fileName: string?,
    _data: { [string]: any },
    _dirty: boolean,
}, ConfigSystem))

function ConfigSystem.new(fileName: string?): ConfigSystem
    local self = setmetatable({}, ConfigSystem)
    self._fileName = fileName
    self._data = {}
    self._dirty = false
    if fileName then
        self:Load()
    end
    return self
end

function ConfigSystem:Load(): boolean
    if not self._fileName then return false end
    local ok, content = pcall(function()
        if readfile then
            return readfile(self._fileName)
        end
        return nil
    end)
    if ok and content then
        local parseOk, data = pcall(HttpService.JSONDecode, HttpService, content)
        if parseOk and typeof(data) == "table" then
            self._data = data :: { [string]: any }
            return true
        end
    end
    return false
end

function ConfigSystem:Save(): boolean
    if not self._fileName then return false end
    local ok, content = pcall(function()
        return HttpService:JSONEncode(self._data)
    end)
    if ok and content and writefile then
        local writeOk = pcall(function()
            writefile(self._fileName, content)
        end)
        return writeOk
    end
    return false
end

function ConfigSystem:Get(key: string): any
    return self._data[key]
end

function ConfigSystem:Set(key: string, value: any): ()
    self._data[key] = value
    self._dirty = true
    if self._fileName then
        task.defer(function()
            if self._dirty then
                self._dirty = false
                self:Save()
            end
        end)
    end
end

function ConfigSystem:Destroy(): ()
    if self._dirty then
        self:Save()
    end
    table.clear(self._data)
end

-- ── HELPERS ──
local function mk(className: string, props: { [string]: any }?): Instance?
    local ok, inst = pcall(Instance.new, className)
    if not ok or not inst then return nil end
    if props then
        for k, v in pairs(props) do
            pcall(function() (inst :: any)[k] = v end)
        end
    end
    return inst
end

local function addTooltip(target: GuiObject, text: string?, ttFrame: Frame, ttText: TextLabel): ()
    if not text or text == "" then return end
    Connection.new(target.MouseEnter:Connect(function()
        ttText.Text = " " .. text .. " "
        ttFrame.Size = UDim2.new(0, ttText.TextBounds.X + 8, 0, 22)
        ttFrame.Visible = true
    end))
    Connection.new(target.MouseLeave:Connect(function()
        ttFrame.Visible = false
    end))
end

local function addHover(
    btn: GuiObject,
    tweenEngine: TweenEngine,
    normal: Color3,
    hover: Color3
): ()
    Connection.new(btn.MouseEnter:Connect(function()
        tweenEngine:Tween(btn, { BackgroundColor3 = hover }, 0.15)
    end))
    Connection.new(btn.MouseLeave:Connect(function()
        tweenEngine:Tween(btn, { BackgroundColor3 = normal }, 0.15)
    end))
end

