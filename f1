function Tab:AddTextInput(config: TextInputConfig): {
    Set: (string, boolean?) -> (),
    Get: () -> string,
    Destroy: () -> (),
}
    local theme = self._window._theme

    local configKey = self._name .. "_" .. config.Text .. "_text"
    local savedValue = self._window:_LoadValue(configKey)
    local text: string = if savedValue ~= nil then savedValue else (config.Default or "")

    local row: Frame = mk("Frame", {
        Parent = self._page,
        Size = UDim2.new(1, 0, 0, 44),
        BackgroundTransparency = 1,
    }) :: Frame

    local lbl: TextLabel = mk("TextLabel", {
        Parent = row,
        Position = UDim2.new(0, 0, 0, 0),
        Size = UDim2.new(1, 0, 0, 16),
        BackgroundTransparency = 1,
        Text = config.Text,
        Font = Enum.Font.Ubuntu,
        TextSize = 13,
        TextColor3 = theme.Text,
        TextXAlignment = Enum.TextXAlignment.Left,
    }) :: TextLabel

    addTooltip(row, config.Tip, self._window._tooltipFrame, self._window._tooltipText)

    local bx: TextBox = mk("TextBox", {
        Parent = row,
        Position = UDim2.new(0, 0, 0, 20),
        Size = UDim2.new(1, 0, 0, 24),
        BackgroundColor3 = theme.PanelDark,
        BorderColor3 = theme.Border,
        Text = text,
        PlaceholderText = config.Placeholder or "...",
        Font = Enum.Font.Ubuntu,
        TextSize = 12,
        TextColor3 = theme.Text,
        ClearTextOnFocus = false,
    }) :: TextBox

    local function onFocusLost()
        local raw = bx.Text
        if config.Numeric then
            local num = tonumber(raw)
            if num then
                bx.Text = tostring(num)
            else
                bx.Text = text
                return
            end
        end
        text = bx.Text
        self._window:_SaveValue(configKey, text)
        if config.Callback then
            pcall(config.Callback, text)
        end
    end

    if config.Finished then
        Connection.new(bx.FocusLost:Connect(onFocusLost))
    else
        Connection.new(bx:GetPropertyChangedSignal("Text"):Connect(function()
            text = bx.Text
            self._window:_SaveValue(configKey, text)
            if config.Callback then
                pcall(config.Callback, text)
            end
        end))
    end

    local api = {
        Set = function(txt: string, silent: boolean?)
            text = txt
            bx.Text = text
            self._window:_SaveValue(configKey, text)
            if config.Callback and not silent then
                pcall(config.Callback, text)
            end
        end,
        Get = function(): string
            return text
        end,
        Destroy = function()
            row:Destroy()
        end,
    }

    self._window:_RegisterElement(row, config.Text, api)
    return api
end

-- ── MODULE FUNCTIONS ──
function DespairUI:Notify(config: NotificationConfig): ()
    self._notifications:Notify(config)
end

function DespairUI:SetTheme(name: ThemeName): ()
    self._theme = Themes[name] or Themes.Default
end

function DespairUI:Destroy(): ()
    for _, conn in ipairs(self._connections) do
        conn:Disconnect()
    end
    table.clear(self._connections)

    for _, win in ipairs(self._windows) do
        if win and win.Parent then
            pcall(function() win:Destroy() end)
        end
    end
    table.clear(self._windows)

    self._notifications:Destroy()
    self._tweenEngine:Destroy()

    if self._config then
        self._config:Destroy()
    end
end

-- ── RETURN ──
return ModuleInstance
