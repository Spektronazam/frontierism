-- ── WINDOW CREATION ──
function DespairUI:CreateWindow(config: WindowConfig): Window
    config = config or {}
    local accent: Color3 = config.Accent or self._accent
    local themeName: ThemeName = config.Theme or "Default"
    local theme: ThemeColors = Themes[themeName] or Themes.Default
    local useConfig: string? = config.UseConfig
    local configSystem: ConfigSystem? = useConfig and ConfigSystem.new(useConfig) or nil

    local coreGui: Instance = (function()
        local ok, hui = pcall(gethui)
        if ok and hui then return hui end
        ok, hui = pcall(function() return game:GetService("CoreGui") end)
        if ok and hui then return hui end
        return LocalPlayer:WaitForChild("PlayerGui")
    end)()

    local sg: ScreenGui = mk("ScreenGui", {
        Parent = coreGui,
        Name = "DespairUI_" .. tostring(tick()),
        ResetOnSpawn = false,
        IgnoreGuiInset = true,
        ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
    }) :: ScreenGui

    table.insert(self._windows, sg)

    -- Tooltip
    local ttFrame: Frame = mk("Frame", {
        Parent = sg,
        Size = UDim2.new(0, 0, 0, 22),
        BackgroundColor3 = theme.PanelDark,
        BorderColor3 = theme.Border,
        BorderSizePixel = 1,
        Visible = false,
        ZIndex = 10000,
    }) :: Frame
    local ttText: TextLabel = mk("TextLabel", {
        Parent = ttFrame,
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        Font = Enum.Font.Ubuntu,
        TextSize = 12,
        TextColor3 = theme.Text,
        ZIndex = 10001,
    }) :: TextLabel

    local ttConn = Connection.new(RunService.RenderStepped:Connect(function()
        if ttFrame.Visible then
            local mp = UserInputService:GetMouseLocation()
            ttFrame.Position = UDim2.new(0, mp.X + 12, 0, mp.Y + 12)
        end
    end))
    table.insert(self._connections, ttConn)

    -- Main Frame
    local winW: number = config.Size and config.Size.X or 680
    local winH: number = config.Size and config.Size.Y or 480
    local root: Frame = mk("Frame", {
        Parent = sg,
        Size = UDim2.new(0, winW, 0, winH),
        Position = config.Position or UDim2.new(0.5, -winW / 2, 0.5, -winH / 2),
        BackgroundColor3 = theme.Bg,
        BorderColor3 = theme.Border,
        BorderSizePixel = 1,
        ZIndex = 5,
    }) :: Frame

    -- Topbar
    local topbar: Frame = mk("Frame", {
        Parent = root,
        Size = UDim2.new(1, 0, 0, 30),
        BackgroundColor3 = theme.Topbar,
        BorderSizePixel = 0,
    }) :: Frame
    mk("Frame", {
        Parent = topbar,
        Size = UDim2.new(1, 0, 0, 1),
        Position = UDim2.new(0, 0, 1, 0),
        BackgroundColor3 = theme.Border,
        BorderSizePixel = 0,
    })
    mk("TextLabel", {
        Parent = topbar,
        Position = UDim2.new(0, 10, 0, 0),
        Size = UDim2.new(1, -10, 1, 0),
        BackgroundTransparency = 1,
        Text = config.Title or "Despair UI",
        Font = Enum.Font.Ubuntu,
        TextSize = 14,
        TextColor3 = theme.Text,
        TextXAlignment = Enum.TextXAlignment.Left,
    })

    -- Dragging
    local dragBtn: TextButton = mk("TextButton", {
        Parent = topbar,
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        Text = "",
    }) :: TextButton

    local window: Window = setmetatable({
        _screenGui = sg,
        _root = root,
        _topbar = topbar,
        _sidebar = nil :: any,
        _content = nil :: any,
        _searchBox = nil :: any,
        _tabList = nil :: any,
        _tabs = {},
        _activeTab = nil,
        _elements = {},
        _keybinds = {},
        _keybindWidget = nil,
        _config = config,
        _theme = theme,
        _accent = accent,
        _tweenEngine = self._tweenEngine,
        _notifications = self._notifications,
        _configSystem = configSystem,
        _tooltipFrame = ttFrame,
        _tooltipText = ttText,
        _dragging = false,
        _dragStart = Vector2.zero,
        _dragPos = UDim2.new(),
        _visible = true,
    }, Window) :: any

    Connection.new(dragBtn.InputBegan:Connect(function(input: InputObject)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            window._dragging = true
            window._dragStart = Vector2.new(input.Position.X, input.Position.Y)
            window._dragPos = root.Position
        end
    end))
    Connection.new(UserInputService.InputChanged:Connect(function(input: InputObject)
        if window._dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = Vector2.new(input.Position.X, input.Position.Y) - window._dragStart
            root.Position = UDim2.new(
                window._dragPos.X.Scale,
                window._dragPos.X.Offset + delta.X,
                window._dragPos.Y.Scale,
                window._dragPos.Y.Offset + delta.Y
            )
        end
    end))
    Connection.new(dragBtn.InputEnded:Connect(function(input: InputObject)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            window._dragging = false
        end
    end))

    -- Sidebar
    local sidebar: Frame = mk("Frame", {
        Parent = root,
        Position = UDim2.new(0, 0, 0, 31),
        Size = UDim2.new(0, 140, 1, -31),
        BackgroundColor3 = theme.Sidebar,
        BorderSizePixel = 0,
    }) :: Frame
    window._sidebar = sidebar
    mk("Frame", {
        Parent = sidebar,
        Size = UDim2.new(0, 1, 1, 0),
        Position = UDim2.new(1, 0, 0, 0),
        BackgroundColor3 = theme.Border,
        BorderSizePixel = 0,
    })

    -- Search
    local searchBox: TextBox = mk("TextBox", {
        Parent = sidebar,
        Size = UDim2.new(1, -10, 0, 24),
        Position = UDim2.new(0, 5, 0, 5),
        BackgroundColor3 = theme.PanelDark,
        BorderColor3 = theme.Border,
        TextColor3 = theme.Text,
        PlaceholderText = "Search...",
        Font = Enum.Font.Ubuntu,
        TextSize = 12,
    }) :: TextBox
    window._searchBox = searchBox

    local tabList: ScrollingFrame = mk("ScrollingFrame", {
        Parent = sidebar,
        Position = UDim2.new(0, 0, 0, 34),
        Size = UDim2.new(1, 0, 1, -34),
        BackgroundTransparency = 1,
        ScrollBarThickness = 2,
        ScrollBarImageColor3 = accent,
        BorderSizePixel = 0,
    }) :: ScrollingFrame
    window._tabList = tabList
    mk("UIListLayout", {
        Parent = tabList,
        SortOrder = Enum.SortOrder.LayoutOrder,
    })

    -- Content
    local content: Frame = mk("Frame", {
        Parent = root,
        Position = UDim2.new(0, 141, 0, 31),
        Size = UDim2.new(1, -141, 1, -31),
        BackgroundTransparency = 1,
    }) :: Frame
    window._content = content

    -- Search functionality
    Connection.new(searchBox:GetPropertyChangedSignal("Text"):Connect(function()
        local query: string = string.lower(searchBox.Text)
        for _, el in ipairs(window._elements) do
            if query == "" then
                el.Instance.Visible = true
            else
                el.Instance.Visible = string.find(string.lower(el.Name), query) ~= nil
            end
        end
        for _, tab in ipairs(window._tabs) do
            tab._layout:ApplyLayout()
        end
    end))

    -- Toggle Key
    local toggleKey: Enum.KeyCode = config.ToggleKey or Enum.KeyCode.Insert
    Connection.new(UserInputService.InputBegan:Connect(function(input: InputObject, gpe: boolean)
        if gpe or UserInputService:GetFocusedTextBox() then return end
        if input.KeyCode == toggleKey then
            window._visible = not window._visible
            root.Visible = window._visible
        end
    end))

    -- Keybind Widget
    window:_BuildKeybindWidget()

    return window
end

-- ── WINDOW INTERNALS ──
function Window:_BuildKeybindWidget(): ()
    local theme = self._theme
    local accent = self._accent

    local widget: Frame = mk("Frame", {
        Parent = self._screenGui,
        Position = UDim2.new(0, 20, 0, Camera.ViewportSize.Y - 100),
        Size = UDim2.new(0, 180, 0, 30),
        BackgroundColor3 = theme.PanelDark,
        BorderColor3 = accent,
        BorderSizePixel = 1,
        ZIndex = 100,
    }) :: Frame
    self._keybindWidget = widget

    local header: TextLabel = mk("TextLabel", {
        Parent = widget,
        Size = UDim2.new(1, 0, 0, 30),
        BackgroundTransparency = 1,
        Text = " Keybinds",
        Font = Enum.Font.Ubuntu,
        TextSize = 13,
        TextColor3 = accent,
        TextXAlignment = Enum.TextXAlignment.Left,
    }) :: TextLabel

    local list: Frame = mk("Frame", {
        Parent = widget,
        Position = UDim2.new(0, 0, 0, 30),
        Size = UDim2.new(1, 0, 1, -30),
        BackgroundTransparency = 1,
    }) :: Frame
    mk("UIListLayout", {
        Parent = list,
        SortOrder = Enum.SortOrder.LayoutOrder,
    })

    local dragging = false
    local dragStart = Vector2.zero
    local dragPos = UDim2.new()
    Connection.new(header.InputBegan:Connect(function(input: InputObject)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = Vector2.new(input.Position.X, input.Position.Y)
            dragPos = widget.Position
        end
    end))
    Connection.new(UserInputService.InputChanged:Connect(function(input: InputObject)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = Vector2.new(input.Position.X, input.Position.Y) - dragStart
            widget.Position = UDim2.new(
                dragPos.X.Scale, dragPos.X.Offset + delta.X,
                dragPos.Y.Scale, dragPos.Y.Offset + delta.Y
            )
        end
    end))
    Connection.new(header.InputEnded:Connect(function(input: InputObject)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end))

    local kbLabels: { TextLabel } = {}
    Connection.new(RunService.RenderStepped:Connect(function()
        local h = 30
        local i = 1
        for name, k in pairs(self._keybinds) do
            local str = string.format(" %s: [%s]", name, k)
            if not kbLabels[i] then
                kbLabels[i] = mk("TextLabel", {
                    Parent = list,
                    Size = UDim2.new(1, 0, 0, 20),
                    BackgroundTransparency = 1,
                    Font = Enum.Font.Ubuntu,
                    TextSize = 12,
                    TextColor3 = theme.Text,
                    TextXAlignment = Enum.TextXAlignment.Left,
                }) :: TextLabel
            end
            kbLabels[i].Text = str
            kbLabels[i].Visible = true
            h = h + 20
            i = i + 1
        end
        for j = i, #kbLabels do
            kbLabels[j].Visible = false
        end
        widget.Size = UDim2.new(0, 180, 0, h + 5)
    end))
end

function Window:_RegisterElement(instance: GuiObject, name: string, api: any): any
    table.insert(self._elements, { Instance = instance, Name = name, API = api })
    return api
end

function Window:_SaveValue(key: string, value: any): ()
    if self._configSystem then
        self._configSystem:Set(key, value)
    end
end

function Window:_LoadValue(key: string): any
    if self._configSystem then
        return self._configSystem:Get(key)
    end
    return nil
end

