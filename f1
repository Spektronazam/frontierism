    local TitleText  = cfg.Title      or "Despair UI"
    local ToggleKey  = cfg.ToggleKey  or Enum.KeyCode.Insert
    local winW       = (cfg.Size and cfg.Size.X) or 700
    local winH       = (cfg.Size and cfg.Size.Y) or 500

    -- Root ScreenGui
    local sg = mk("ScreenGui", {
        Parent           = CoreParent,
        Name             = "DespairUI_" .. tk(),
        ResetOnSpawn     = false,
        IgnoreGuiInset   = true,
        ZIndexBehavior   = Enum.ZIndexBehavior.Sibling,
        DisplayOrder     = 999,
    })
    tins(self.Windows, sg)

    -- ── Tooltip ───────────────────────────────────────────────
    local ttFrame = mk("Frame", {
        Parent = sg, Visible = false, ZIndex = 10000,
        Size = UD2(0,0,0,22), BackgroundColor3 = Theme.Dark,
    })
    corner(ttFrame, 4)
    stroke(ttFrame, Theme.Border, 1)
    local ttText = mk("TextLabel", {
        Parent = ttFrame, Size = UD2(1,0,1,0), BackgroundTransparency = 1,
        Font = Enum.Font.GothamMedium, TextSize = 12, TextColor3 = Theme.SubText, ZIndex = 10001,
    })

    hook(RS.RenderStepped:Connect(function()
        if ttFrame.Visible then
            local mp = UIS:GetMouseLocation()
            ttFrame.Position = UD2(0, mp.X+14, 0, mp.Y+14)
        end
    end))

    local function addTooltip(inst, text)
        if not text or text == "" then return end
        hook(inst.MouseEnter:Connect(function()
            ttText.Text = "  " .. text .. "  "
            ttFrame.Size = UD2(0, ttText.TextBounds.X + 10, 0, 22)
            ttFrame.Visible = true
        end))
        hook(inst.MouseLeave:Connect(function() ttFrame.Visible = false end))
    end

    -- ── Root Frame ────────────────────────────────────────────
    local root = mk("Frame", {
        Parent = sg,
        Size   = UD2(0, winW, 0, winH),
        Position = UD2(0.5, -winW/2, 0.5, -winH/2),
        BackgroundColor3 = Theme.Bg,
        ZIndex = 5,
        ClipsDescendants = true,
    })
    corner(root, 8)
    stroke(root, Theme.Border, 1)

    -- Drop shadow (subtle outer frame)
    local shadow = mk("Frame", {
        Parent = root, ZIndex = 4,
        Size = UD2(1, 12, 1, 12),
        Position = UD2(0, -6, 0, -6),
        BackgroundColor3 = BLACK,
        BackgroundTransparency = 0.72,
    })
    corner(shadow, 12)

    -- ── Topbar ────────────────────────────────────────────────
    local topbar = mk("Frame", {
        Parent = root, ZIndex = 6,
        Size = UD2(1, 0, 0, 36),
        BackgroundColor3 = Theme.Topbar,
    })
    mk("Frame", {
        Parent = topbar, ZIndex = 6,
        Size = UD2(1,0,0,1), Position = UD2(0,0,1,-1),
        BackgroundColor3 = Theme.Border,
    })

    -- Accent stripe at very top
    mk("Frame", {
        Parent = topbar, ZIndex = 7,
        Size = UD2(0,42,0,2), Position = UD2(0,10,0,0),
        BackgroundColor3 = Accent,
    })

    local title = mk("TextLabel", {
        Parent = topbar, ZIndex = 7,
        Position = UD2(0,12,0,0), Size = UD2(1,-120,1,0),
        BackgroundTransparency = 1,
        Text = TitleText,
        Font = Enum.Font.GothamBold, TextSize = 14,
        TextColor3 = Theme.Text, TextXAlignment = Enum.TextXAlignment.Left,
    })

    -- Minimize / Close buttons
    local function topBtn(label, xOff, hoverCol)
        local b = mk("TextButton", {
            Parent = topbar, ZIndex = 8,
            Position = UD2(1, xOff, 0, 6),
            Size = UD2(0, 22, 0, 22),
            BackgroundColor3 = Theme.Panel,
            Text = label, Font = Enum.Font.GothamBold,
            TextSize = 12, TextColor3 = Theme.SubText,
            AutoButtonColor = false,
        })
        corner(b, 5)
        b.MouseEnter:Connect(function() Tw(b,{BackgroundColor3=hoverCol},0.12) end)
        b.MouseLeave:Connect(function() Tw(b,{BackgroundColor3=Theme.Panel},0.12) end)
        return b
    end

    local btnClose = topBtn("✕", -28, C3(200,60,60))
    local btnMin   = topBtn("–", -56, Theme.Hover)

    local minimised = false
    hook(btnMin.MouseButton1Click:Connect(function()
        minimised = not minimised
        Tw(root, {Size = minimised and UD2(0,winW,0,36) or UD2(0,winW,0,winH)}, 0.22)
    end))
    hook(btnClose.MouseButton1Click:Connect(function()
        Tw(root, {BackgroundTransparency=1}, 0.18)
        task.delay(0.2, function() root.Visible = false; root.BackgroundTransparency = 0 end)
    end))

    -- ── Dragging (clamped to screen) ──────────────────────────
    local drag = { active=false, start=ZV2, startPos=nil }

    local dragBtn = mk("TextButton", {
        Parent = topbar, ZIndex = 9,
        Size = UD2(1,-116,1,0), BackgroundTransparency=1, Text="",
    })
    hook(dragBtn.InputBegan:Connect(function(i)
        if i.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
        drag.active=true; drag.start=V2(i.Position.X,i.Position.Y); drag.startPos=root.Position
    end))
    hook(UIS.InputChanged:Connect(function(i)
        if not drag.active or i.UserInputType ~= Enum.UserInputType.MouseMovement then return end
        local d = V2(i.Position.X,i.Position.Y) - drag.start
        local nx = clamp(drag.startPos.X.Offset+d.X, 0, Screen.W-winW)
        local ny = clamp(drag.startPos.Y.Offset+d.Y, 0, Screen.H-winH)
        root.Position = UD2(0,nx,0,ny)
    end))
    hook(dragBtn.InputEnded:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 then drag.active=false end
    end))

    -- ── Sidebar ───────────────────────────────────────────────
    local SIDE_W = 148
    local sidebar = mk("Frame", {
        Parent = root, ZIndex = 6,
        Position = UD2(0,0,0,37),
        Size = UD2(0,SIDE_W,1,-37),
        BackgroundColor3 = Theme.Sidebar,
    })
    mk("Frame", {
        Parent = sidebar, ZIndex = 6,
        Size = UD2(0,1,1,0), Position = UD2(1,-1,0,0),
        BackgroundColor3 = Theme.Border,
    })

    -- Search box
    local searchBox = mk("TextBox", {
        Parent = sidebar, ZIndex = 7,
        Size = UD2(1,-14,0,26), Position = UD2(0,7,0,7),
        BackgroundColor3 = Theme.Dark,
        PlaceholderText = "  🔍 Search...",
        PlaceholderColor3 = Theme.SubText,
        Text = "", ClearTextOnFocus = false,
        Font = Enum.Font.Gotham, TextSize = 12,
        TextColor3 = Theme.Text, TextXAlignment = Enum.TextXAlignment.Left,
    })
    corner(searchBox, 5)
    stroke(searchBox, Theme.Border)

    -- Tab list
    local tabList = mk("ScrollingFrame", {
        Parent = sidebar, ZIndex = 6,
        Position = UD2(0,0,0,40), Size = UD2(1,0,1,-40),
        BackgroundTransparency = 1,
        ScrollBarThickness = 2, ScrollBarImageColor3 = Accent,
        BorderSizePixel = 0, CanvasSize = UD2(0,0,0,0),
    })
    local tabLayout = mk("UIListLayout", { Parent=tabList, SortOrder=Enum.SortOrder.LayoutOrder })
    hook(tabLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        tabList.CanvasSize = UD2(0,0,0, tabLayout.AbsoluteContentSize.Y)
    end))

    -- ── Content area ──────────────────────────────────────────
    local content = mk("Frame", {
        Parent = root, ZIndex = 6,
        Position = UD2(0, SIDE_W+1, 0, 37),
        Size = UD2(1, -(SIDE_W+1), 1, -37),
        BackgroundTransparency = 1,
        ClipsDescendants = true,
    })

    -- ── Window state ──────────────────────────────────────────
    local Window = { Tabs={}, ActiveTab=nil, Elements={}, Keybinds={} }

    -- Search filtering
    hook(searchBox:GetPropertyChangedSignal("Text"):Connect(function()
        local q = slow(searchBox.Text)
        for _, el in ipairs(Window.Elements) do
            if el.i and el.name then
                el.i.Visible = (q == "") or (sfind(slow(el.name), q, 1, true) ~= nil)
            end
        end
    end))

    -- ── AddHover helper ───────────────────────────────────────
    local function hoverFX(btn, norm, hov)
        hook(btn.MouseEnter:Connect(function() Tw(btn,{BackgroundColor3=hov},0.12) end))
        hook(btn.MouseLeave:Connect(function() Tw(btn,{BackgroundColor3=norm},0.12) end))
    end

    -- ── ADD TAB ───────────────────────────────────────────────
    function Window:AddTab(name, icon)
        local tab = { Name = name }

        -- Sidebar button
        local btn = mk("TextButton", {
            Parent = tabList, ZIndex = 7,
            Size = UD2(1,-8,0,32),
            BackgroundColor3 = Theme.Sidebar,
            Text = (icon and icon.." " or "  ") .. name,
            Font = Enum.Font.GothamMedium, TextSize = 13,
            TextColor3 = Theme.SubText,
            TextXAlignment = Enum.TextXAlignment.Left,
            AutoButtonColor = false,
        })
        corner(btn, 5)
        mk("UIPadding", { Parent=btn, PaddingLeft=UDS(0,8) })

        local indicator = mk("Frame", {
            Parent = btn, ZIndex = 8,
            Size = UD2(0,3,0.6,0), Position = UD2(0,0,0.2,0),
            BackgroundColor3 = Accent, Visible = false,
        })
        corner(indicator, 2)

        -- Page
        local page = mk("ScrollingFrame", {
            Parent = content, ZIndex = 6,
            Size = UD2(1,0,1,0), BackgroundTransparency = 1,
            Visible = false,
            ScrollBarThickness = 3, ScrollBarImageColor3 = Accent,
            BorderSizePixel = 0, CanvasSize = UD2(0,0,0,0),
        })
        local pageLayout = mk("UIListLayout", {
            Parent = page, SortOrder = Enum.SortOrder.LayoutOrder,
            Padding = UDS(0,5),
        })
        mk("UIPadding", {
            Parent = page,
            PaddingTop=UDS(0,10), PaddingLeft=UDS(0,10),
            PaddingRight=UDS(0,12), PaddingBottom=UDS(0,10),
        })
        hook(pageLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
            page.CanvasSize = UD2(0,0,0, pageLayout.AbsoluteContentSize.Y+20)
        end))

        tab.page = page; tab.btn = btn; tab.indicator = indicator

        -- Activate tab
        local function activateTab()
            if Window.ActiveTab == tab then return end
            if Window.ActiveTab then
                local prev = Window.ActiveTab
                Tw(prev.page, {GroupTransparency=1}, 0.14)
                task.delay(0.14, function() if prev.page then prev.page.Visible=false end end)
                Tw(prev.btn, {BackgroundColor3=Theme.Sidebar}, 0.14)
                prev.btn.TextColor3 = Theme.SubText
                prev.indicator.Visible = false
            end
            Window.ActiveTab = tab
            page.Visible = true; page.GroupTransparency = 1
            Tw(page, {GroupTransparency=0}, 0.18)
            Tw(btn, {BackgroundColor3=Theme.Hover}, 0.14)
            btn.TextColor3 = Theme.Text
            indicator.Visible = true
        end

        hook(btn.MouseButton1Click:Connect(activateTab))
        tins(Window.Tabs, tab)
        if #Window.Tabs == 1 then task.defer(activateTab) end

