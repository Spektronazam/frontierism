    -- ── Keybind Widget ────────────────────────────────────────
    local kbWidget=mk("Frame",{
        Parent=sg, ZIndex=100,
        Position=UD2(0,16,1,-120),
        Size=UD2(0,190,0,34),
        BackgroundColor3=Theme.Dark,
    })
    corner(kbWidget,6); stroke(kbWidget,Accent,1)

    local kbHeader=mk("TextLabel",{Parent=kbWidget,ZIndex=101,Size=UD2(1,0,0,32),BackgroundTransparency=1,Text=" ⌨ Keybinds",Font=Enum.Font.GothamBold,TextSize=12,TextColor3=Accent,TextXAlignment=Enum.TextXAlignment.Left})

    local kbBody=mk("Frame",{Parent=kbWidget,ZIndex=101,Position=UD2(0,0,0,32),Size=UD2(1,0,1,-32),BackgroundTransparency=1})
    mk("UIListLayout",{Parent=kbBody,SortOrder=Enum.SortOrder.LayoutOrder})

    -- Drag keybind widget
    local kbDrag={act=false,st=ZV2,sp=nil}
    hook(kbHeader.InputBegan:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 then
            kbDrag.act=true; kbDrag.st=V2(i.Position.X,i.Position.Y); kbDrag.sp=kbWidget.Position
        end
    end))
    hook(UIS.InputChanged:Connect(function(i)
        if kbDrag.act and i.UserInputType==Enum.UserInputType.MouseMovement then
            local d=V2(i.Position.X,i.Position.Y)-kbDrag.st
            kbWidget.Position=UD2(kbDrag.sp.X.Scale,kbDrag.sp.X.Offset+d.X,kbDrag.sp.Y.Scale,kbDrag.sp.Y.Offset+d.Y)
        end
    end))
    hook(kbHeader.InputEnded:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 then kbDrag.act=false end
    end))

    local kbLabels={}
    hook(RS.RenderStepped:Connect(function()
        local totalH=34; local idx=1
        for name,k in pairs(Window.Keybinds) do
            if not kbLabels[idx] then
                kbLabels[idx]=mk("TextLabel",{Parent=kbBody,ZIndex=102,Size=UD2(1,0,0,18),BackgroundTransparency=1,Font=Enum.Font.Gotham,TextSize=12,TextColor3=Theme.Text,TextXAlignment=Enum.TextXAlignment.Left})
                mk("UIPadding",{Parent=kbLabels[idx],PaddingLeft=UDS(0,8)})
            end
            kbLabels[idx].Text=fmt("%s  [%s]",name,k)
            kbLabels[idx].Visible=true
            totalH=totalH+18; idx=idx+1
        end
        for j=idx,#kbLabels do kbLabels[j].Visible=false end
        kbWidget.Size=UD2(0,190,0,totalH+6)
    end))

    -- ── Toggle Visibility ─────────────────────────────────────
    hook(UIS.InputBegan:Connect(function(i,gpe)
        if gpe or UIS:GetFocusedTextBox() then return end
        if i.KeyCode==ToggleKey then
            root.Visible = not root.Visible
        end
    end))

    -- Fade in on open
    root.BackgroundTransparency = 1
    Tw(root,{BackgroundTransparency=0},0.25)

    return Window
end

-- ── CLEANUP ───────────────────────────────────────────────────
function DespairUI:Destroy()
    for _,c in ipairs(self.Connections) do
        if c and c.Connected then pcall(c.Disconnect,c) end
    end
    self.Connections={}
    for _,w in ipairs(self.Windows) do pcall(function() if w and w.Parent then w:Destroy() end end) end
    self.Windows={}
    for _,d in ipairs(self.Drawings) do pcall(function() d.Visible=false; d:Remove() end) end
    self.Drawings={}
    self.DrawCache=setmetatable({},{ __mode="k" })
    Nf.active={}; Nf.pool={}
end

return DespairUI
