-- Resolve best UI parent: gethui → CoreGui → PlayerGui
local CoreParent = (function()
    local r = safeGet(function() return gethui() end)
    if r then return r end
    r = safeGet(function() return game:GetService("CoreGui") end)
    if r then return r end
    return lp:WaitForChild("PlayerGui")
end)()

